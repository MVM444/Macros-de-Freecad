        btn_circuit_up = QtWidgets.QPushButton("Subir")
        btn_circuit_down = QtWidgets.QPushButton("Bajar")
        btn_clear_circuits = QtWidgets.QPushButton("Automatico")
        circuit_buttons.addWidget(btn_refresh_circuits, 0, 0)
        circuit_buttons.addWidget(btn_clear_circuits, 0, 1)
