class _AcometidaDialog(QtWidgets.QWidget):
    def __init__(self, doc, parent=None):
        super(_AcometidaDialog, self).__init__(parent)
        self.doc = doc
        self.items = _candidate_objects(doc)
        self.wire_items = _candidate_wires(doc)
        self.area_items = _candidate_area_objects(doc)
        self.state = _load_state()
        self.setObjectName("AcometidaRoot")
        self.setMinimumWidth(620)
        self.setStyleSheet(_acometida_form_qss())

        vbox = QtWidgets.QVBoxLayout(self)

        self.cb_medidor = QtWidgets.QComboBox()
        self.cb_tablero = QtWidgets.QComboBox()
        for obj in self.items:
            txt = f"{_safe_text(getattr(obj, 'Label', obj.Name))} ({obj.Name})"
            self.cb_medidor.addItem(txt, obj.Name)
            self.cb_tablero.addItem(txt, obj.Name)

        self.cb_wire_manual = QtWidgets.QComboBox()
        self.cb_wire_manual.addItem("(Auto - crear ruta)", "")
        for obj in self.wire_items:
            txt = f"{_safe_text(getattr(obj, 'Label', obj.Name))} ({obj.Name})"
            self.cb_wire_manual.addItem(txt, obj.Name)

        self.cb_area_obj = QtWidgets.QComboBox()
        self.cb_area_obj.addItem("(Ninguno)", "")
        for obj in self.area_items:
            a = _shape_area_m2(obj)
            txt = f"{_safe_text(getattr(obj, 'Label', obj.Name))} ({obj.Name}) [{a:.3f} m2]"
            self.cb_area_obj.addItem(txt, obj.Name)

        self.cb_system = QtWidgets.QComboBox()
        self.cb_system.addItems(["1F-2H 120/240", "3F-4H 120/208", "3F-4H 277/480"])
        self.cb_norma = QtWidgets.QComboBox()
        self.cb_norma.addItems(["CR", "NEC"])
        self.cb_demanda_metodo = QtWidgets.QComboBox()
        self.cb_demanda_metodo.addItem("Manual (VA)", "MANUAL")
        self.cb_demanda_metodo.addItem("Por area (VA/m2)", "AREA")
        self.cb_demanda_metodo.addItem("Mayor (manual/area)", "MAYOR")

        self.sp_va_m2 = QtWidgets.QDoubleSpinBox()
        self.sp_va_m2.setRange(0.0, 10000.0)
        self.sp_va_m2.setDecimals(3)
        self.sp_va_m2.setValue(_default_va_m2("CR"))

        self.sp_vln = QtWidgets.QDoubleSpinBox()
        self.sp_vln.setRange(0.0, 1000.0)
        self.sp_vln.setDecimals(1)
        self.sp_vln.setValue(120.0)

        self.sp_vll = QtWidgets.QDoubleSpinBox()
        self.sp_vll.setRange(0.0, 1000.0)
        self.sp_vll.setDecimals(1)
        self.sp_vll.setValue(240.0)

        self.sp_demanda_va = QtWidgets.QDoubleSpinBox()
        self.sp_demanda_va.setRange(0.0, 100000000.0)
        self.sp_demanda_va.setDecimals(1)
        self.sp_demanda_va.setSingleStep(100.0)
        self.sp_demanda_va.setValue(25000.0)

        self.sp_pf = QtWidgets.QDoubleSpinBox()
        self.sp_pf.setRange(0.10, 1.00)
        self.sp_pf.setSingleStep(0.01)
        self.sp_pf.setDecimals(2)
        self.sp_pf.setValue(0.95)

        self.sp_growth = QtWidgets.QDoubleSpinBox()
        self.sp_growth.setRange(0.0, 300.0)
        self.sp_growth.setDecimals(1)
        self.sp_growth.setValue(25.0)

        self.sp_breaker = QtWidgets.QSpinBox()
        self.sp_breaker.setRange(0, 6000)
        self.sp_breaker.setValue(100)

        self.cb_material = QtWidgets.QComboBox()
        self.cb_material.addItems(["Cu", "Al"])

        self.cb_awg = QtWidgets.QComboBox()
        self.cb_awg.addItems(AWG_ORDER)
        self.cb_awg.setCurrentText("2")

        self.lb_demanda_area = QtWidgets.QLabel("0.0 VA (0.000 kVA)")
        self.lb_demanda_usada = QtWidgets.QLabel("0.0 VA (0.000 kVA)")
        self.lb_i_nom = QtWidgets.QLabel("0.000 A")
        self.lb_i_diseno = QtWidgets.QLabel("0.000 A")
        self.lb_breaker_calc = QtWidgets.QLabel("-")
        self.lb_conductor_calc = QtWidgets.QLabel("-")
        self.lb_va_breaker_nom = QtWidgets.QLabel("0.0 VA")
        self.lb_va_conductor_nom = QtWidgets.QLabel("0.0 VA")

        self.sp_zroute = QtWidgets.QDoubleSpinBox()
        self.sp_zroute.setRange(-10000.0, 100000.0)
        self.sp_zroute.setDecimals(1)
        self.sp_zroute.setValue(2500.0)

        self.chk_use_manual_wire = QtWidgets.QCheckBox("Usar wire manual para longitud/calculo")
        self.chk_use_manual_wire.setChecked(False)

        self.chk_reuse = QtWidgets.QCheckBox("Reemplazar wire anterior de esta misma acometida")
        self.chk_reuse.setChecked(True)
        self.chk_project_group = QtWidgets.QCheckBox("Crear/usar grupo Proyecto_Acometida")
        self.chk_project_group.setChecked(True)

        self.sp_area_total = QtWidgets.QDoubleSpinBox()
        self.sp_area_total.setRange(0.0, 1000000.0)
        self.sp_area_total.setDecimals(3)
        self.sp_area_total.setValue(0.0)

        self.ed_notes = QtWidgets.QLineEdit()
        self.ed_notes.setPlaceholderText("Notas u observaciones")

        gb_basicos = QtWidgets.QGroupBox("Datos basicos")
        form_basicos = QtWidgets.QFormLayout(gb_basicos)
        form_basicos.addRow("Medidor:", self.cb_medidor)
        form_basicos.addRow("Tablero principal:", self.cb_tablero)
        form_basicos.addRow("Wire ruta manual:", self.cb_wire_manual)
        form_basicos.addRow("", self.chk_use_manual_wire)
        form_basicos.addRow("Altura ruta Z (mm):", self.sp_zroute)
        form_basicos.addRow("Area total proyecto (m2):", self.sp_area_total)
        form_basicos.addRow("Objeto area proyecto:", self.cb_area_obj)
        form_basicos.addRow("", self.chk_project_group)
        form_basicos.addRow("", self.chk_reuse)
        form_basicos.addRow("Observaciones:", self.ed_notes)

        gb_auto = QtWidgets.QGroupBox("Datos calculados por demanda (auto NEC/CR)")
        form_auto = QtWidgets.QFormLayout(gb_auto)
        form_auto.addRow("Sistema:", self.cb_system)
        form_auto.addRow("Voltaje L-N (V):", self.sp_vln)
        form_auto.addRow("Voltaje L-L (V):", self.sp_vll)
        form_auto.addRow("Normativa:", self.cb_norma)
        form_auto.addRow("Metodo demanda:", self.cb_demanda_metodo)
        form_auto.addRow("Carga base (VA/m2):", self.sp_va_m2)
        form_auto.addRow("Demanda manual (VA):", self.sp_demanda_va)
        form_auto.addRow("Demanda area auto:", self.lb_demanda_area)
        form_auto.addRow("Demanda usada:", self.lb_demanda_usada)
        form_auto.addRow("Factor de potencia:", self.sp_pf)
        form_auto.addRow("Crecimiento (%):", self.sp_growth)
        form_auto.addRow("I nominal estimada:", self.lb_i_nom)
        form_auto.addRow("I diseno estimada:", self.lb_i_diseno)
        form_auto.addRow("Breaker calculado:", self.lb_breaker_calc)
        form_auto.addRow("Conductor calculado:", self.lb_conductor_calc)

        gb_manual = QtWidgets.QGroupBox("Seleccion manual final")
        form_manual = QtWidgets.QFormLayout(gb_manual)
        form_manual.addRow("Breaker seleccionado (A):", self.sp_breaker)
        form_manual.addRow("Material conductor:", self.cb_material)
        form_manual.addRow("Conductor seleccionado (AWG):", self.cb_awg)
        form_manual.addRow("VA nominal breaker:", self.lb_va_breaker_nom)
        form_manual.addRow("VA nominal conductor:", self.lb_va_conductor_nom)

        sel_box = QtWidgets.QGroupBox("Seleccion con ventana abierta")
        sel_grid = QtWidgets.QGridLayout(sel_box)
        self.btn_pick_medidor = QtWidgets.QPushButton("Tomar seleccion -> Medidor")
        self.btn_pick_tablero = QtWidgets.QPushButton("Tomar seleccion -> Tablero")
        self.btn_pick_wire_manual = QtWidgets.QPushButton("Tomar seleccion -> Wire manual")
        self.btn_pick_area = QtWidgets.QPushButton("Tomar seleccion -> Area proyecto")
        self.btn_refresh = QtWidgets.QPushButton("Refrescar listas")
        sel_grid.addWidget(self.btn_pick_medidor, 0, 0)
        sel_grid.addWidget(self.btn_pick_tablero, 0, 1)
        sel_grid.addWidget(self.btn_pick_wire_manual, 1, 0)
        sel_grid.addWidget(self.btn_pick_area, 1, 1)
        sel_grid.addWidget(self.btn_refresh, 2, 0, 1, 2)

        tabs = QtWidgets.QTabWidget()
        tab_basicos = QtWidgets.QWidget()
        lay_basicos = QtWidgets.QVBoxLayout(tab_basicos)
        lay_basicos.addWidget(gb_basicos)
        lay_basicos.addWidget(sel_box)
        lay_basicos.addStretch(1)

        tab_auto = QtWidgets.QWidget()
        lay_auto = QtWidgets.QVBoxLayout(tab_auto)
        lay_auto.addWidget(gb_auto)
        lay_auto.addStretch(1)

        tab_manual = QtWidgets.QWidget()
        lay_manual = QtWidgets.QVBoxLayout(tab_manual)
        lay_manual.addWidget(gb_manual)
        lay_manual.addStretch(1)

        tabs.addTab(tab_basicos, "Datos Basicos")
        tabs.addTab(tab_auto, "Demanda Auto")
        tabs.addTab(tab_manual, "Seleccion Final")
        vbox.addWidget(tabs)

        self.cb_system.currentIndexChanged.connect(self._apply_system_defaults)
        self.cb_norma.currentIndexChanged.connect(self._on_norma_changed)
        self.cb_area_obj.currentIndexChanged.connect(self._on_area_obj_changed)
        self.cb_wire_manual.currentIndexChanged.connect(self._on_manual_wire_changed)
        self.cb_demanda_metodo.currentIndexChanged.connect(self._update_preview)
        self.sp_va_m2.valueChanged.connect(self._update_preview)
        self.sp_demanda_va.valueChanged.connect(self._update_preview)
        self.sp_vln.valueChanged.connect(self._update_preview)
        self.sp_vll.valueChanged.connect(self._update_preview)
        self.sp_pf.valueChanged.connect(self._update_preview)
        self.sp_growth.valueChanged.connect(self._update_preview)
        self.sp_area_total.valueChanged.connect(self._update_preview)
        self.sp_breaker.valueChanged.connect(self._update_preview)
        self.cb_material.currentIndexChanged.connect(self._update_preview)
        self.cb_awg.currentIndexChanged.connect(self._update_preview)
        self.btn_pick_medidor.clicked.connect(lambda: self._assign_from_selection("medidor"))
        self.btn_pick_tablero.clicked.connect(lambda: self._assign_from_selection("tablero"))
        self.btn_pick_wire_manual.clicked.connect(lambda: self._assign_from_selection("wire_manual"))
        self.btn_pick_area.clicked.connect(lambda: self._assign_from_selection("area_obj"))
        self.btn_refresh.clicked.connect(self._refresh_dynamic_lists)
        self._apply_system_defaults()
        self._on_norma_changed()
        self._apply_state_defaults()
        self._prefill_from_selection()
        self._update_preview()

    def _prefill_from_selection(self):
        sel = list(Gui.Selection.getSelection() or [])
        if len(sel) >= 1:
            self._set_combo_obj(self.cb_medidor, sel[0])
        if len(sel) >= 2:
            self._set_combo_obj(self.cb_tablero, sel[1])
        if len(sel) >= 3:
            self._set_combo_obj(self.cb_wire_manual, sel[2])
            self.chk_use_manual_wire.setChecked(True)
        if len(sel) >= 4:
            self._set_combo_obj(self.cb_area_obj, sel[3])
            self._on_area_obj_changed()
        self._update_preview()

    def _set_combo_obj(self, combo, obj):
        if obj is None:
            return
        name = _safe_text(getattr(obj, "Name", ""))
        self._set_combo_name(combo, name)

    def _set_combo_name(self, combo, name):
        if not name:
            return
        for i in range(combo.count()):
            if _safe_text(combo.itemData(i)) == name:
                combo.setCurrentIndex(i)
                return

    def _obj_display_text(self, obj, with_area=False):
        base = f"{_safe_text(getattr(obj, 'Label', obj.Name))} ({obj.Name})"
        if with_area:
            a = _shape_area_m2(obj)
            return f"{base} [{a:.3f} m2]"
        return base

    def _ensure_combo_has_object(self, combo, obj, with_area=False):
        if obj is None:
            return
        name = _safe_text(getattr(obj, "Name", "")).strip()
        if not name:
            return
        for i in range(combo.count()):
            if _safe_text(combo.itemData(i)).strip() == name:
                combo.setCurrentIndex(i)
                return
        combo.addItem(self._obj_display_text(obj, with_area=with_area), name)
        combo.setCurrentIndex(combo.count() - 1)

    def _current_selection_object(self):
        sel = list(Gui.Selection.getSelection() or [])
        if sel:
            return sel[0]
        try:
            sx = list(Gui.Selection.getSelectionEx() or [])
            for s in sx:
                obj = getattr(s, "Object", None)
                if obj is not None:
                    return obj
        except Exception:
            pass
        return None

    def _assign_from_selection(self, target):
        obj = self._current_selection_object()
        if obj is None:
            _log_w("No hay seleccion activa para capturar.")
            return
        if target == "medidor":
            self._ensure_combo_has_object(self.cb_medidor, obj, with_area=False)
            return
        if target == "tablero":
            self._ensure_combo_has_object(self.cb_tablero, obj, with_area=False)
            return
        if target == "wire_manual":
            self._ensure_combo_has_object(self.cb_wire_manual, obj, with_area=False)
            self.chk_use_manual_wire.setChecked(True)
            return
        if target == "area_obj":
            self._ensure_combo_has_object(self.cb_area_obj, obj, with_area=True)
            self._on_area_obj_changed()
            return

    def _refresh_dynamic_lists(self):
        cur_wire_manual = _safe_text(self.cb_wire_manual.currentData()).strip()
        cur_area_obj = _safe_text(self.cb_area_obj.currentData()).strip()

        self.wire_items = _candidate_wires(self.doc)
        self.area_items = _candidate_area_objects(self.doc)

        self.cb_wire_manual.clear()
        self.cb_wire_manual.addItem("(Auto - crear ruta)", "")
        for obj in self.wire_items:
            self.cb_wire_manual.addItem(self._obj_display_text(obj, with_area=False), obj.Name)

        self.cb_area_obj.clear()
        self.cb_area_obj.addItem("(Ninguno)", "")
        for obj in self.area_items:
            self.cb_area_obj.addItem(self._obj_display_text(obj, with_area=True), obj.Name)

        self._set_combo_name(self.cb_wire_manual, cur_wire_manual)
        self._set_combo_name(self.cb_area_obj, cur_area_obj)
        self._update_preview()

    def _apply_state_defaults(self):
        st = self.state or {}
        self._set_combo_name(self.cb_medidor, _safe_text(st.get("medidor_name")))
        self._set_combo_name(self.cb_tablero, _safe_text(st.get("tablero_name")))
        self._set_combo_name(self.cb_wire_manual, _safe_text(st.get("wire_manual_name")))
        self._set_combo_name(self.cb_area_obj, _safe_text(st.get("area_obj_name")))
        if _safe_text(st.get("sistema")):
            idx = self.cb_system.findText(_safe_text(st.get("sistema")))
            if idx >= 0:
                self.cb_system.setCurrentIndex(idx)
        normativa = _safe_text(st.get("normativa")).strip().upper()
        if normativa in AREA_LOAD_DEFAULTS:
            self.cb_norma.setCurrentText(normativa)
        demand_method = _safe_text(st.get("demand_method")).strip().upper()
        if demand_method:
            idx = self.cb_demanda_metodo.findData(demand_method)
            if idx >= 0:
                self.cb_demanda_metodo.setCurrentIndex(idx)
        if _to_float(st.get("carga_base_va_m2"), -1.0) >= 0:
            self.sp_va_m2.setValue(_to_float(st.get("carga_base_va_m2"), self.sp_va_m2.value()))
        if _to_float(st.get("demanda_va_manual"), -1.0) >= 0:
            self.sp_demanda_va.setValue(_to_float(st.get("demanda_va_manual"), self.sp_demanda_va.value()))
        elif _to_float(st.get("demanda_kva"), -1.0) >= 0:
            self.sp_demanda_va.setValue(_to_float(st.get("demanda_kva"), 0.0) * 1000.0)
        if _to_float(st.get("pf"), -1.0) > 0:
            self.sp_pf.setValue(_to_float(st.get("pf"), self.sp_pf.value()))
        if _to_float(st.get("growth_pct"), -1.0) >= 0:
            self.sp_growth.setValue(_to_float(st.get("growth_pct"), self.sp_growth.value()))
        if _to_int(st.get("breaker_sel"), -1) >= 0:
            self.sp_breaker.setValue(_to_int(st.get("breaker_sel"), self.sp_breaker.value()))
        if _to_float(st.get("z_route_mm"), -1.0) > -1.0:
            self.sp_zroute.setValue(_to_float(st.get("z_route_mm"), self.sp_zroute.value()))
        if _to_float(st.get("area_total_m2"), -1.0) >= 0:
            self.sp_area_total.setValue(_to_float(st.get("area_total_m2"), self.sp_area_total.value()))
        use_m = bool(st.get("use_manual_wire", False))
        self.chk_use_manual_wire.setChecked(use_m)
        self.chk_project_group.setChecked(bool(st.get("use_project_group", True)))
        if _safe_text(st.get("material")) in ("Cu", "Al"):
            self.cb_material.setCurrentText(_safe_text(st.get("material")))
        if _safe_text(st.get("awg_sel")):
            self.cb_awg.setCurrentText(_safe_text(st.get("awg_sel")))
        self._update_preview()

    def _on_norma_changed(self):
        norma = _safe_text(self.cb_norma.currentText()).strip().upper()
        self.sp_va_m2.setValue(_default_va_m2(norma))
        self._update_preview()

    def _on_area_obj_changed(self):
        name = _safe_text(self.cb_area_obj.currentData()).strip()
        if not name:
            self._update_preview()
            return
        obj = self.doc.getObject(name)
        if obj is None:
            self._update_preview()
            return
        a = _shape_area_m2(obj)
        if _is_wire_like_object(obj) and not _is_closed_object(obj):
            _log_w(f"El objeto '{name}' no esta cerrado; no se puede usar como area de proyecto.")
        if a > 0:
            self.sp_area_total.setValue(a)
        else:
            _log_w(f"El objeto '{name}' no tiene area valida para calculo.")
        self._update_preview()

    def _on_manual_wire_changed(self):
        if _safe_text(self.cb_wire_manual.currentData()).strip():
            self.chk_use_manual_wire.setChecked(True)
        self._update_preview()

    def _update_preview(self):
        sistema = _safe_text(self.cb_system.currentText()).strip()
        poles = _system_poles(sistema)
        v_ll = max(_to_float(self.sp_vll.value(), 0.0), 0.0)
        pf = max(min(_to_float(self.sp_pf.value(), 1.0), 1.0), 0.0)
        growth = max(_to_float(self.sp_growth.value(), 0.0), 0.0)
        demand_method = _safe_text(self.cb_demanda_metodo.currentData()).strip().upper() or "MANUAL"
        area_total_m2 = max(_to_float(self.sp_area_total.value(), 0.0), 0.0)
        va_m2 = max(_to_float(self.sp_va_m2.value(), 0.0), 0.0)
        demanda_manual_va = max(_to_float(self.sp_demanda_va.value(), 0.0), 0.0)
        demanda_area_va = area_total_m2 * va_m2
        if demand_method == "AREA":
            demanda_usada_va = demanda_area_va
        elif demand_method == "MAYOR":
            demanda_usada_va = max(demanda_manual_va, demanda_area_va)
        else:
            demanda_usada_va = demanda_manual_va

        va_per_amp = _va_per_amp(v_ll, poles)
        i_nom = (demanda_usada_va / va_per_amp) if va_per_amp > 0 else 0.0
        i_diseno = i_nom * (1.0 + (growth / 100.0)) * 1.25
        breaker_calc = _next_breaker(i_diseno)
        material = _safe_text(self.cb_material.currentText()).strip() or "Cu"
        awg_sel = _safe_text(self.cb_awg.currentText()).strip() or "12"
        conductor_calc = _awg_for_current(material, max(i_diseno, breaker_calc))

        breaker_sel = _to_int(self.sp_breaker.value(), 0)
        amp_table = _ampacity_table(material)
        amp_sel = _to_float(amp_table.get(awg_sel, 0.0), 0.0)
        va_nom_breaker = breaker_sel * va_per_amp
        va_nom_conductor = amp_sel * va_per_amp

        self.lb_demanda_area.setText(f"{demanda_area_va:.1f} VA ({demanda_area_va / 1000.0:.3f} kVA)")
        self.lb_demanda_usada.setText(f"{demanda_usada_va:.1f} VA ({demanda_usada_va / 1000.0:.3f} kVA)")
        self.lb_i_nom.setText(f"{i_nom:.3f} A")
        self.lb_i_diseno.setText(f"{i_diseno:.3f} A")
        self.lb_breaker_calc.setText(f"{breaker_calc} A")
        self.lb_conductor_calc.setText(_safe_text(conductor_calc))
        self.lb_va_breaker_nom.setText(f"{va_nom_breaker:.1f} VA")
        self.lb_va_conductor_nom.setText(f"{va_nom_conductor:.1f} VA")

    def _apply_system_defaults(self):
        s = _safe_text(self.cb_system.currentText())
        if "120/208" in s:
            self.sp_vln.setValue(120.0)
            self.sp_vll.setValue(208.0)
        elif "277/480" in s:
            self.sp_vln.setValue(277.0)
            self.sp_vll.setValue(480.0)
        else:
            self.sp_vln.setValue(120.0)
            self.sp_vll.setValue(240.0)

    def _obj_by_name(self, name):
        return self.doc.getObject(_safe_text(name).strip())

    def values(self):
        medidor = self._obj_by_name(self.cb_medidor.currentData())
        tablero = self._obj_by_name(self.cb_tablero.currentData())
        demanda_va_manual = _to_float(self.sp_demanda_va.value(), 0.0)
        return {
            "medidor": medidor,
            "tablero": tablero,
            "wire_manual_obj": self._obj_by_name(self.cb_wire_manual.currentData()),
            "area_obj": self._obj_by_name(self.cb_area_obj.currentData()),
            "sistema": _safe_text(self.cb_system.currentText()).strip(),
            "normativa": _safe_text(self.cb_norma.currentText()).strip().upper() or "CR",
            "demand_method": _safe_text(self.cb_demanda_metodo.currentData()).strip().upper() or "MANUAL",
            "carga_base_va_m2": _to_float(self.sp_va_m2.value(), _default_va_m2("CR")),
            "v_ln": _to_float(self.sp_vln.value(), 0.0),
            "v_ll": _to_float(self.sp_vll.value(), 0.0),
            "demanda_va_manual": demanda_va_manual,
            "demanda_kva": demanda_va_manual / 1000.0,
            "pf": _to_float(self.sp_pf.value(), 1.0),
            "growth_pct": _to_float(self.sp_growth.value(), 0.0),
            "breaker_sel": _to_int(self.sp_breaker.value(), 0),
            "material": _safe_text(self.cb_material.currentText()).strip() or "Cu",
            "awg_sel": _safe_text(self.cb_awg.currentText()).strip() or "12",
            "use_manual_wire": bool(self.chk_use_manual_wire.isChecked()),
            "z_route_mm": _to_float(self.sp_zroute.value(), 0.0),
            "area_total_m2": _to_float(self.sp_area_total.value(), 0.0),
            "use_project_group": bool(self.chk_project_group.isChecked()),
            "reuse_wire": bool(self.chk_reuse.isChecked()),
            "notes": _safe_text(self.ed_notes.text()).strip(),
        }


def _find_existing_wire(doc, label):
    for obj in getattr(doc, "Objects", []) or []:
        if _safe_text(getattr(obj, "Label", "")) != label:
            continue
        t = _safe_text(getattr(obj, "TypeId", "")).lower()
        if "wire" in t or "part::part2dobject" in t or hasattr(obj, "Points"):
            return obj
    return None


def _system_poles(system_text):
    s = _safe_text(system_text).upper()
    if s.startswith("3F"):
        return 3
    return 2


def _va_per_amp(v_ll, poles):
    v = max(_to_float(v_ll, 0.0), 0.0)
    p = _to_int(poles, 2)
    if v <= 0:
        return 0.0
    if p >= 3:
        return math.sqrt(3.0) * v
    return v


class _AcometidaTaskPanel:
    def __init__(self, doc):
        self.form = _AcometidaDialog(doc, parent=None)
        self._done = False
        self._result = QtWidgets.QDialog.Rejected
        self._values = {}

    def getStandardButtons(self):
        return int(QtWidgets.QDialogButtonBox.Ok | QtWidgets.QDialogButtonBox.Cancel)

    def accept(self):
        self._values = self.form.values()
        self._result = QtWidgets.QDialog.Accepted
        self._done = True
        return True

    def reject(self):
        self._result = QtWidgets.QDialog.Rejected
        self._done = True
        return True


def _run_task_panel_blocking(panel):
    used_task_panel = False
    try:
        if hasattr(Gui, "Control") and hasattr(Gui.Control, "showDialog"):
            Gui.Control.showDialog(panel)
            used_task_panel = True
        else:
            raise RuntimeError("Gui.Control.showDialog no disponible")
    except Exception as ex:
        _log_w(f"Task Panel no disponible ({ex}); se usa dialogo clasico.")
        dlg = QtWidgets.QDialog()
        dlg.setWindowTitle("Formulario Acometida")
        dlg.setMinimumWidth(700)
        lay = QtWidgets.QVBoxLayout(dlg)
        lay.addWidget(panel.form)
        btns = QtWidgets.QDialogButtonBox(QtWidgets.QDialogButtonBox.Ok | QtWidgets.QDialogButtonBox.Cancel)
        btns.accepted.connect(dlg.accept)
        btns.rejected.connect(dlg.reject)
        lay.addWidget(btns)
        try:
            if QtCore is not None:
                dlg.setWindowModality(QtCore.Qt.NonModal)
            dlg.setModal(False)
        except Exception:
            pass
        dlg.show()
        while dlg.isVisible():
            try:
                QtWidgets.QApplication.processEvents()
                if hasattr(Gui, "updateGui"):
                    Gui.updateGui()
            except Exception:
                pass
            time.sleep(0.02)
        if dlg.result() == QtWidgets.QDialog.Accepted:
            return QtWidgets.QDialog.Accepted, panel.form.values()
        return QtWidgets.QDialog.Rejected, {}

    while used_task_panel and not bool(getattr(panel, "_done", False)):
        try:
            QtWidgets.QApplication.processEvents()
            if hasattr(Gui, "updateGui"):
                Gui.updateGui()
        except Exception:
            pass
        time.sleep(0.02)

    if used_task_panel:
        try:
            Gui.Control.closeDialog()
        except Exception:
            pass
    return getattr(panel, "_result", QtWidgets.QDialog.Rejected), getattr(panel, "_values", {})


def registrar_acometida_y_ruta():
    doc = App.ActiveDocument
    if doc is None:
        doc = App.newDocument("Electrico")

    panel = _AcometidaTaskPanel(doc)
    result, data = _run_task_panel_blocking(panel)
    if result != QtWidgets.QDialog.Accepted:
        _log_i("Operacion cancelada por usuario.")
        return

    medidor = data["medidor"]
    tablero = data["tablero"]
    if medidor is None or tablero is None:
        _log_e("Debe seleccionar medidor y tablero principal.")
        return
    if medidor.Name == tablero.Name:
        _log_e("Medidor y tablero no pueden ser el mismo objeto.")
        return

    sistema = data["sistema"]
    normativa = _safe_text(data.get("normativa", "CR")).strip().upper()
    if normativa not in AREA_LOAD_DEFAULTS:
        normativa = "CR"
    metodo_demanda = _safe_text(data.get("demand_method", "MANUAL")).strip().upper()
    if metodo_demanda not in ("MANUAL", "AREA", "MAYOR"):
        metodo_demanda = "MANUAL"
    carga_base_va_m2 = max(_to_float(data.get("carga_base_va_m2"), _default_va_m2(normativa)), 0.0)
    poles = _system_poles(sistema)
    v_ll = max(_to_float(data["v_ll"], 0.0), 0.001)
    demanda_manual_va = max(_to_float(data.get("demanda_va_manual"), -1.0), 0.0)
    if demanda_manual_va <= 0.0:
        demanda_manual_va = max(_to_float(data.get("demanda_kva"), 0.0), 0.0) * 1000.0
    demanda_manual_kva = demanda_manual_va / 1000.0
    pf = max(min(_to_float(data["pf"], 1.0), 1.0), 0.0)
    growth = max(_to_float(data["growth_pct"], 0.0), 0.0)
    material = data["material"]
    awg_sel = data["awg_sel"]
    breaker_sel = _next_breaker(data["breaker_sel"]) if _to_int(data["breaker_sel"], 0) > 0 else 0
    wire_manual_obj = data.get("wire_manual_obj")
    use_manual_wire = bool(data.get("use_manual_wire")) and (wire_manual_obj is not None)
    area_obj = data.get("area_obj")
    use_project_group = bool(data.get("use_project_group", True))

    source_longitud = "AUTO"
    route_len_m = 0.0
    wire_name_for_row = ""
    wire_manual_name = ""
    area_total_m2 = max(_to_float(data.get("area_total_m2"), 0.0), 0.0)

    if bool(data.get("use_manual_wire")) and wire_manual_obj is None:
        _log_w("Se activo 'usar wire manual' pero no se selecciono wire; se usara ruta automatica.")

    if area_obj is not None and _is_wire_like_object(area_obj) and not _is_closed_object(area_obj):
        _log_w("El objeto de area seleccionado no esta cerrado; se ignora para demanda por area.")

    if area_total_m2 <= 0 and area_obj is not None:
        area_total_m2 = _shape_area_m2(area_obj)

    demanda_area_va = area_total_m2 * carga_base_va_m2
    demanda_area_kva = demanda_area_va / 1000.0
    if metodo_demanda == "AREA":
        demanda_usada_va = demanda_area_va
    elif metodo_demanda == "MAYOR":
        demanda_usada_va = max(demanda_manual_va, demanda_area_va)
    else:
        demanda_usada_va = demanda_manual_va
    demanda_usada_kva = demanda_usada_va / 1000.0

    if metodo_demanda in ("AREA", "MAYOR") and area_total_m2 <= 0:
        _log_w("Area total del proyecto es 0.0 m2; la demanda por area resulta 0.0 kVA.")

    project_group = None
    if use_project_group:
        project_group = _ensure_group(doc, "Proyecto_Acometida")
        _add_to_group_safe(project_group, medidor)
        _add_to_group_safe(project_group, tablero)
        _add_to_group_safe(project_group, wire_manual_obj)
        _add_to_group_safe(project_group, area_obj)

    p0 = _connection_point(medidor)
    p1 = _connection_point(tablero)
    points = _route_points_ortho(p0, p1, data["z_route_mm"])
    route_len_mm_auto = _path_length_mm(points)
    route_len_m_auto = route_len_mm_auto / 1000.0

    if use_manual_wire:
        wire_manual_name = _safe_text(getattr(wire_manual_obj, "Name", ""))
        route_len_mm_manual = _shape_length_mm(wire_manual_obj)
        if route_len_mm_manual > 0:
            route_len_m = route_len_mm_manual / 1000.0
            source_longitud = "MANUAL"
            wire_name_for_row = wire_manual_name
        else:
            _log_w("Wire manual sin longitud valida; se usara ruta automatica.")
            use_manual_wire = False
            route_len_m = route_len_m_auto
            source_longitud = "AUTO"
    else:
        route_len_m = route_len_m_auto
        source_longitud = "AUTO"

    p_kw = demanda_usada_kva * pf
    va_per_amp = _va_per_amp(v_ll, poles)
    i_nom = (demanda_usada_va / va_per_amp) if va_per_amp > 0 else 0.0

    i_diseno = i_nom * (1.0 + (growth / 100.0)) * 1.25
    breaker_calc = _next_breaker(i_diseno)
    conductor_calc = _awg_for_current(material, max(i_diseno, breaker_calc))

    if breaker_sel <= 0:
        breaker_sel = _next_breaker(i_diseno)
    if not awg_sel:
        awg_sel = _awg_for_current(material, breaker_sel)

    caida_sel = _voltage_drop_pct(route_len_m, i_diseno, v_ll, poles, awg_sel)
    caida_calc = _voltage_drop_pct(route_len_m, i_diseno, v_ll, poles, conductor_calc)

    wire_obj = None
    if not use_manual_wire:
        wire_label = "Acometida_{}_{}".format(
            _safe_name(getattr(medidor, "Label", medidor.Name)),
            _safe_name(getattr(tablero, "Label", tablero.Name)),
        )

        if data["reuse_wire"]:
            old = _find_existing_wire(doc, wire_label)
            if old is not None:
                try:
                    doc.removeObject(old.Name)
                    _log_i(f"Wire anterior reemplazado: {wire_label}")
                except Exception as ex:
                    _log_w(f"No se pudo remover wire previo: {ex}")

        wire_obj = _make_wire(points)
        wire_obj.Label = wire_label
        wire_name_for_row = _safe_text(getattr(wire_obj, "Name", ""))
        try:
            if hasattr(wire_obj, "FilletRadius"):
                wire_obj.FilletRadius = 0.0
        except Exception:
            pass
        try:
            vo = getattr(wire_obj, "ViewObject", None)
            if vo is not None:
                if hasattr(vo, "LineWidth"):
                    vo.LineWidth = 3.0
                if hasattr(vo, "LineColor"):
                    vo.LineColor = (0.85, 0.35, 0.1)
        except Exception:
            pass

        g_con = _ensure_group(doc, "Conexiones")
        try:
            _add_to_group_safe(g_con, wire_obj)
        except Exception as ex:
            _log_w(f"No se pudo mover wire al grupo Conexiones: {ex}")
        _add_to_group_safe(project_group, wire_obj)

    sheet, used_cols = _ensure_sheet(doc, "Acometida")
    row = _first_empty_row(sheet, used_cols, start_row=2)

    timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    values = [
        timestamp,
        _safe_text(getattr(medidor, "Label", medidor.Name)),
        _safe_text(getattr(tablero, "Label", tablero.Name)),
        sistema,
        normativa,
        metodo_demanda,
        carga_base_va_m2,
        area_total_m2,
        demanda_manual_kva,
        demanda_area_kva,
        demanda_usada_kva,
        poles,
        data["v_ln"],
        v_ll,
        pf,
        p_kw,
        i_nom,
        growth,
        i_diseno,
        material,
        breaker_sel,
        breaker_calc,
        awg_sel,
        conductor_calc,
        route_len_m,
        caida_sel,
        caida_calc,
        wire_name_for_row,
        data["notes"],
        source_longitud,
        wire_manual_name,
    ]

    _save_state(
        {
            "medidor_name": _safe_text(getattr(medidor, "Name", "")),
            "tablero_name": _safe_text(getattr(tablero, "Name", "")),
            "wire_manual_name": _safe_text(getattr(wire_manual_obj, "Name", "")),
            "area_obj_name": _safe_text(getattr(area_obj, "Name", "")),
            "sistema": sistema,
            "normativa": normativa,
            "demand_method": metodo_demanda,
            "carga_base_va_m2": carga_base_va_m2,
            "demanda_va_manual": demanda_manual_va,
            "demanda_kva": demanda_manual_kva,
            "pf": pf,
            "growth_pct": growth,
            "breaker_sel": breaker_sel,
            "material": material,
            "awg_sel": awg_sel,
            "z_route_mm": _to_float(data.get("z_route_mm"), 0.0),
            "use_manual_wire": use_manual_wire,
            "use_project_group": use_project_group,
            "area_total_m2": area_total_m2,
        }
    )

    for i, value in enumerate(values, start=1):
        cell = f"{_col_letter(i)}{row}"
        if isinstance(value, (int, float)):
            dec = 0 if i in (12, 21, 22) else 3
            _set_number(sheet, cell, value, decimals=dec)
        else:
            _set_text(sheet, cell, value)

    try:
        sheet.recompute()
        doc.recompute()
    except Exception as ex:
        _log_w(f"Recompute con advertencia: {ex}")

    _log_i(
        "Acometida registrada. Norma={}, Metodo={}, DemManual={:.1f} VA, DemArea={:.1f} VA, "
        "DemUsada={:.1f} VA, FuenteRuta={}, GrupoProyecto={}, I_nom={:.3f} A, I_diseno={:.3f} A, "
        "Breaker_calc={} A, Conductor_calc={}, Ruta={:.3f} m, Caida_sel={:.3f}%, Area={:.3f} m2".format(
            normativa, metodo_demanda, demanda_manual_va, demanda_area_va, demanda_usada_va,
            source_longitud, "SI" if use_project_group else "NO",
            i_nom, i_diseno, breaker_calc, conductor_calc, route_len_m, caida_sel, area_total_m2
        )
    )


if __name__ == "__main__":
    registrar_acometida_y_ruta()
