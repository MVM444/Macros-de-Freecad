APPROACH_PERP_MM = 100.0
FINAL_APPROACH_MM = 120.0

FALLBACK_CIRCUITO = "Sin_Circuito"
FALLBACK_RECINTO = "Sin_Recinto"

CIRCUIT_ATTRS = ("CircuitoID", "Circuito_Grupo", "Circuito", "CircuitID", "Circuit")
AREA_ATTRS = ("Recinto", "Area", "AreaID", "AreaNombre", "Habitacion", "Local", "Espacio", "Zona")
