    "almacen": "Bodega",
    "cuartoaseo": "Bodega",
    "suministros": "Bodega",
    "boveda": "Archivo",
    "comedor": "Cocina",
    "estacionamiento": "Parqueo",
    "exterior": "Exteriores",
}

INFER_RULES = (
    ("Pasillo", ("pasillo", "corredor", "circulacion")),
    ("Servicio Sanitario", ("serviciosanitario", "sanitario", "bano", "banos", "ss")),
    ("Sala de Reuniones", ("reunion", "reuniones", "juntas")),
