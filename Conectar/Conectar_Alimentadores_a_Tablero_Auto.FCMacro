        board_dialog_state = {"dlg": None}

        def _save_active_section_order():
            sec_key = texto_seguro(active_section_state.get("key", "")).strip()
            if not sec_key:
                return
            manual_state["section_order_map"][sec_key] = _list_ids(list_section_circuits)

        def _load_active_section_order():
            sec_key = texto_seguro(cmb_section_filter.currentData()).strip() or "AUTO"
            active_section_state["key"] = sec_key
            items = list(preview_state["section_map"].get(sec_key, []) or [])
            _set_list_items(list_section_circuits, items, manual_state["section_order_map"].get(sec_key, []))

        def _refresh_sections_and_circuits():
            _save_active_section_order()
            _build_preview()
            route_items = _route_section_items()
            route_keys = [k for k, _v in route_items]
            merged_keys = []
            for key in list(preview_state["section_keys"] or []) + route_keys:
                k = _route_key_from_any(key)
                if k and k not in merged_keys:
                    merged_keys.append(k)
            section_items = []
            known = set()
            for k, lbl in route_items:
                if k not in known:
                    section_items.append((k, lbl))
                    known.add(k)
            for k in merged_keys:
                if k not in known:
                    section_items.append((k, _section_label(k)))
                    known.add(k)
            _set_list_items(list_sections, section_items, _list_ids(list_sections) or manual_state["guide_order"])
            _set_combo_keys(cmb_section_filter, _list_ids(list_sections))
            _set_combo_keys(cmb_section_target, _list_ids(list_sections))
            _load_active_section_order()
            _render_board_table()

        def _job_section_key(job_key):
            return texto_seguro(preview_state.get("job_section_map", {}).get(texto_seguro(job_key).strip(), "AUTO")).strip() or "AUTO"

        def _guide_polyline_points(obj):
            pts = []
            try:
                for pt in list(getattr(obj, "Points", []) or []):
                    if pt is not None:
                        pts.append(pt)
            except Exception:
                pass
            if not pts:
                try:
                    for vtx in list(getattr(getattr(obj, "Shape", None), "OrderedVertexes", []) or []):
                        pt = getattr(vtx, "Point", None)
                        if pt is not None:
                            pts.append(pt)
                except Exception:
                    pass
            if not pts:
                try:
                    for vtx in list(getattr(getattr(obj, "Shape", None), "Vertexes", []) or []):
                        pt = getattr(vtx, "Point", None)
                        if pt is not None:
                            pts.append(pt)
                except Exception:
                    pass
            out = []
            seen = set()
            for pt in pts:
                key = (
                    round(float(getattr(pt, "x", 0.0)), 3),
                    round(float(getattr(pt, "y", 0.0)), 3),
                    round(float(getattr(pt, "z", 0.0)), 3),
                )
                if key in seen:
                    continue
                seen.add(key)
                out.append(pt)
            return out

        def _board_reference_xy():
            board_obj = state.get("tablero")
            if board_obj is None:
                return 0.0, 0.0
            try:
                bb = getattr(getattr(board_obj, "Shape", None), "BoundBox", None)
                if bb is not None:
                    return 0.5 * (float(bb.XMin) + float(bb.XMax)), 0.5 * (float(bb.YMin) + float(bb.YMax))
            except Exception:
                pass
            try:
                base = getattr(getattr(board_obj, "Placement", None), "Base", None)
                if base is not None:
                    return float(getattr(base, "x", 0.0)), float(getattr(base, "y", 0.0))
            except Exception:
                pass
            return 0.0, 0.0

        def _section_visual_x(section_key):
            sec_key = _route_key_from_any(section_key) or "AUTO"
            for obj in list(state.get("rutas", []) or []):
                name = texto_seguro(getattr(obj, "Name", "")).strip()
                label = texto_seguro(getattr(obj, "Label", "")).strip()
                if sec_key not in (name, label):
                    continue
                board_x, board_y = _board_reference_xy()
                pts = _guide_polyline_points(obj)
                if pts:
                    best_pt = min(
                        pts,
                        key=lambda pt: (
                            ((float(getattr(pt, "x", 0.0)) - board_x) ** 2) + ((float(getattr(pt, "y", 0.0)) - board_y) ** 2),
                            abs(float(getattr(pt, "x", 0.0)) - board_x),
                        ),
                    )
                    return float(getattr(best_pt, "x", 0.0))
                try:
                    bb = getattr(getattr(obj, "Shape", None), "BoundBox", None)
                    if bb is not None:
                        return 0.5 * (float(bb.XMin) + float(bb.XMax))
                except Exception:
                    pass
                try:
                    base = getattr(getattr(obj, "Placement", None), "Base", None)
                    if base is not None:
                        return float(getattr(base, "x", 0.0))
                except Exception:
                    pass
            if sec_key == "AUTO":
                xs = []
                job_index = {
                    texto_seguro(job.get("job_key", "")).strip(): job
                    for job in list(preview_state.get("jobs", []) or [])
                    if texto_seguro(job.get("job_key", "")).strip()
                }
                for gid, _lbl in list(preview_state.get("section_map", {}).get("AUTO", []) or []):
                    job = job_index.get(texto_seguro(gid).strip())
                    group_obj = None if job is None else job.get("group")
                    try:
                        for child in list(getattr(group_obj, "Group", []) or []):
                            bb = getattr(getattr(child, "Shape", None), "BoundBox", None)
                            if bb is None:
                                continue
                            xs.append(0.5 * (float(bb.XMin) + float(bb.XMax)))
                            break
                    except Exception:
                        pass
                if xs:
                    return sum(xs) / float(len(xs))
            return 0.0

        def _board_section_color(section_key, idx):
            palette = [
                "#D7EAF9",
                "#E7F4D8",
                "#F9E4CC",
                "#EADCF8",
                "#F8DCE3",
                "#E0F3F1",
                "#F6F1CC",
                "#DDE3F7",
            ]
            color_hex = palette[int(idx) % len(palette)]
            color = QtGui.QColor(color_hex) if QtGui is not None and hasattr(QtGui, "QColor") else None
            return color

        def _board_section_blocks(cols, auto_expand=False):
            active_sections = []
            for sec in list(_list_ids(list_sections) or []) + list(preview_state.get("section_keys", []) or []):
                sec_key = _route_key_from_any(sec) or "AUTO"
                if sec_key in active_sections:
                    continue
                if list(preview_state.get("section_map", {}).get(sec_key, []) or []):
                    active_sections.append(sec_key)
            if not active_sections:
                return [("AUTO", 0, max(1, int(cols)))], max(1, int(cols))
            if not bool(chk_manual_guides.isChecked()):
                active_sections = sorted(
                    active_sections,
                    key=lambda sec: (
                        float(_section_visual_x(sec)),
                        natural_key(_section_label(sec)),
                    ),
                )
            widths = []
            min_total = 0
            rows_n = max(1, int(board_state.get("rows", 2) or 2))
            for sec in active_sections:
                count = len(list(preview_state.get("section_map", {}).get(sec, []) or []))
                count_n = max(0, int(count))
                width = max(1, (count_n + max(1, rows_n) - 1) // max(1, rows_n))
                widths.append(width)
                min_total += width
            actual_cols = max(1, int(cols))
            if auto_expand and actual_cols < min_total:
                actual_cols = int(min_total)
            if actual_cols >= min_total and widths:
                extra = int(actual_cols - min_total)
                idx = 0
                while extra > 0:
                    widths[idx % len(widths)] += 1
                    idx += 1
                    extra -= 1
            blocks = []
            cur_col = 0
            for sec, width in zip(active_sections, widths):
                width = max(0, int(width))
                if cur_col >= actual_cols:
                    break
                width = min(width, actual_cols - cur_col)
                if width <= 0:
                    continue
                blocks.append((sec, cur_col, width))
                cur_col += width
            return blocks, actual_cols

        def _board_fill_sequence_for_block(start_col, width, start_row=0):
            out = []
            c0 = max(0, int(start_col))
            w = max(0, int(width))
            rows_n = max(1, int(board_state.get("rows", 2) or 2))
            r0 = max(0, min(rows_n - 1, int(start_row)))
            base_rows = list(range(rows_n))
            rotated_rows = base_rows[r0:] + base_rows[:r0]
            for offset in range(w):
                col = c0 + offset
                rows = list(rotated_rows)
                if offset % 2 == 1:
                    rows = list(reversed(rows))
                for row in rows:
                    out.append((row, col))
            return out

        def _render_board_table():
            cols = max(1, int(sp_board_cols.value() if sp_board_cols is not None else board_state.get("columns", 1)))
            rows_n = max(1, int(sp_board_rows.value() if sp_board_rows is not None else board_state.get("rows", 2)))
            board_state["columns"] = cols
            board_state["rows"] = rows_n
            _normalize_board_slot_map()
            labels = _job_label_map()
            blocks, actual_cols = _board_section_blocks(cols, auto_expand=False)
            table_board.blockSignals(True)
            table_board.clear()
            table_board.setRowCount(rows_n)
            table_board.setColumnCount(actual_cols)
            try:
                table_board.setHorizontalHeaderLabels([str(i + 1) for i in range(actual_cols)])
                row_labels = ["Fila {}".format(i + 1) for i in range(rows_n)]
                if rows_n >= 1:
                    row_labels[0] = "Fila superior"
                if rows_n >= 2:
                    row_labels[-1] = "Fila inferior"
                table_board.setVerticalHeaderLabels(row_labels)
                table_board.horizontalHeader().setStretchLastSection(True)
            except Exception:
                pass
            block_by_col = {}
            for idx, (sec, start_col, width) in enumerate(blocks):
                for col in range(int(start_col), int(start_col) + int(width)):
                    if 0 <= col < actual_cols:
                        block_by_col[col] = (sec, idx)
            for row in range(rows_n):
                for col in range(actual_cols):
                    sec, sec_idx = block_by_col.get(col, ("AUTO", 0))
                    item = table_board.item(row, col)
                    if item is None:
                        item = QtWidgets.QTableWidgetItem("")
                        table_board.setItem(row, col, item)
                    color = _board_section_color(sec, sec_idx)
                    if color is not None:
                        try:
                            item.setBackground(color)
                        except Exception:
                            pass
                    try:
                        hdr = table_board.horizontalHeaderItem(col)
                        if hdr is None:
                            hdr = QtWidgets.QTableWidgetItem(str(col + 1))
                            table_board.setHorizontalHeaderItem(col, hdr)
                        hdr.setToolTip("Seccion: {}".format(_section_label(sec)))
                    except Exception:
                        pass
            for gid, slot in dict(manual_state.get("board_slot_map", {}) or {}).items():
                row = int(slot.get("row", 0))
                col = int(slot.get("col", 0))
                if row < 0 or row >= rows_n or col < 0 or col >= actual_cols:
                    continue
                item = QtWidgets.QTableWidgetItem(labels.get(gid, gid))
                if QtCore is not None:
                    item.setData(QtCore.Qt.UserRole, gid)
                sec = _job_section_key(gid)
                sec_idx = next((idx for idx, (bsec, _start, _width) in enumerate(blocks) if bsec == sec), 0)
                color = _board_section_color(sec, sec_idx)
                if color is not None:
                    try:
                        item.setBackground(color)
                    except Exception:
                        pass
                try:
                    item.setToolTip("Seccion: {}".format(_section_label(sec)))
                except Exception:
                    pass
                table_board.setItem(row, col, item)
            table_board.blockSignals(False)
            _refresh_board_job_lists()
            _refresh_board_section_order_editor()
            lbl_board_blocks.setText(
                "Bloques: " + " | ".join(
                    "{}: col {}-{}".format(
                        _section_label(sec),
                        int(start_col) + 1,
                        int(start_col) + int(width),
                    )
                    for sec, start_col, width in blocks
                )
            )
            _refresh_board_summary()

        def _make_board_job_list():
            lw = _BoardJobListWidget()
            lw.setSelectionMode(QtWidgets.QAbstractItemView.ExtendedSelection)
            try:
                lw.setDragEnabled(True)
            except Exception:
                pass
            return lw

        def _selected_board_job_ids():
            if board_job_tabs is None or board_job_tabs.count() <= 0:
                return []
            widget = board_job_tabs.currentWidget()
            job_list = getattr(widget, "_job_list", None)
            if job_list is None:
                return []
            return _selected_ids(job_list)

        def _board_section_combo_keys():
            keys = []
            for sec in list(_list_ids(list_sections) or []) + list(preview_state.get("section_keys", []) or []):
                sec_key = _route_key_from_any(sec) or "AUTO"
                if sec_key not in keys and list(preview_state.get("section_map", {}).get(sec_key, []) or []):
                    keys.append(sec_key)
            if "AUTO" not in keys and list(preview_state.get("section_map", {}).get("AUTO", []) or []):
                keys.append("AUTO")
            return keys

        def _save_board_section_order():
            sec_key = texto_seguro(cmb_board_section_order.currentData()).strip() or "AUTO"
            manual_state["section_order_map"][sec_key] = _list_ids(list_board_section_order)

        def _load_board_section_order():
            sec_key = texto_seguro(cmb_board_section_order.currentData()).strip() or "AUTO"
            items = list(preview_state.get("section_map", {}).get(sec_key, []) or [])
            _set_list_items(list_board_section_order, items, manual_state["section_order_map"].get(sec_key, []))

        def _refresh_board_section_order_editor():
            current = texto_seguro(cmb_board_section_order.currentData()).strip()
            _set_combo_keys(cmb_board_section_order, _board_section_combo_keys())
            if current:
                idx = cmb_board_section_order.findData(current)
                if idx >= 0:
                    cmb_board_section_order.setCurrentIndex(idx)
            _load_board_section_order()

        def _refresh_board_job_lists():
            labels = _job_label_map()
            assigned = set(dict(manual_state.get("board_slot_map", {}) or {}).keys())
            available_pairs = [
                (gid, lbl, _job_section_key(gid))
                for gid, lbl in list(preview_state.get("job_items", []) or [])
                if gid and gid not in assigned
            ]
            sections_order = []
            for sec in list(_list_ids(list_sections) or []) + list(preview_state.get("section_keys", []) or []):
                sec_key = _route_key_from_any(sec) or "AUTO"
                if sec_key not in sections_order:
                    sections_order.append(sec_key)
            if "AUTO" not in sections_order:
                sections_order.append("AUTO")
            try:
                board_job_tabs.blockSignals(True)
            except Exception:
                pass
            try:
                board_job_tabs.clear()
            except Exception:
                pass
            board_job_lists.clear()
            grouped = {"__ALL__": []}
            for gid, lbl, sec in available_pairs:
                grouped.setdefault(sec, []).append((gid, "{} [{}]".format(lbl, _section_label(sec))))
                grouped["__ALL__"].append((gid, "{} [{}]".format(lbl, _section_label(sec))))
            tabs_data = [("__ALL__", "Todos", list(grouped.get("__ALL__", [])))]
            for sec in sections_order:
                items = list(grouped.get(sec, []))
                if items:
                    tabs_data.append((sec, _section_label(sec), items))
            for sec_key, tab_label, items in tabs_data:
                page = QtWidgets.QWidget()
                page_lay = QtWidgets.QVBoxLayout(page)
                page_lay.setContentsMargins(0, 0, 0, 0)
                job_list = _make_board_job_list()
                _set_list_items(job_list, items, [])
                page._job_list = job_list
                page_lay.addWidget(job_list)
                board_job_tabs.addTab(page, tab_label)
                board_job_lists[sec_key] = job_list
            try:
                board_job_tabs.blockSignals(False)
            except Exception:
                pass

        def _refresh_board_summary():
            assigned_n = len(dict(manual_state.get("board_slot_map", {}) or {}))
            total_n = len(list(preview_state.get("job_items", []) or []))
            cols = max(1, int(board_state.get("columns", 1) or 1))
            rows_n = max(1, int(board_state.get("rows", 2) or 2))
            lbl_board_table_summary.setText(
                "Salidas tablero: {} asignados / {} circuitos | {} columnas x {} filas | guias={} | circuitos/seccion={}".format(
                    int(assigned_n),
                    int(total_n),
                    int(cols),
                    int(rows_n),
                    "manual" if bool(chk_manual_guides.isChecked()) else "auto",
                    "manual" if bool(chk_manual_section_circuits.isChecked()) else "auto",
                )
            )

        def _board_selected_cell():
            items = table_board.selectedItems()
            if not items:
                row = int(table_board.currentRow())
                col = int(table_board.currentColumn())
                if row >= 0 and col >= 0:
                    return row, col
                return None
            item = items[0]
            return int(item.row()), int(item.column())

        def _board_assign_gids_at_cell(gids, start_row, start_col, replace_target=False):
            gids = [texto_seguro(gid).strip() for gid in list(gids or []) if texto_seguro(gid).strip()]
            if not gids:
                return
            cols = max(1, int(sp_board_cols.value()))
            rows_n = max(1, int(sp_board_rows.value()))
            row = max(0, min(rows_n - 1, int(start_row)))
            col = max(0, min(cols - 1, int(start_col)))
            for gid in gids:
                manual_state["board_slot_map"].pop(gid, None)
            if replace_target:
                for gid, slot in list(dict(manual_state.get("board_slot_map", {}) or {}).items()):
                    if int(slot.get("row", -1)) == row and int(slot.get("col", -1)) == col:
                        manual_state["board_slot_map"].pop(gid, None)
            used = {(int(v.get("row", 0)), int(v.get("col", 0))) for v in dict(manual_state.get("board_slot_map", {}) or {}).values()}
            seq = _board_fill_sequence(cols, start_row=row, start_col=col)
            idx = 0
            for cur_row, cur_col in seq:
                if (cur_row, cur_col) in used:
                    continue
                if idx >= len(gids):
                    break
                manual_state["board_slot_map"][gids[idx]] = {"row": int(cur_row), "col": int(cur_col)}
                idx += 1
            _render_board_table()

        def _board_assign_selected():
            gids = _selected_board_job_ids()
            if not gids:
                _warn("Seleccione uno o varios circuitos de la tabla de puntos.")
                return
            cell = _board_selected_cell()
            if cell is None:
                cell = (0, 0)
            _board_assign_gids_at_cell(gids, cell[0], cell[1], False)

        def _board_clear_cell():
            cell = _board_selected_cell()
            if cell is None:
                return
            row, col = cell
            for gid, slot in list(dict(manual_state.get("board_slot_map", {}) or {}).items()):
                if int(slot.get("row", -1)) == int(row) and int(slot.get("col", -1)) == int(col):
                    manual_state["board_slot_map"].pop(gid, None)
            _render_board_table()

        def _board_clear_all():
            manual_state["board_slot_map"] = {}
            _render_board_table()

        def _board_flip_left_right():
            cols = max(1, int(sp_board_cols.value()))
            rows_n = max(1, int(sp_board_rows.value()))
            sec_key = texto_seguro(cmb_board_section_order.currentData()).strip() or "AUTO"
            blocks, actual_cols = _board_section_blocks(cols, auto_expand=False)
            block = next((it for it in list(blocks or []) if texto_seguro(it[0]).strip() == sec_key), None)
            if block is None:
                _warn("No hay bloque activo para invertir en la seccion seleccionada.")
                return
            _sec, start_col, width = block
            start_col = max(0, int(start_col))
            width = max(1, int(width))
            max_col = min(max(1, int(actual_cols)) - 1, start_col + width - 1)
            flipped = dict(manual_state.get("board_slot_map", {}) or {})
            changed = False
            for gid, slot in list(dict(manual_state.get("board_slot_map", {}) or {}).items()):
                if _job_section_key(gid) != sec_key:
                    continue
                row = int(slot.get("row", 0))
                col = int(slot.get("col", 0))
                if row < 0 or row >= rows_n:
                    continue
                col = max(start_col, min(max_col, col))
                local_col = col - start_col
                flipped_col = start_col + ((width - 1) - local_col)
                flipped[gid] = {"row": int(row), "col": int(flipped_col)}
                changed = True
            if not changed:
                _warn("No hay circuitos asignados en la seccion seleccionada para invertir.")
                return
            manual_state["board_slot_map"] = flipped
            _render_board_table()

        def _board_auto_fill():
            cols = max(1, int(sp_board_cols.value()))
            rows_n = max(1, int(sp_board_rows.value()))
            board_state["rows"] = int(rows_n)
            blocks, actual_cols = _board_section_blocks(cols, auto_expand=True)
            board_state["columns"] = int(actual_cols)
            if int(sp_board_cols.value()) != int(actual_cols):
                sp_board_cols.blockSignals(True)
                sp_board_cols.setValue(int(actual_cols))
                sp_board_cols.blockSignals(False)
            if int(sp_board_rows.value()) != int(rows_n):
                sp_board_rows.blockSignals(True)
                sp_board_rows.setValue(int(rows_n))
                sp_board_rows.blockSignals(False)
            manual_state["board_slot_map"] = {}
            for sec, start_col, width in blocks:
                gids = [texto_seguro(gid).strip() for gid, _lbl in list(preview_state.get("section_map", {}).get(sec, []) or []) if texto_seguro(gid).strip()]
                seq = _board_fill_sequence_for_block(start_col, width, start_row=0)
                for idx, gid in enumerate(gids):
                    if idx >= len(seq):
                        break
                    row, col = seq[idx]
                    manual_state["board_slot_map"][gid] = {"row": int(row), "col": int(col)}
            _render_board_table()

        def _open_board_table_dialog():
            _render_board_table()
            dlg_board = board_dialog_state.get("dlg")
            if dlg_board is None:
                dlg_board = QtWidgets.QDialog(parent)
                dlg_board.setWindowTitle("Salidas de tuberia del tablero")
                dlg_board.resize(1180, 700)
                try:
                    dlg_board.setMinimumSize(1040, 560)
                except Exception:
                    pass
                if QtCore is not None:
                    dlg_board.setWindowModality(QtCore.Qt.NonModal)
                    dlg_board.setWindowFlag(QtCore.Qt.Tool, True)
                lay_dlg_board = QtWidgets.QVBoxLayout(dlg_board)
                lay_dlg_board.addWidget(grp_board_table)
                btn_close_board = QtWidgets.QPushButton("Cerrar")
                btn_close_board.clicked.connect(dlg_board.close)
                row_close_board = QtWidgets.QHBoxLayout()
                row_close_board.addStretch(1)
                row_close_board.addWidget(btn_close_board)
                lay_dlg_board.addLayout(row_close_board)
                board_dialog_state["dlg"] = dlg_board
            dlg_board.show()
            try:
                dlg_board.raise_()
                dlg_board.activateWindow()
            except Exception:
                pass

        def _selected_ids(list_widget):
            out = []
            try:
                selected = list_widget.selectedItems()
            except Exception:
                selected = []
            for item in list(selected or []):
                gid = texto_seguro(item.data(QtCore.Qt.UserRole) if QtCore else item.text()).strip()
                if gid and gid not in out:
                    out.append(gid)
            return out

        def _move_selected_circuit_to_section(target_section=None, reset_to_auto=False):
            gids = _selected_ids(list_section_circuits)
            if not gids:
                item = list_section_circuits.currentItem()
                gid = texto_seguro(item.data(QtCore.Qt.UserRole) if (QtCore and item is not None) else (item.text() if item is not None else "")).strip()
                if gid:
                    gids = [gid]
            if not gids:
                _warn("Seleccione uno o varios circuitos en la lista de la seccion actual.")
                return
            chk_manual_section_circuits.setChecked(True)
            _save_active_section_order()
            for sec_key in list(manual_state["section_order_map"].keys()):
                manual_state["section_order_map"][sec_key] = [
                    x for x in list(manual_state["section_order_map"].get(sec_key, []) or [])
                    if texto_seguro(x).strip() not in gids
                ]
            if reset_to_auto:
                for gid in gids:
                    manual_state["section_override_map"].pop(gid, None)
                target_key = ""
            else:
                target_key = texto_seguro(target_section or cmb_section_target.currentData()).strip() or "AUTO"
                for gid in gids:
                    manual_state["section_override_map"][gid] = target_key
                target_list = list(manual_state["section_order_map"].get(target_key, []) or [])
                for gid in gids:
                    if gid not in target_list:
                        target_list.append(gid)
                manual_state["section_order_map"][target_key] = target_list
            _refresh_sections_and_circuits()
            if reset_to_auto:
                target_key = texto_seguro(preview_state.get("job_section_map", {}).get(gids[0], "AUTO")).strip() or "AUTO"
            idx = cmb_section_filter.findData(target_key)
            if idx >= 0:
                cmb_section_filter.setCurrentIndex(idx)

        btn_circuit_up.clicked.connect(lambda: (chk_manual_circuits.setChecked(True), _move_current_item(list_circuits, -1)))
        btn_circuit_down.clicked.connect(lambda: (chk_manual_circuits.setChecked(True), _move_current_item(list_circuits, 1)))
        btn_clear_circuits.clicked.connect(lambda: (chk_manual_circuits.setChecked(False), _set_list_items(list_circuits, circuit_items, [])))
        btn_section_up.clicked.connect(lambda: (chk_manual_guides.setChecked(True), _move_current_item(list_sections, -1), _set_combo_keys(cmb_section_filter, _list_ids(list_sections)), _set_combo_keys(cmb_section_target, _list_ids(list_sections))))
        btn_section_down.clicked.connect(lambda: (chk_manual_guides.setChecked(True), _move_current_item(list_sections, 1), _set_combo_keys(cmb_section_filter, _list_ids(list_sections)), _set_combo_keys(cmb_section_target, _list_ids(list_sections))))
        btn_clear_sections.clicked.connect(lambda: (chk_manual_guides.setChecked(False), _set_list_items(list_sections, [(k, k) for k in preview_state["section_keys"]], []), _set_combo_keys(cmb_section_filter, _list_ids(list_sections)), _set_combo_keys(cmb_section_target, _list_ids(list_sections))))
        btn_refresh_sections.clicked.connect(_refresh_sections_and_circuits)
        btn_refresh_section_circuits.clicked.connect(_refresh_sections_and_circuits)
        btn_section_circuit_up.clicked.connect(lambda: (chk_manual_section_circuits.setChecked(True), _move_current_item(list_section_circuits, -1), _save_active_section_order()))
        btn_section_circuit_down.clicked.connect(lambda: (chk_manual_section_circuits.setChecked(True), _move_current_item(list_section_circuits, 1), _save_active_section_order()))
        btn_reverse_section_circuits.clicked.connect(lambda: (chk_manual_section_circuits.setChecked(True), _reverse_list_items(list_section_circuits), _save_active_section_order()))
        btn_clear_section_circuits.clicked.connect(lambda: (chk_manual_section_circuits.setChecked(False), manual_state["section_order_map"].__setitem__(texto_seguro(cmb_section_filter.currentData()).strip() or "AUTO", []), _load_active_section_order()))
        btn_move_section.clicked.connect(lambda: _move_selected_circuit_to_section())
        btn_reset_section.clicked.connect(lambda: _move_selected_circuit_to_section(reset_to_auto=True))
        cmb_section_filter.currentIndexChanged.connect(lambda _idx: (_save_active_section_order(), _load_active_section_order()))
        try:
            list_section_circuits.model().rowsMoved.connect(
                lambda *_args: (chk_manual_section_circuits.setChecked(True), _save_active_section_order())
            )
        except Exception:
            pass
        cmb_board_section_order.currentIndexChanged.connect(lambda _idx: _load_board_section_order())
        try:
            list_board_section_order.model().rowsMoved.connect(
                lambda *_args: (chk_manual_section_circuits.setChecked(True), _save_board_section_order(), _refresh_sections_and_circuits())
            )
        except Exception:
            pass
        try:
            btn_refresh_section_circuits.setToolTip("Recarga el preview de circuitos por seccion con el estado actual de guias, overrides y orden manual.")
            btn_reverse_section_circuits.setToolTip("Invierte el orden visible de la seccion activa y lo guarda como orden manual.")
            btn_board_section_refresh.setToolTip("Refresca la lista de circuitos de la seccion activa dentro de Salidas de tuberia del tablero.")
            btn_board_section_reverse.setToolTip("Invierte el orden de la seccion activa dentro de Salidas de tuberia del tablero.")
            btn_board_flip.setToolTip("Invierte izquierda/derecha solo dentro del bloque de la seccion activa en Salidas de tuberia del tablero.")
            btn_tab.setToolTip("ES: usa el tablero y las caras activas de la selección actual.\nEN: uses the panel and active faces from the current selection.")
            btn_guias.setToolTip("ES: reemplaza las rutas guía activas por las seleccionadas en el documento.\nEN: replaces active guide routes with the current document selection.")
            btn_add_guias.setToolTip("ES: agrega las rutas guía seleccionadas a la lista actual.\nEN: adds selected guide routes to the current list.")
            btn_remove_guias.setToolTip("ES: quita del panel las rutas guía seleccionadas.\nEN: removes selected guide routes from the panel list.")
            btn_todas.setToolTip("ES: carga rutas guía desde el grupo seleccionado o, si no hay grupo, desde el documento.\nEN: loads guide routes from the selected group or, if none is selected, from the document.")
        except Exception:
            pass
        btn_tab.clicked.connect(_refresh_sections_and_circuits)
        btn_guias.clicked.connect(_refresh_sections_and_circuits)
        btn_add_guias.clicked.connect(_refresh_sections_and_circuits)
        btn_remove_guias.clicked.connect(_refresh_sections_and_circuits)
        btn_todas.clicked.connect(_refresh_sections_and_circuits)
        btn_board_refresh.clicked.connect(_render_board_table)
        btn_assign_cell.clicked.connect(_board_assign_selected)
        btn_clear_cell.clicked.connect(_board_clear_cell)
        btn_clear_board.clicked.connect(_board_clear_all)
        btn_board_auto.clicked.connect(_board_auto_fill)
        btn_board_flip.clicked.connect(_board_flip_left_right)
        btn_board_section_refresh.clicked.connect(_refresh_board_section_order_editor)
        btn_board_section_up.clicked.connect(lambda: (chk_manual_section_circuits.setChecked(True), _move_current_item(list_board_section_order, -1), _save_board_section_order(), _refresh_sections_and_circuits()))
        btn_board_section_down.clicked.connect(lambda: (chk_manual_section_circuits.setChecked(True), _move_current_item(list_board_section_order, 1), _save_board_section_order(), _refresh_sections_and_circuits()))
        btn_board_section_reverse.clicked.connect(lambda: (chk_manual_section_circuits.setChecked(True), _reverse_list_items(list_board_section_order), _save_board_section_order(), _refresh_sections_and_circuits()))
        btn_board_section_auto.clicked.connect(lambda: (chk_manual_section_circuits.setChecked(False), manual_state["section_order_map"].__setitem__(texto_seguro(cmb_board_section_order.currentData()).strip() or "AUTO", []), _refresh_sections_and_circuits()))
        btn_open_board_table.clicked.connect(_open_board_table_dialog)
        table_board.set_drop_callback(_board_assign_gids_at_cell)
        try:
            table_board.itemDoubleClicked.connect(lambda _item: _board_clear_cell())
        except Exception:
            pass

        _refresh_sections_and_circuits()

        grp_scope = QtWidgets.QGroupBox(bi("Tablero y guías", "Panel and guides"))
        lay_scope_grp = QtWidgets.QVBoxLayout(grp_scope)
