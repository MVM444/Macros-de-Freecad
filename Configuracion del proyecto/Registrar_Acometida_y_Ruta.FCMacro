# -*- coding: utf-8 -*-
# MenuText: Registrar acometida y ruta
# Icon: Registrar_Acometida_y_Ruta.svg

# Qt compatibility for FreeCAD 1.x (PySide6) and older builds.
def _ensure_qt_compat():
    import sys
    import types

    QtCore = QtGui = QtWidgets = None
    binding_name = None

    for candidate in ("PySide6", "PySide2", "PySide"):
        try:
            if candidate == "PySide":
                from PySide import QtCore as _QtCore, QtGui as _QtGui
                _QtWidgets = _QtGui
            else:
                module = __import__(candidate, fromlist=["QtCore", "QtGui", "QtWidgets"])
                _QtCore = module.QtCore
                _QtGui = module.QtGui
                _QtWidgets = module.QtWidgets
            QtCore, QtGui, QtWidgets = _QtCore, _QtGui, _QtWidgets
            binding_name = candidate
            break
        except Exception:
            continue

    if QtCore is None:
        return

    qtgui_compat = types.ModuleType("QtGui")
    qtgui_compat.__dict__.update(getattr(QtGui, "__dict__", {}))
    qtgui_compat.__dict__.update(getattr(QtWidgets, "__dict__", {}))

    qtsvg_compat = None
    for module_name in ("QtSvg", "QtSvgWidgets"):
        try:
            module = __import__(binding_name, fromlist=[module_name])
            qt_module = getattr(module, module_name)
        except Exception:
            continue
        if qtsvg_compat is None:
            qtsvg_compat = types.ModuleType("QtSvg")
        qtsvg_compat.__dict__.update(getattr(qt_module, "__dict__", {}))

    qtuitools_compat = None
    try:
        module = __import__(binding_name, fromlist=["QtUiTools"])
        qtuitools_compat = module.QtUiTools
    except Exception:
        pass

    for package_name in ("PySide2", "PySide"):
        package = sys.modules.get(package_name)
        if package is None:
            package = types.ModuleType(package_name)
            sys.modules[package_name] = package
        package.QtCore = QtCore
        package.QtGui = qtgui_compat
        package.QtWidgets = QtWidgets
        sys.modules[package_name + ".QtCore"] = QtCore
        sys.modules[package_name + ".QtGui"] = qtgui_compat
        sys.modules[package_name + ".QtWidgets"] = QtWidgets
        if qtsvg_compat is not None:
            package.QtSvg = qtsvg_compat
            sys.modules[package_name + ".QtSvg"] = qtsvg_compat
        if qtuitools_compat is not None:
            package.QtUiTools = qtuitools_compat
            sys.modules[package_name + ".QtUiTools"] = qtuitools_compat


_ensure_qt_compat()


"""
Macro base para acometida:
- Formulario para capturar datos de acometida.
- Calcula corriente nominal/diseno, breaker y conductor recomendados.
- Crea (o reemplaza) un Draft Wire de ruta desde medidor a tablero principal.
- Guarda historial en Spreadsheet "Acometida" para recalculo en el tiempo.

Notas:
- Version inicial; tablas de ampacidad y criterios son aproximados.
- Ajustar segun NEC/Codigo CR en iteraciones posteriores.
"""

import json
import math
import os
import re
import time
from datetime import datetime

import FreeCAD as App
import FreeCADGui as Gui
import Draft
try:
    import Part
except Exception:
    Part = None

try:
    from PySide2 import QtCore, QtWidgets
except Exception:
    try:
        from PySide import QtCore, QtGui as QtWidgets
    except Exception:
        QtCore = None
        QtWidgets = None


TAG = "[ACOMETIDA]"
BREAKER_STANDARDS = [15, 20, 30, 40, 50, 60, 70, 80, 90, 100, 125, 150, 175, 200, 225, 250, 300, 400, 600]
AWG_ORDER = ["14", "12", "10", "8", "6", "4", "3", "2", "1", "1/0", "2/0", "3/0", "4/0"]

AMPACITY_CU = {
    "14": 20, "12": 25, "10": 35, "8": 50, "6": 65, "4": 85, "3": 100,
    "2": 115, "1": 130, "1/0": 150, "2/0": 175, "3/0": 200, "4/0": 230,
}
AMPACITY_AL = {
    "12": 20, "10": 30, "8": 40, "6": 50, "4": 65, "3": 75,
    "2": 90, "1": 100, "1/0": 120, "2/0": 135, "3/0": 155, "4/0": 180,
}
AWG_CMIL = {
    "14": 4110, "12": 6530, "10": 10380, "8": 16510, "6": 26240, "4": 41740,
    "3": 52620, "2": 66360, "1": 83690, "1/0": 105600, "2/0": 133100,
    "3/0": 167800, "4/0": 211600,
}

STATE_FILE_NAME = "_acometida_state.json"
AREA_LOAD_DEFAULTS = {
    "NEC": 32.29,  # 3 VA/ft2 aproximado
    "CR": 32.29,   # ajustar segun tabla local vigente
}
ACOMETIDA_HEADERS = [
    "Fecha",
    "Medidor",
    "TableroPrincipal",
    "Sistema",
    "Normativa",
    "Metodo_demanda",
    "Carga_base_VA_m2",
    "Area_total_m2",
    "Demanda_kVA_manual",
    "Demanda_kVA_area",
    "Demanda_kVA_usada",
    "Polos",
    "V_LN",
    "V_LL",
    "FP",
    "P_kW",
    "I_nom_A",
    "Crecimiento_pct",
    "I_diseno_A",
    "Material",
    "Breaker_sel_A",
    "Breaker_calc_A",
    "Conductor_sel_AWG",
    "Conductor_calc_AWG",
    "Longitud_ruta_m",
    "Caida_sel_pct",
    "Caida_calc_pct",
    "WireName",
    "Observaciones",
    "Fuente_longitud",
    "Wire_manual",
]


def _log_i(msg):
    App.Console.PrintMessage(f"{TAG}[INFO] {msg}\n")


def _log_w(msg):
    App.Console.PrintWarning(f"{TAG}[WARN] {msg}\n")


def _log_e(msg):
    App.Console.PrintError(f"{TAG}[ERROR] {msg}\n")


def _safe_text(v):
    try:
        return str(v or "")
    except Exception:
        return ""


def _to_float(v, default=0.0):
    try:
        return float(v)
    except Exception:
        pass
    try:
        return float(getattr(v, "Value", default))
    except Exception:
        return default


def _to_int(v, default=0):
    try:
        return int(round(float(v)))
    except Exception:
        return int(default)


def _safe_name(text):
    s = re.sub(r"[^0-9A-Za-z_]+", "_", _safe_text(text))
    s = re.sub(r"_+", "_", s).strip("_")
    return s or "Obj"


def _default_va_m2(norma):
    key = _safe_text(norma).strip().upper()
    if key in AREA_LOAD_DEFAULTS:
        return _to_float(AREA_LOAD_DEFAULTS[key], 32.29)
    return 32.29


def _state_path():
    try:
        base = os.path.dirname(os.path.abspath(__file__))
    except Exception:
        base = os.getcwd()
    return os.path.join(base, STATE_FILE_NAME)


def _load_state():
    path = _state_path()
    try:
        if os.path.exists(path):
            with open(path, "r", encoding="utf-8") as f:
                data = json.load(f)
            return data if isinstance(data, dict) else {}
    except Exception as ex:
        _log_w(f"No se pudo leer estado previo: {ex}")
    return {}


def _save_state(data):
    path = _state_path()
    try:
        payload = data if isinstance(data, dict) else {}
        with open(path, "w", encoding="utf-8") as f:
            json.dump(payload, f, ensure_ascii=False, indent=2)
    except Exception as ex:
        _log_w(f"No se pudo guardar estado: {ex}")


def _col_letter(idx):
    out = ""
    i = int(idx)
    while i > 0:
        i, rem = divmod(i - 1, 26)
        out = chr(65 + rem) + out
    return out or "A"


def _set_text(sheet, cell, value):
    # Always force text to avoid Spreadsheet expression parsing (example: "2/0").
    s = _safe_text(value).replace('"', '""')
    sheet.set(cell, '"' + s + '"')


def _set_number(sheet, cell, value, decimals=2):
    try:
        sheet.set(cell, f"{float(value):.{decimals}f}")
    except Exception:
        sheet.set(cell, "")


def _get_cell(sheet, cell, default=""):
    try:
        v = sheet.get(cell)
        return v if v is not None else default
    except Exception:
        return default


def _get_raw_cell(sheet, cell, default=""):
    try:
        if hasattr(sheet, "getContents"):
            v = sheet.getContents(cell)
            return v if v is not None else default
    except Exception:
        pass
    return _get_cell(sheet, cell, default)


def _first_empty_row(sheet, used_cols, start_row=2, max_rows=20000):
    for r in range(start_row, max_rows + 1):
        empty = True
        for c in used_cols:
            v = _safe_text(_get_cell(sheet, f"{c}{r}", "")).strip()
            if v:
                empty = False
                break
        if empty:
            return r
    return max_rows + 1


def _repair_legacy_awg_cells(sheet, max_rows=5000):
    # Repair old cells where values like 2/0 were interpreted as expression.
    for c in range(1, 60):
        col = _col_letter(c)
        for r in range(2, max_rows + 1):
            cell = f"{col}{r}"
            raw = _safe_text(_get_raw_cell(sheet, cell, "")).strip()
            if not raw:
                continue
            cleaned = raw.strip().strip('"').replace(" ", "")
            if re.match(r"^\d+/0$", cleaned):
                _set_text(sheet, cell, cleaned)


def _ensure_sheet(doc, name="Acometida"):
    sheet = doc.getObject(name)
    if sheet is None:
        sheet = doc.addObject("Spreadsheet::Sheet", name)

    for i, h in enumerate(ACOMETIDA_HEADERS, start=1):
        _set_text(sheet, f"{_col_letter(i)}1", h)
    _repair_legacy_awg_cells(sheet, max_rows=5000)

    used = [_col_letter(i) for i in range(1, len(ACOMETIDA_HEADERS) + 1)]
    return sheet, used


def _connection_point(obj):
    if obj is None or not hasattr(obj, "Placement"):
        return App.Vector(0, 0, 0)
    p = obj.Placement.Base
    z_extra = 0.0
    for n in ("AlturaRel", "Altura", "Elevation", "Elevacion", "Z"):
        if hasattr(obj, n):
            try:
                z_extra = _to_float(getattr(obj, n), 0.0)
                break
            except Exception:
                pass
    return App.Vector(_to_float(p.x, 0.0), _to_float(p.y, 0.0), _to_float(p.z, 0.0) + z_extra)


def _route_points_ortho(p0, p1, z_route):
    z = max(_to_float(z_route, 0.0), _to_float(p0.z, 0.0), _to_float(p1.z, 0.0))
    pts = [
        App.Vector(p0.x, p0.y, p0.z),
        App.Vector(p0.x, p0.y, z),
        App.Vector(p1.x, p0.y, z),
        App.Vector(p1.x, p1.y, z),
        App.Vector(p1.x, p1.y, p1.z),
    ]
    clean = []
    for p in pts:
        if not clean:
            clean.append(p)
            continue
        if p.distanceToPoint(clean[-1]) > 1e-7:
            clean.append(p)
    return clean


def _path_length_mm(points):
    total = 0.0
    if not points or len(points) < 2:
        return total
    for i in range(1, len(points)):
        total += points[i - 1].distanceToPoint(points[i])
    return total


def _make_wire(points):
    maker = getattr(Draft, "make_wire", None)
    if maker is None:
        maker = getattr(Draft, "makeWire", None)
    if maker is None:
        raise RuntimeError("No se encontro Draft.make_wire ni Draft.makeWire")

    attempts = [
        lambda: maker(points, closed=False, face=False),
        lambda: maker(points, False, False),
        lambda: maker(points, False),
        lambda: maker(points),
    ]
    last_err = None
    for attempt in attempts:
        try:
            return attempt()
        except Exception as ex:
            last_err = ex
    raise RuntimeError(f"No se pudo crear Wire: {last_err}")


def _ensure_group(doc, group_name):
    g = doc.getObject(group_name)
    if g is None:
        g = doc.addObject("App::DocumentObjectGroup", group_name)
    return g


def _add_to_group_safe(group_obj, child_obj):
    if group_obj is None or child_obj is None:
        return
    try:
        current = list(getattr(group_obj, "Group", []) or [])
        if child_obj in current:
            return
    except Exception:
        pass
    try:
        group_obj.addObject(child_obj)
    except Exception:
        pass


def _next_breaker(amps):
    a = _to_float(amps, 0.0)
    if a <= 0:
        return 15
    for b in BREAKER_STANDARDS:
        if a <= float(b):
            return int(b)
    return int(BREAKER_STANDARDS[-1])


def _ampacity_table(material):
    m = _safe_text(material).strip().lower()
    return AMPACITY_AL if m.startswith("al") else AMPACITY_CU


def _awg_for_current(material, required_amps):
    req = _to_float(required_amps, 0.0)
    table = _ampacity_table(material)
    for awg in AWG_ORDER:
        if awg in table and _to_float(table[awg], 0.0) >= req:
            return awg
    return AWG_ORDER[-1]


def _cmil_from_awg(awg):
    key = _safe_text(awg).strip().upper()
    return _to_float(AWG_CMIL.get(key, 0.0), 0.0)


def _voltage_drop_pct(distance_m, current_a, voltage_v, poles, awg):
    d = _to_float(distance_m, 0.0)
    i = _to_float(current_a, 0.0)
    v = _to_float(voltage_v, 0.0)
    cmil = _cmil_from_awg(awg)
    if d <= 0 or i <= 0 or v <= 0 or cmil <= 0:
        return 0.0

    # Copper approximation. For first version this is used for both Cu/Al as estimate.
    k = 12.9
    l_ft = d * 3.28084
    p = _to_int(poles, 2)
    if p >= 3:
        v_drop = (1.732 * k * i * l_ft) / cmil
    else:
        v_drop = (2.0 * k * i * l_ft) / cmil
    return (v_drop / v) * 100.0


def _shape_length_mm(obj):
    if obj is None or not hasattr(obj, "Shape"):
        return 0.0
    try:
        sh = obj.Shape
    except Exception:
        return 0.0
    if sh is None:
        return 0.0
    try:
        length_attr = getattr(sh, "Length", 0.0)
    except Exception:
        length_attr = 0.0
    length = _to_float(length_attr, 0.0)
    if length > 0:
        return length
    total = 0.0
    try:
        for e in getattr(sh, "Edges", []) or []:
            try:
                elen = getattr(e, "Length", 0.0)
            except Exception:
                elen = 0.0
            total += _to_float(elen, 0.0)
    except Exception:
        pass
    return total


def _area_to_m2(value, assume_mm2=False):
    if value is None:
        return 0.0
    try:
        if hasattr(value, "getValueAs"):
            q = value.getValueAs("m^2")
            return max(_to_float(q, 0.0), 0.0)
    except Exception:
        pass
    num = _to_float(getattr(value, "Value", value), 0.0)
    if num <= 0:
        return 0.0
    if assume_mm2:
        return num / 1000000.0
    if hasattr(value, "Unit"):
        # Fallback for quantities without getValueAs.
        return num / 1000000.0
    # Plain numeric fallback:
    # - if very large, likely mm2
    # - otherwise treat as m2
    if num > 10000.0:
        return num / 1000000.0
    return num


def _to_vec3(v):
    if v is None:
        return None
    try:
        return App.Vector(_to_float(v.x, 0.0), _to_float(v.y, 0.0), _to_float(v.z, 0.0))
    except Exception:
        pass
    try:
        if len(v) >= 3:
            return App.Vector(_to_float(v[0], 0.0), _to_float(v[1], 0.0), _to_float(v[2], 0.0))
    except Exception:
        pass
    return None


def _polygon_area_m2(points, is_closed=False):
    if not points or len(points) < 3:
        return 0.0
    pts = []
    for p in points:
        v = _to_vec3(p)
        if v is not None:
            pts.append(v)
    if len(pts) < 3:
        return 0.0

    # Wire must be closed to define area.
    geom_closed = pts[0].distanceToPoint(pts[-1]) <= 1e-6
    if not is_closed and not geom_closed:
        return 0.0

    pts2 = pts[:-1] if geom_closed else pts[:]
    if len(pts2) < 3:
        return 0.0

    acc = App.Vector(0.0, 0.0, 0.0)
    n = len(pts2)
    for i in range(n):
        p0 = pts2[i]
        p1 = pts2[(i + 1) % n]
        acc = acc.add(p0.cross(p1))
    area_mm2 = 0.5 * acc.Length
    if area_mm2 <= 0:
        return 0.0
    return area_mm2 / 1000000.0


def _shape_area_m2(obj, _visited=None):
    if obj is None:
        return 0.0

    if _visited is None:
        _visited = set()
    name = _safe_text(getattr(obj, "Name", ""))
    if name:
        if name in _visited:
            return 0.0
        _visited.add(name)

    # If obj is a Link, evaluate linked object area.
    linked = getattr(obj, "LinkedObject", None)
    if linked is not None:
        a_link = _shape_area_m2(linked, _visited)
        if a_link > 0:
            return a_link

    # If obj is a Group, sum area of children.
    if hasattr(obj, "Group"):
        total = 0.0
        try:
            for child in list(getattr(obj, "Group", []) or []):
                total += _shape_area_m2(child, _visited)
        except Exception:
            pass
        if total > 0:
            return total

    # Prefer direct Area property when available.
    if hasattr(obj, "Area"):
        try:
            a = _area_to_m2(getattr(obj, "Area"), assume_mm2=False)
            if a > 0:
                return a
        except Exception:
            pass

    sh = None
    if hasattr(obj, "Shape"):
        try:
            sh = obj.Shape
        except Exception:
            sh = None

    if sh is not None:
        # Shape.Area in FreeCAD geometry is usually mm2.
        try:
            a = _area_to_m2(getattr(sh, "Area", 0.0), assume_mm2=True)
            if a > 0:
                return a
        except Exception:
            pass

        # Try to create face from closed wires if area is not directly available.
        if Part is not None:
            try:
                for w in list(getattr(sh, "Wires", []) or []):
                    try:
                        if not w.isClosed():
                            continue
                        face = Part.Face(w)
                        a = _area_to_m2(getattr(face, "Area", 0.0), assume_mm2=True)
                        if a > 0:
                            return a
                    except Exception:
                        continue
            except Exception:
                pass

    # Last fallback: polygon area from Draft points (closed wire).
    points = getattr(obj, "Points", None)
    if points:
        try:
            closed_flag = bool(getattr(obj, "Closed", False))
            return _polygon_area_m2(points, is_closed=closed_flag)
        except Exception:
            pass
    return 0.0


def _is_wire_like_object(obj):
    if obj is None:
        return False
    t = _safe_text(getattr(obj, "TypeId", "")).lower()
    if "wire" in t:
        return True
    if hasattr(obj, "Points"):
        return True
    try:
        sh = getattr(obj, "Shape", None)
        if sh is not None:
            edges = len(list(getattr(sh, "Edges", []) or []))
            faces = len(list(getattr(sh, "Faces", []) or []))
            if edges > 0 and faces == 0:
                return True
    except Exception:
        pass
    return False


def _is_closed_object(obj):
    if obj is None:
        return False
    try:
        if bool(getattr(obj, "Closed", False)):
            return True
    except Exception:
        pass
    points = getattr(obj, "Points", None)
    if points:
        pts = []
        for p in points:
            v = _to_vec3(p)
            if v is not None:
                pts.append(v)
        if len(pts) >= 3 and pts[0].distanceToPoint(pts[-1]) <= 1e-6:
            return True
    try:
        sh = getattr(obj, "Shape", None)
        if sh is not None:
            if len(list(getattr(sh, "Faces", []) or [])) > 0:
                return True
            for w in list(getattr(sh, "Wires", []) or []):
                if w.isClosed():
                    return True
    except Exception:
        pass
    return False


def _candidate_objects(doc):
    out = []
    for obj in getattr(doc, "Objects", []) or []:
        if not hasattr(obj, "Placement"):
            continue
        if hasattr(obj, "Group"):
            continue
        out.append(obj)
    out.sort(key=lambda o: (_safe_text(getattr(o, "Label", "")).lower(), _safe_text(getattr(o, "Name", "")).lower()))
    return out


def _candidate_wires(doc):
    out = []
    for obj in getattr(doc, "Objects", []) or []:
        try:
            t = _safe_text(getattr(obj, "TypeId", "")).lower()
            if "wire" in t:
                out.append(obj)
                continue
            if hasattr(obj, "Shape"):
                if _shape_length_mm(obj) > 0:
                    out.append(obj)
        except Exception:
            # Ignore objects with broken/incomplete shapes.
            continue
    # unique by Name preserving order
    seen = set()
    uniq = []
    for o in out:
        n = _safe_text(getattr(o, "Name", ""))
        if n in seen:
            continue
        seen.add(n)
        uniq.append(o)
    uniq.sort(key=lambda o: (_safe_text(getattr(o, "Label", "")).lower(), _safe_text(getattr(o, "Name", "")).lower()))
    return uniq


def _candidate_area_objects(doc):
    out = []
    for obj in getattr(doc, "Objects", []) or []:
        try:
            if _shape_area_m2(obj) > 0:
                out.append(obj)
        except Exception:
            continue
    out.sort(key=lambda o: (_safe_text(getattr(o, "Label", "")).lower(), _safe_text(getattr(o, "Name", "")).lower()))
    return out


