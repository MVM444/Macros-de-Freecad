            if _safe_text(x).strip() in BOARD_FACES
        ]
        if not selected_anchor_faces and face_txt in BOARD_FACES:
            selected_anchor_faces = [face_txt]
        if len(selected_anchor_faces) == len(BOARD_FACES):
            selected_anchor_faces = []
        self._set_selected_anchor_faces(list_anchor_faces, selected_anchor_faces)

