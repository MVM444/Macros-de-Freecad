EN: the manual board outlet table is hidden from the current form to keep the workflow simpler; the algorithm still distributes entries automatically over the selected face.</p>
"""


def log_info(msg):
    App.Console.PrintMessage(f"{TAG} {msg}\n")


def log_error(msg):
    App.Console.PrintError(f"{TAG} {msg}\n")


def texto_seguro(value):
    try:
        return str(value or "")
    except Exception:
        return ""


def bi(es, en):
    es_txt = texto_seguro(es).strip()
    en_txt = texto_seguro(en).strip()
    if es_txt and en_txt:
        return f"{es_txt} / {en_txt}"
    return es_txt or en_txt


def clamp_int(value, minimum, maximum):
    try:
        num = int(value)
    except Exception:
        num = int(minimum)
    return max(int(minimum), min(int(maximum), num))


def natural_key(text):
    s = texto_seguro(text)
    return [int(t) if t.isdigit() else t.lower() for t in re.split(r"([0-9]+)", s)]


def prefs():
    return App.ParamGet(PREF_PATH)


def pref_get_str(name, default=""):
    try:
        return texto_seguro(prefs().GetString(name, texto_seguro(default)))
    except Exception:
        return texto_seguro(default)


def pref_get_float(name, default):
    try:
        return float(prefs().GetFloat(name, float(default)))
    except Exception:
        return float(default)


def pref_get_bool(name, default):
    try:
        return bool(prefs().GetBool(name, bool(default)))
    except Exception:
        return bool(default)


def pref_get_list(name, default=None):
    txt = pref_get_str(name, "")
    if not txt:
        return list(default or [])
    try:
        data = json.loads(txt)
        if isinstance(data, list):
            return list(data)
    except Exception:
        pass
    return list(default or [])


def pref_get_json_dict(name, default=None):
    txt = pref_get_str(name, "")
    if not txt:
        return dict(default or {})
    try:
        data = json.loads(txt)
        if isinstance(data, dict):
            return dict(data)
    except Exception:
        pass
    return dict(default or {})


def pref_set(name, value):
    try:
        if isinstance(value, bool):
            prefs().SetBool(name, bool(value))
        elif isinstance(value, (int, float)):
            prefs().SetFloat(name, float(value))
        elif isinstance(value, (list, dict)):
            prefs().SetString(name, json.dumps(value, ensure_ascii=True))
        else:
            prefs().SetString(name, texto_seguro(value))
    except Exception:
        pass


def cargar_backend(force_reload=False):
    global _BACKEND
    if (not force_reload) and (_BACKEND is not None):
        return _BACKEND
    backend_path = Path(__file__).resolve().with_name("alimentadores_backend.py")
    if not backend_path.exists():
        raise RuntimeError(f"No se encontro el backend de alimentadores: {backend_path}")
    folder = str(backend_path.parent)
    if folder not in sys.path:
        sys.path.insert(0, folder)
    module = importlib.import_module("alimentadores_backend")
    if force_reload:
        module = importlib.reload(module)
    _BACKEND = module
    return module


def es_grupo(obj):
    if obj is None:
        return False
    tid = texto_seguro(getattr(obj, "TypeId", ""))
    return tid.startswith("App::DocumentObjectGroup") or hasattr(obj, "Group")


def es_tablero(obj):
    if obj is None or es_grupo(obj):
        return False
    txt = f"{texto_seguro(getattr(obj, 'Tipo', ''))} {texto_seguro(getattr(obj, 'Label', ''))} {texto_seguro(getattr(obj, 'Name', ''))}".lower()
    return "tablero" in txt


def obtener_puntos_polilinea(obj):
    if obj is None or es_grupo(obj):
        return []
    try:
        shape = getattr(obj, "Shape", None)
        if shape is None or shape.isNull():
            return []
    except Exception:
        return []
    for wire in list(getattr(shape, "Wires", []) or []):
        pts = []
        for vtx in list(getattr(wire, "OrderedVertexes", []) or []):
            pt = getattr(vtx, "Point", None)
            if pt is not None:
                pts.append(pt)
        if len(pts) >= 2:
            return pts
    return []


def es_ruta_guia(obj):
    pts = obtener_puntos_polilinea(obj)
    return len(pts) >= 2


def clasificar_cara_desde_face(face):
    if face is None:
        return None
    try:
        u0, u1, v0, v1 = face.ParameterRange
        normal = face.normalAt(0.5 * (u0 + u1), 0.5 * (v0 + v1))
    except Exception:
        return None
    ax = abs(float(normal.x))
    ay = abs(float(normal.y))
    az = abs(float(normal.z))
    if az >= ax and az >= ay:
        return "Top" if float(normal.z) >= 0.0 else "Bottom"
    if ax >= ay:
        return "East" if float(normal.x) >= 0.0 else "West"
    return "North" if float(normal.y) >= 0.0 else "South"


def tablero_y_caras_desde_seleccion():
    if Gui is None:
        return None, []
    tablero = None
    caras = []
    for item in list(Gui.Selection.getSelectionEx() or []):
        if es_tablero(item.Object):
            tablero = item.Object
            for sub in list(getattr(item, "SubObjects", []) or []):
                cara = clasificar_cara_desde_face(sub)
                if cara and cara not in caras:
                    caras.append(cara)
            break
    if tablero is None:
        for obj in list(Gui.Selection.getSelection() or []):
            if es_tablero(obj):
                tablero = obj
                break
    return tablero, caras


def rutas_guia_desde_seleccion():
    if Gui is None:
        return []
    out = []
    seen = set()
    for item in list(Gui.Selection.getSelectionEx() or []):
        obj = item.Object
        name = texto_seguro(getattr(obj, "Name", ""))
        if not name or name in seen or es_tablero(obj):
            continue
        if es_ruta_guia(obj):
            out.append(obj)
            seen.add(name)
    return out


def _sorted_route_guides(objs):
    return sorted(
        [obj for obj in list(objs or []) if obj is not None and es_ruta_guia(obj)],
        key=lambda o: natural_key(texto_seguro(getattr(o, "Label", "")) or texto_seguro(getattr(o, "Name", ""))),
    )


def _is_group_like(obj):
    return obj is not None and hasattr(obj, "Group")


def rutas_guia_desde_grupo_o_documento(doc):
    if doc is None:
        return []
    groups = []
    if Gui is not None:
        seen_groups = set()
        for obj in list(Gui.Selection.getSelection() or []):
            name = texto_seguro(getattr(obj, "Name", "")).strip()
            if not name or name in seen_groups:
                continue
            if _is_group_like(obj) and not es_tablero(obj) and not es_ruta_guia(obj):
                groups.append(obj)
                seen_groups.add(name)
    if not groups:
        return _sorted_route_guides(list(getattr(doc, "Objects", []) or []))
    out = []
    seen = set()
    queue = list(groups)
    while queue:
        cur = queue.pop(0)
        name = texto_seguro(getattr(cur, "Name", "")).strip()
        if name and name in seen:
            continue
        if name:
            seen.add(name)
        for child in list(getattr(cur, "Group", []) or []):
            if _is_group_like(child):
                queue.append(child)
                continue
            child_name = texto_seguro(getattr(child, "Name", "")).strip()
            if not child_name or child_name in seen:
                continue
            if es_ruta_guia(child):
                out.append(child)
                seen.add(child_name)
    return _sorted_route_guides(out)


class FormularioAlimentadores(object):
    def __init__(self, doc, on_apply=None):
        self.doc = doc
        self.on_apply = on_apply

    def run(self):
        backend = cargar_backend(force_reload=True)
        engine_defaults = dict(backend.default_engine_config() or {})
        board_pref_name = pref_get_str("board_name", texto_seguro(engine_defaults.get("anchor_name", "")))
        board_pref = backend.find_object_by_name(self.doc, board_pref_name)
        faces_pref = pref_get_list("board_faces", list(engine_defaults.get("anchor_faces", []) or []))
        guides_pref = backend.objects_by_names(
            self.doc,
            pref_get_list("guide_names", list(engine_defaults.get("guide_names", []) or [])),
        )
        route_z_default = pref_get_float("route_z", float(engine_defaults.get("route_z", DEFAULT_ROUTE_Z)))
        bend_default = pref_get_float("bend_radius", float(engine_defaults.get("bend_radius", DEFAULT_BEND_RADIUS)))
        separation_default = pref_get_float("separation", float(engine_defaults.get("circuit_separation", DEFAULT_CIRCUIT_SEPARATION)))
        board_align_distance_default = pref_get_float("board_align_distance", float(engine_defaults.get("board_align_distance", DEFAULT_BOARD_ALIGN_DISTANCE)))
        include_apag_default = pref_get_bool("include_apagadores", bool(engine_defaults.get("include_apagadores", DEFAULT_INCLUDE_APAGADORES)))
        route_perimeter_default = pref_get_bool("route_by_perimeter", bool(engine_defaults.get("route_by_perimeter", DEFAULT_ROUTE_BY_PERIMETER)))
        refresh_existing_default = pref_get_bool("refresh_existing_routes", DEFAULT_REFRESH_EXISTING)
        manual_circuit_order_default = pref_get_list("manual_circuit_order_json", list(engine_defaults.get("manual_circuit_order", []) or []))
        manual_circuit_enabled_default = pref_get_bool("manual_circuit_order_enabled", bool(engine_defaults.get("manual_circuit_order_enabled", False)))
        manual_guide_order_default = pref_get_list("manual_guide_order_json", list(engine_defaults.get("manual_guide_order", []) or []))
        manual_guide_enabled_default = pref_get_bool("manual_guide_order_enabled", bool(engine_defaults.get("manual_guide_order_enabled", False)))
        manual_section_map_default = pref_get_json_dict("manual_section_circuit_order_json", dict(engine_defaults.get("manual_section_circuit_order_map", {}) or {}))
        manual_section_enabled_default = pref_get_bool("manual_section_circuit_order_enabled", bool(engine_defaults.get("manual_section_circuit_order_enabled", False)))
        manual_section_override_default = pref_get_json_dict("manual_section_override_json", dict(engine_defaults.get("manual_section_override_map", {}) or {}))
        manual_board_slot_default = pref_get_json_dict("manual_board_slot_map_json", {})
        board_slot_columns_default = max(0, int(pref_get_float("board_slot_columns", 0.0)))
        board_slot_rows_default = max(1, int(pref_get_float("board_slot_rows", 2.0)))

        if QtWidgets is None:
            board_sel, faces_sel = tablero_y_caras_desde_seleccion()
            return {
                "tablero": board_sel or board_pref,
                "caras": list(faces_sel or faces_pref),
                "rutas": list(rutas_guia_desde_seleccion() or guides_pref),
                "route_z": route_z_default,
                "bend_radius": bend_default,
                "separation": separation_default,
                "board_align_distance": board_align_distance_default,
                "include_apagadores": include_apag_default,
                "route_by_perimeter": route_perimeter_default,
                "refresh_existing_routes": refresh_existing_default,
                "anchor_face": texto_seguro(engine_defaults.get("anchor_face", "Auto")) or "Auto",
                "anchor_faces": list(engine_defaults.get("anchor_faces", []) or []),
                "manual_circuit_order": list(manual_circuit_order_default),
                "manual_circuit_order_enabled": bool(manual_circuit_enabled_default),
                "manual_guide_order": list(manual_guide_order_default),
                "manual_guide_order_enabled": bool(manual_guide_enabled_default),
                "manual_section_circuit_order_map": dict(manual_section_map_default),
                "manual_section_circuit_order_enabled": bool(manual_section_enabled_default),
                "manual_section_override_map": dict(manual_section_override_default),
                "manual_board_slot_map": dict(manual_board_slot_default),
                "board_slot_columns": int(board_slot_columns_default),
                "board_slot_rows": int(board_slot_rows_default),
            }

        parent = Gui.getMainWindow() if Gui is not None else None
        dlg = QtWidgets.QDialog(parent)
        dock = None
        root = None
        lay = None
        screen_w = 1920
        screen_h = 1080
        try:
            screen = None
            if parent is not None and hasattr(parent, "windowHandle") and parent.windowHandle() is not None:
                try:
                    screen = parent.windowHandle().screen()
                except Exception:
                    screen = None
            if screen is None and QtWidgets is not None and hasattr(QtWidgets, "QApplication"):
                try:
                    screen = QtWidgets.QApplication.primaryScreen()
                except Exception:
                    screen = None
            if screen is not None and hasattr(screen, "availableGeometry"):
                geom = screen.availableGeometry()
                if geom is not None:
                    screen_w = max(800, int(geom.width()))
                    screen_h = max(600, int(geom.height()))
        except Exception:
            pass
        dock_min_w = clamp_int(screen_w * 0.16, 420, 560)
        dock_pref_w = clamp_int(screen_w * 0.20, 500, 680)
        dock_max_w = clamp_int(screen_w * 0.28, dock_pref_w + 20, 860)
        dialog_w = clamp_int(screen_w * 0.28, 660, 860)
        dialog_h = clamp_int(screen_h * 0.74, 620, 920)

        if QtCore is not None and parent is not None and hasattr(QtWidgets, "QDockWidget"):
            try:
                old = parent.findChild(QtWidgets.QDockWidget, "ElectricCR_ConectarAlimentadoresDock")
                if old is not None:
                    old.close()
                    old.deleteLater()
            except Exception:
                pass
            try:
                dock = QtWidgets.QDockWidget(DEFAULT_PANEL_TITLE, parent)
                dock.setObjectName("ElectricCR_ConectarAlimentadoresDock")
                dock.setAllowedAreas(QtCore.Qt.RightDockWidgetArea)
                dock.setMinimumWidth(dock_min_w)
                dock.setMaximumWidth(dock_max_w)
                dock.setFeatures(QtWidgets.QDockWidget.DockWidgetClosable)
                dock.setFloating(False)
                root = QtWidgets.QWidget(dock)
                try:
                    root.setMinimumWidth(max(400, dock_min_w - 16))
                except Exception:
                    pass
                dock.setWidget(root)
                try:
                    parent.addDockWidget(QtCore.Qt.RightDockWidgetArea, dock, QtCore.Qt.Vertical)
                except Exception:
                    parent.addDockWidget(QtCore.Qt.RightDockWidgetArea, dock)
                try:
                    task_dock = None
                    for other in list(parent.findChildren(QtWidgets.QDockWidget) or []):
                        if other is None or other is dock:
                            continue
                        title = texto_seguro(other.windowTitle()).strip().lower()
                        obj_name = texto_seguro(other.objectName()).strip().lower()
                        if any(token in title for token in ("tasks", "task", "tareas")) or any(token in obj_name for token in ("tasks", "task", "tareas")):
                            task_dock = other
                            break
                    if task_dock is not None:
                        parent.splitDockWidget(dock, task_dock, QtCore.Qt.Vertical)
                except Exception:
                    pass
                try:
                    parent.resizeDocks([dock], [dock_pref_w], QtCore.Qt.Horizontal)
                except Exception:
                    pass
                lay = QtWidgets.QVBoxLayout(root)
            except Exception:
                dock = None
                root = None
                lay = None

        if root is None or lay is None:
            dlg.setWindowTitle(DEFAULT_PANEL_TITLE)
            dlg.resize(dialog_w, dialog_h)
            try:
                dlg.setMinimumSize(max(680, dialog_w - 80), max(600, dialog_h - 120))
            except Exception:
                pass
            if QtCore is not None:
                dlg.setWindowModality(QtCore.Qt.NonModal)
                dlg.setWindowFlag(QtCore.Qt.Tool, True)
            lay = QtWidgets.QVBoxLayout(dlg)

        panel_host = root if root is not None else dlg
        try:
            panel_host.setObjectName("AlimPanelRoot")
            panel_host.setStyleSheet(PANEL_STYLESHEET)
        except Exception:
            pass
        try:
            lay.setContentsMargins(14, 14, 14, 14)
            lay.setSpacing(12)
        except Exception:
            pass

        state = {"tablero": board_pref, "caras": list(faces_pref), "rutas": list(guides_pref)}

        def _make_rich_label(text, role="help"):
            lbl = QtWidgets.QLabel(text)
            lbl.setWordWrap(True)
            try:
                lbl.setTextFormat(QtCore.Qt.RichText)
            except Exception:
                pass
            try:
                lbl.setProperty("role", role)
            except Exception:
                pass
            return lbl

        intro_card = QtWidgets.QFrame()
        intro_card.setObjectName("introCard")
        lay_intro = QtWidgets.QVBoxLayout(intro_card)
        lay_intro.setContentsMargins(0, 0, 0, 0)
        lay_intro.setSpacing(4)
        lbl_intro_tag = _make_rich_label("Selección / Selection", role="eyebrow")
        lbl_intro_title = _make_rich_label("Panel de alimentadores / Feeder panel", role="heroTitle")
        lbl_intro_sub = _make_rich_label("Controles básicos para tablero y rutas guía / Basic controls for panel and guide routes", role="heroSub")
        lbl_intro = _make_rich_label(
            "<b>ES:</b> Seleccione tablero, caras activas y rutas guía.<br>"
            "<b>EN:</b> Select panel, active faces, and guide routes.",
            role="help",
        )
        lay_intro.addWidget(lbl_intro_tag)
        lay_intro.addWidget(lbl_intro_title)
        lay_intro.addWidget(lbl_intro_sub)
        lay_intro.addWidget(lbl_intro)

        lbl_tab = QtWidgets.QLabel()
        lbl_faces = QtWidgets.QLabel()
        lbl_guides = QtWidgets.QLabel(bi("Rutas guía:", "Guide routes:"))
        list_guides = QtWidgets.QListWidget()
        list_guides.setMinimumHeight(72)
        list_guides.setMaximumHeight(96)
        try:
            list_guides.setSelectionMode(QtWidgets.QAbstractItemView.ExtendedSelection)
        except Exception:
            pass
        try:
            list_guides.setUniformItemSizes(True)
        except Exception:
            pass
        try:
            list_guides.setSizePolicy(QtWidgets.QSizePolicy.Expanding, QtWidgets.QSizePolicy.Fixed)
        except Exception:
            pass

        def _set_route_guides(route_objs):
            state["rutas"] = _sorted_route_guides(route_objs)

        def _add_route_guides(route_objs):
            merged = []
            seen = set()
            for obj in list(state["rutas"] or []) + list(route_objs or []):
                if obj is None or not es_ruta_guia(obj):
                    continue
                name = texto_seguro(getattr(obj, "Name", "")).strip()
                if not name or name in seen:
                    continue
                merged.append(obj)
                seen.add(name)
            state["rutas"] = _sorted_route_guides(merged)

        def _remove_selected_route_guides():
            rows = sorted(
                {int(list_guides.row(item)) for item in list(list_guides.selectedItems() or []) if int(list_guides.row(item)) >= 0},
                reverse=True,
            )
            if not rows:
                return
            rutas_now = list(state["rutas"] or [])
            for row in rows:
                if 0 <= row < len(rutas_now):
                    del rutas_now[row]
            state["rutas"] = rutas_now

        def refresh():
            lbl_tab.setText(bi("Tablero", "Panel") + ": " + (texto_seguro(getattr(state["tablero"], "Label", "")) or texto_seguro(getattr(state["tablero"], "Name", "")) or bi("(ninguno)", "(none)")))
            lbl_faces.setText(bi("Caras", "Faces") + ": " + (", ".join(state["caras"]) if state["caras"] else bi("automáticas", "automatic")))
            list_guides.clear()
            for obj in state["rutas"]:
                list_guides.addItem(texto_seguro(getattr(obj, "Label", "")) or texto_seguro(getattr(obj, "Name", "")))

        btn_tab = QtWidgets.QPushButton(bi("Tomar selección", "Use selection"))
        btn_guias = QtWidgets.QPushButton(bi("Reemplazar", "Replace"))
        btn_add_guias = QtWidgets.QPushButton(bi("Agregar", "Add"))
        btn_remove_guias = QtWidgets.QPushButton(bi("Quitar", "Remove"))
        btn_todas = QtWidgets.QPushButton(bi("Grupo/doc.", "Group/doc."))
        btn_tab.clicked.connect(lambda: (state.update({"tablero": tablero_y_caras_desde_seleccion()[0], "caras": tablero_y_caras_desde_seleccion()[1]}), refresh()))
        btn_guias.clicked.connect(lambda: (_set_route_guides(rutas_guia_desde_seleccion()), refresh()))
        btn_add_guias.clicked.connect(lambda: (_add_route_guides(rutas_guia_desde_seleccion()), refresh()))
        btn_remove_guias.clicked.connect(lambda: (_remove_selected_route_guides(), refresh()))
        btn_todas.clicked.connect(lambda: (_set_route_guides(rutas_guia_desde_grupo_o_documento(self.doc)), refresh()))
        guides_btn_row = QtWidgets.QGridLayout()
        guides_btn_row.addWidget(btn_guias, 0, 0)
        guides_btn_row.addWidget(btn_add_guias, 0, 1)
        guides_btn_row.addWidget(btn_remove_guias, 1, 0)
        guides_btn_row.addWidget(btn_todas, 1, 1)

        form = QtWidgets.QFormLayout()
        sp_route = QtWidgets.QDoubleSpinBox()
        sp_route.setRange(-5000.0, 20000.0)
        sp_route.setSuffix(" mm")
        sp_route.setDecimals(1)
        sp_route.setValue(route_z_default)
