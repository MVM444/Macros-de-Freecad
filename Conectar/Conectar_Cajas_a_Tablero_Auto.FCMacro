        guide_buttons.addWidget(btn_pick_guides, 0, 0)
        guide_buttons.addWidget(btn_clear_guides, 0, 1)
        guide_buttons.addWidget(btn_rename_guides, 1, 0, 1, 2)

        guide_note = QtWidgets.QLabel(
