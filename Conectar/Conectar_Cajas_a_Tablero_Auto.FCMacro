def _candidate_anchor_objects(doc):
    out = []
    seen = set()
    for obj in getattr(doc, "Objects", []) or []:
        if obj is None or _is_group(obj):
            continue
        name = _safe_text(getattr(obj, "Name", "")).strip()
        if not name or name in seen:
            continue
        txt = f"{_safe_text(getattr(obj, 'Label', ''))} {_safe_text(getattr(obj, 'Name', ''))} {_safe_text(getattr(obj, 'Tipo', ''))}".lower()
        ctype = _fallback_component_type(obj)
        if ctype == "Tablero":
            pri = 0
        elif _is_octagon_box(obj):
            pri = 1
        elif hasattr(obj, "PuertosJSON"):
            pri = 2
        elif any(tok in txt for tok in ("conduit", "emt", "pvc", "tuber", "canal", "ducto", "charola")):
            pri = 3
        else:
            continue
        seen.add(name)
        if not hasattr(obj, "Placement") and not hasattr(obj, "Shape"):
            continue
        out.append((pri, obj))

    def _rank(item):
        pri, obj = item
        return (pri, _safe_text(getattr(obj, "Label", "")).lower(), _safe_text(getattr(obj, "Name", "")).lower())

    out.sort(key=_rank)
    return [obj for _pri, obj in out]


def _polyline_points_from_object(obj):
    if obj is None or _is_group(obj):
        return []
    try:
        shape = getattr(obj, "Shape", None)
    except Exception:
        shape = None
    if shape is None:
        return []
    try:
        if shape.isNull():
            return []
    except Exception:
        pass

    candidates = []
    try:
        for wire in (getattr(shape, "Wires", []) or []):
            pts = []
            for vtx in (getattr(wire, "OrderedVertexes", []) or []):
                pt = getattr(vtx, "Point", None)
                if pt is not None:
                    pts.append(_vec(pt.x, pt.y, pt.z))
            if len(pts) >= 2:
                candidates.append(_dedup_points(pts))
    except Exception:
        pass

    if candidates:
        candidates.sort(key=lambda pts: len(pts), reverse=True)
        return candidates[0]

    try:
        pts = []
        for vtx in (getattr(shape, "OrderedVertexes", []) or []):
            pt = getattr(vtx, "Point", None)
            if pt is not None:
                pts.append(_vec(pt.x, pt.y, pt.z))
        if len(pts) >= 2:
            return _dedup_points(pts)
    except Exception:
        pass

    try:
        pts = []
        for vtx in (getattr(shape, "Vertexes", []) or []):
            pt = getattr(vtx, "Point", None)
            if pt is not None:
                pts.append(_vec(pt.x, pt.y, pt.z))
        if len(pts) >= 2:
            return _dedup_points(pts)
    except Exception:
        pass
    return []


def _is_guide_route_candidate(obj):
    pts = _polyline_points_from_object(obj)
    if len(pts) < 2:
        return False
    try:
        if pts[0].distanceToPoint(pts[-1]) <= 0.1:
            return False
    except Exception:
        pass
    return True


def _candidate_guide_objects(doc):
    out = []
    seen = set()
    for obj in getattr(doc, "Objects", []) or []:
        if obj is None or _is_group(obj):
            continue
        name = _safe_text(getattr(obj, "Name", "")).strip()
        if not name or name in seen:
            continue
        if not _is_guide_route_candidate(obj):
            continue
        seen.add(name)
        out.append(obj)
    out.sort(key=lambda o: (_safe_text(getattr(o, "Label", "")).lower(), _safe_text(getattr(o, "Name", "")).lower()))
    return out


def _object_display_text(obj):
    label = _safe_text(getattr(obj, "Label", "")) or _safe_text(getattr(obj, "Name", ""))
    name = _safe_text(getattr(obj, "Name", ""))
    return f"{label} ({name})"


def _selection_summary_text(selection_ctx):
    ctx = selection_ctx or {}
    sel = list(ctx.get("selection") or [])
    groups = list(ctx.get("groups") or [])
    selection_anchor = ctx.get("selection_anchor")
    persisted_anchor = ctx.get("anchor")
    if not sel:
        if persisted_anchor is not None:
            return (
                "Sin seleccion actual. Se usara el documento completo, salvo que elija grupos manualmente "
                f"desde el arbol. Tablero/ancla persistente: {_object_display_text(persisted_anchor)}."
            )
        return "Sin seleccion actual. Se usara el documento completo, salvo que elija grupos manualmente desde el arbol."

    parts = [f"Seleccion actual: {len(sel)} objeto(s)."]
    if groups:
        parts.append(f"Circuitos inferidos: {len(groups)}.")
    else:
        parts.append("Sin circuitos inferidos desde la seleccion.")
    if selection_anchor is not None:
        parts.append(f"Ancla/tablero detectado en la seleccion: {_object_display_text(selection_anchor)}.")
    elif persisted_anchor is not None:
        parts.append(f"Tablero/ancla persistente: {_object_display_text(persisted_anchor)}.")
    else:
        parts.append("Sin tablero/ancla detectado en la seleccion.")
    parts.append("Si selecciona una toma o apagador, se procesara su grupo de circuito.")
    return " ".join(parts)


class _ConfigDialog(object):
    def __init__(self, doc, selection_ctx):
        self.doc = doc
        self.selection_ctx = selection_ctx or {}
        self.anchor_items = _candidate_anchor_objects(doc)
        # El orden manual es global al documento, no solo al alcance actual.
        self.circuit_items = _candidate_circuit_groups(doc, [])

    def _set_combo_name(self, combo, name):
        want = _safe_text(name).strip()
        if not want:
            return
        for i in range(combo.count()):
            if _safe_text(combo.itemData(i)).strip() == want:
                combo.setCurrentIndex(i)
                return

    def _ensure_combo_has_object(self, combo, obj):
        if obj is None:
            return
        name = _safe_text(getattr(obj, "Name", "")).strip()
        if not name:
            return
        for i in range(combo.count()):
            if _safe_text(combo.itemData(i)).strip() == name:
                combo.setCurrentIndex(i)
                return
        combo.addItem(_object_display_text(obj), name)
        combo.setCurrentIndex(combo.count() - 1)

    def _current_selection_object(self):
        sel = _selection_objects()
        if sel:
            return sel[0]
        return None

    def _current_selection_objects(self):
        return list(_selection_objects() or [])

    def _board_face_from_subshape(self, obj, subshape):
        if obj is None or subshape is None:
            return ""
        try:
            u0, u1, v0, v1 = subshape.ParameterRange
            normal = subshape.normalAt(0.5 * (u0 + u1), 0.5 * (v0 + v1))
        except Exception:
            normal = None
        if normal is not None:
            try:
                nx = float(normal.x)
                ny = float(normal.y)
                nz = float(normal.z)
                ax = abs(nx)
                ay = abs(ny)
                az = abs(nz)
                if az >= ax and az >= ay and az > 0.25:
                    return "Top" if nz > 0.0 else "Bottom"
                if ax >= ay and ax > 0.25:
                    return "East" if nx > 0.0 else "West"
                if abs(ny) > 0.25:
                    return "North" if ny > 0.0 else "South"
            except Exception:
                pass
        try:
            obj_bb = getattr(getattr(obj, "Shape", None), "BoundBox", None)
            face_bb = getattr(subshape, "BoundBox", None)
            if obj_bb is None or face_bb is None:
                return ""
            best = min(
                (
                    (abs(float(face_bb.XMin) - float(obj_bb.XMin)), "West"),
                    (abs(float(face_bb.XMax) - float(obj_bb.XMax)), "East"),
                    (abs(float(face_bb.YMin) - float(obj_bb.YMin)), "South"),
                    (abs(float(face_bb.YMax) - float(obj_bb.YMax)), "North"),
                    (abs(float(face_bb.ZMin) - float(obj_bb.ZMin)), "Bottom"),
                    (abs(float(face_bb.ZMax) - float(obj_bb.ZMax)), "Top"),
                ),
                key=lambda it: float(it[0]),
            )
            return best[1]
        except Exception:
            return ""

    def _selection_face_subshape(self, sel_ex, idx, sub_name):
        sub_objs = list(getattr(sel_ex, "SubObjects", []) or [])
        if idx < len(sub_objs) and sub_objs[idx] is not None:
            return sub_objs[idx]
        sobj = getattr(sel_ex, "Object", None)
        shape = getattr(sobj, "Shape", None) if sobj is not None else None
        if shape is None:
            return None
        try:
            return shape.getElement(_safe_text(sub_name).strip())
        except Exception:
            return None

    def _selection_anchor_face_pick(self):
        picks = []
        for sel_ex in (_selection_ex() or []):
            sobj = getattr(sel_ex, "Object", None)
            if sobj is None:
                continue
            sub_names = list(getattr(sel_ex, "SubElementNames", []) or [])
            faces = []
            seen = set()
            for idx, sub_name in enumerate(sub_names):
                sub_txt = _safe_text(sub_name).strip()
                if not sub_txt.startswith("Face"):
                    continue
                sub_obj = self._selection_face_subshape(sel_ex, idx, sub_txt)
                face_name = self._board_face_from_subshape(sobj, sub_obj)
                if face_name and face_name not in seen:
                    faces.append(face_name)
                    seen.add(face_name)
            if faces:
                picks.append((0 if _is_board_like(sobj) else 1, sobj, faces))
        if not picks:
            return None, []
        picks.sort(key=lambda it: (int(it[0]), _safe_text(getattr(it[1], "Label", "")).lower(), _safe_text(getattr(it[1], "Name", "")).lower()))
        return picks[0][1], picks[0][2]

    def _selected_anchor_face_names(self, list_widget):
        names = []
        for i in range(list_widget.count()):
            item = list_widget.item(i)
            name = _safe_text(item.data(QtCore.Qt.UserRole) if QtCore else item.text()).strip()
            if name in BOARD_FACES and name not in names:
                names.append(name)
        return names

    def _set_selected_anchor_faces(self, list_widget, faces):
        list_widget.clear()
        seen = set()
        for face_name in (faces or []):
            key = _safe_text(face_name).strip()
            if key not in BOARD_FACES or key in seen:
                continue
            seen.add(key)
            item = QtWidgets.QListWidgetItem(key)
            if QtCore:
                item.setData(QtCore.Qt.UserRole, key)
            list_widget.addItem(item)

    def _anchor_faces_status_text(self, faces):
        vals = [x for x in (faces or []) if _safe_text(x).strip() in BOARD_FACES]
        if not vals:
            return "Caras del tablero activas: automatico (todas)."
        return "Caras del tablero activas: " + ", ".join(vals) + "."

    def _anchor_face_display_text(self, faces):
        vals = [x for x in (faces or []) if _safe_text(x).strip() in BOARD_FACES]
        if not vals:
            return "Automatico (todas)"
        if len(vals) == 1:
            return vals[0]
        return ", ".join(vals)

    def _sync_anchor_face_controls(self, combo_face, list_widget, value_widget=None, label_widget=None):
        vals = self._selected_anchor_face_names(list_widget)
        target = vals[0] if len(vals) == 1 else "Auto"
        idx = max(0, combo_face.findText(target))
        combo_face.setCurrentIndex(idx)
        if value_widget is not None:
            value_widget.setText(self._anchor_face_display_text(vals))
        self._update_anchor_faces_status(label_widget, list_widget)

    def _update_anchor_faces_status(self, label_widget, list_widget):
        if label_widget is None:
            return
        label_widget.setText(self._anchor_faces_status_text(self._selected_anchor_face_names(list_widget)))

    def _apply_anchor_face_selection(self, combo_face, list_widget, faces, value_widget=None, label_widget=None):
        picked = [x for x in (faces or []) if _safe_text(x).strip() in BOARD_FACES]
        if not picked:
            return
        self._set_selected_anchor_faces(list_widget, picked)
        self._sync_anchor_face_controls(combo_face, list_widget, value_widget, label_widget)

    def _assign_anchor_from_selection(self, combo):
        obj = self._current_selection_object()
        if obj is None:
            _warn("No hay seleccion activa para capturar como tablero/ancla.")
            return
        self._ensure_combo_has_object(combo, obj)

    def _assign_anchor_faces_from_selection(self, combo_anchor, combo_face, list_widget, value_widget=None, label_widget=None):
        obj, faces = self._selection_anchor_face_pick()
        if obj is None:
            _warn("No hay seleccion activa para capturar caras de tablero/ancla.")
            return
        self._ensure_combo_has_object(combo_anchor, obj)
        if not faces:
            _warn("Seleccione una o mas caras del tablero/ancla para capturarlas.")
            return
        self._apply_anchor_face_selection(combo_face, list_widget, faces, value_widget, label_widget)
        _log(
            "Caras tablero capturadas: "
            f"{', '.join(faces)} | objeto={_safe_text(getattr(obj, 'Label', '')) or _safe_text(getattr(obj, 'Name', ''))}"
        )

    def _clear_anchor_faces(self, combo_face, list_widget, value_widget=None, label_widget=None):
        self._set_selected_anchor_faces(list_widget, [])
        self._sync_anchor_face_controls(combo_face, list_widget, value_widget, label_widget)

    def _refresh_anchor_list(self, combo):
        current_name = _safe_text(combo.currentData()).strip()
        self.anchor_items = _candidate_anchor_objects(self.doc)
        combo.clear()
        combo.addItem("(Sin tablero/ancla)", "")
        for obj in self.anchor_items:
            combo.addItem(_object_display_text(obj), obj.Name)
        self._set_combo_name(combo, current_name)

    def _selected_guide_names(self, list_widget):
        names = []
        for i in range(list_widget.count()):
            item = list_widget.item(i)
            name = _safe_text(item.data(QtCore.Qt.UserRole) if QtCore else item.text()).strip()
            if name:
                names.append(name)
        return names

    def _set_selected_guides(self, list_widget, names):
        list_widget.clear()
        seen = set()
        for name in (names or []):
            key = _safe_text(name).strip()
            if not key or key in seen:
                continue
            seen.add(key)
            obj = _find_object_by_name(self.doc, key)
            text = _object_display_text(obj) if obj is not None else key
            item = QtWidgets.QListWidgetItem(text)
            if QtCore:
                item.setData(QtCore.Qt.UserRole, key)
            list_widget.addItem(item)

    def _candidate_circuits_for_ui(self):
        groups = _candidate_circuit_groups(self.doc, [])
        if not groups:
            groups = list(self.circuit_items or [])
        self.circuit_items = list(groups or [])
        return self.circuit_items

    def _set_circuit_order(self, list_widget, groups, ordered_ids=None):
        order_ids = [_safe_text(x).strip() for x in (ordered_ids or []) if _safe_text(x).strip()]
        group_map = {}
        for grp in (groups or []):
            gid = _group_id(grp)
            if gid and gid not in group_map:
                group_map[gid] = grp
        ordered = []
        seen = set()
        for gid in order_ids:
            grp = group_map.get(gid)
            if grp is None or gid in seen:
                continue
            ordered.append(grp)
            seen.add(gid)
        leftovers = sorted(
            [grp for gid, grp in group_map.items() if gid not in seen],
            key=lambda g: _natural_key(_circuit_id_for_group(g)),
        )
        ordered.extend(leftovers)
        list_widget.clear()
        for grp in ordered:
            gid = _group_id(grp)
            if not gid:
                continue
            item = QtWidgets.QListWidgetItem(_circuit_id_for_group(grp))
            if QtCore:
                item.setData(QtCore.Qt.UserRole, gid)
            item.setToolTip(gid)
            list_widget.addItem(item)

    def _selected_circuit_order_ids(self, list_widget):
        out = []
        for i in range(list_widget.count()):
            item = list_widget.item(i)
            gid = _safe_text(item.data(QtCore.Qt.UserRole) if QtCore else item.text()).strip()
            if gid:
                out.append(gid)
        return out

    def _refresh_circuit_order(self, list_widget):
        groups = self._candidate_circuits_for_ui()
        current = self._selected_circuit_order_ids(list_widget)
        self._set_circuit_order(list_widget, groups, current)

    def _move_circuit_order(self, list_widget, delta):
        row = list_widget.currentRow()
        if row < 0:
            return
        target = row + int(delta)
        if target < 0 or target >= list_widget.count():
            return
        item = list_widget.takeItem(row)
        list_widget.insertItem(target, item)
        list_widget.setCurrentRow(target)

    def _clear_circuit_order(self, list_widget):
        groups = self._candidate_circuits_for_ui()
        self._set_circuit_order(list_widget, groups, [])

    def _section_display_text(self, section_key):
        key = _safe_text(section_key).strip()
        if not key or key == "AUTO":
            return "AUTO (sin guia)"
        obj = _find_object_by_name(self.doc, key)
        return _object_display_text(obj) if obj is not None else key

    def _selected_section_keys(self, list_widget):
        out = []
        for i in range(list_widget.count()):
            item = list_widget.item(i)
            key = _safe_text(item.data(QtCore.Qt.UserRole) if QtCore else item.text()).strip()
            if key:
                out.append(key)
        return out

    def _set_section_order(self, list_widget, section_keys, ordered_keys=None):
        want = [_safe_text(x).strip() for x in (ordered_keys or []) if _safe_text(x).strip()]
        keys = []
        seen = set()
        for key in (section_keys or []):
            k = _safe_text(key).strip()
            if not k or k in seen:
                continue
            seen.add(k)
            keys.append(k)
        if "AUTO" not in seen:
            keys.append("AUTO")
        out = []
        used = set()
        for key in want:
            if key in keys and key not in used:
                out.append(key)
                used.add(key)
        leftovers = [k for k in keys if k not in used]
        leftovers = sorted(leftovers, key=lambda x: (1 if x == "AUTO" else 0, self._section_display_text(x).lower()))
        out.extend(leftovers)
        list_widget.clear()
        for key in out:
            item = QtWidgets.QListWidgetItem(self._section_display_text(key))
            if QtCore:
                item.setData(QtCore.Qt.UserRole, key)
            item.setToolTip(key)
            list_widget.addItem(item)

    def _set_section_keys_in_combo(self, combo, section_keys):
        current = _safe_text(combo.currentData()).strip()
        combo.blockSignals(True)
        combo.clear()
        seen = set()
        for key in (section_keys or []):
            k = _safe_text(key).strip()
            if not k or k in seen:
                continue
            seen.add(k)
            combo.addItem(self._section_display_text(k), k)
        if combo.count() == 0:
            combo.addItem("AUTO (sin guia)", "AUTO")
        idx = combo.findData(current)
        combo.setCurrentIndex(idx if idx >= 0 else 0)
        combo.blockSignals(False)

    def _selected_section_circuit_ids(self, list_widget):
        out = []
        for i in range(list_widget.count()):
            item = list_widget.item(i)
            gid = _safe_text(item.data(QtCore.Qt.UserRole) if QtCore else item.text()).strip()
            if gid:
                out.append(gid)
        return out

    def _set_section_circuit_order(self, list_widget, items, ordered_ids=None):
        want = [_safe_text(x).strip() for x in (ordered_ids or []) if _safe_text(x).strip()]
        item_map = {}
        for gid, label in (items or []):
            key = _safe_text(gid).strip()
            if key and key not in item_map:
                item_map[key] = _safe_text(label).strip() or key
        ordered = []
        used = set()
        for gid in want:
            if gid in item_map and gid not in used:
                ordered.append((gid, item_map[gid]))
                used.add(gid)
        leftovers = sorted(
            [(gid, label) for gid, label in item_map.items() if gid not in used],
            key=lambda pair: _natural_key(pair[1]),
        )
        ordered.extend(leftovers)
        list_widget.clear()
        for gid, label in ordered:
            item = QtWidgets.QListWidgetItem(label)
            if QtCore:
                item.setData(QtCore.Qt.UserRole, gid)
            item.setToolTip(gid)
            list_widget.addItem(item)

    def _preview_section_circuit_items(self, anchor_name, anchor_face, anchor_faces, guide_names, include_apagadores=True, section_override_map=None):
        board_obj = _find_object_by_name(self.doc, anchor_name)
        guide_objs = [o for o in _objects_by_names(self.doc, guide_names) if _is_guide_route_candidate(o)]
        get_component_type = _import_component_classifier()
        groups = self._candidate_circuits_for_ui()
        section_map = defaultdict(list)
        section_keys = []
        seen_sections = set()
        for key in list(guide_names or []) + ["AUTO"]:
            k = _safe_text(key).strip()
            if not k or k in seen_sections:
                continue
            seen_sections.add(k)
            section_keys.append(k)
        preview_cfg = {
            "fallback_missing_box": True,
            "direct_same_level_only": True,
            "device_level_tolerance": DEFAULT_DEVICE_LEVEL_TOLERANCE,
            "connect_to_board": True,
        }
        for cgroup in groups:
            circuit_id = _circuit_id_for_group(cgroup)
            devices, boxes = _collect_circuit_objects(
                cgroup,
                get_component_type=get_component_type,
                include_apagadores=bool(include_apagadores),
            )
            if not devices and not boxes:
                continue
            box_by_source = _map_boxes_by_source(boxes)
            plan = _build_plan_for_circuit(
                circuit_group=cgroup,
                devices=devices,
                boxes=boxes,
                box_by_source=box_by_source,
                board_obj=board_obj,
                cfg=preview_cfg,
            )
            src_obj = _feeder_source_from_plan(plan)
            section_key = "AUTO"
            if src_obj is not None and board_obj is not None and guide_objs:
                src_pt = _anchor_point(src_obj)
                board_ep = _board_face_endpoint(
                    board_obj,
                    toward_point=src_pt,
                    forced_face=_safe_text(anchor_face).strip() or "Auto",
                    tangent_offset=0.0,
                    allowed_faces=[x for x in (anchor_faces or list(BOARD_FACES)) if _safe_text(x).strip() in BOARD_FACES],
                )
                guide_info = _best_guide_for_pair(
                    src_pt,
                    board_ep.get("point"),
                    guide_objs,
                    offset_vec=_vec(0.0, 0.0, 0.0),
                    offset_scalar=0.0,
                    prefer_start=True,
                )
                if guide_info is not None:
                    section_key = _safe_text(getattr(guide_info.get("obj"), "Name", "")).strip() or "AUTO"
            gid = _group_id(cgroup) or circuit_id
            forced_key = _safe_text(dict(section_override_map or {}).get(gid, "")).strip()
            if forced_key:
                section_key = forced_key
            section_map[section_key].append((gid, circuit_id))
            if section_key not in seen_sections:
                seen_sections.add(section_key)
                section_keys.append(section_key)
        return section_keys, dict(section_map)

    def _assign_guides_from_selection(self, list_widget):
        objs = [o for o in self._current_selection_objects() if _is_guide_route_candidate(o)]
        if not objs:
            _warn("Seleccione una o mas polilineas/wires guia en el plano de trabajo.")
            return
        self._set_selected_guides(list_widget, [_safe_text(getattr(o, "Name", "")) for o in objs])

    def _clear_guides(self, list_widget):
        list_widget.clear()

    def _ensure_root_group(self, name, label=None):
        grp = _find_object_by_name(self.doc, name)
        if grp is None:
            try:
                grp = self.doc.addObject("App::DocumentObjectGroup", name)
            except Exception:
                grp = _find_object_by_name(self.doc, name)
        if grp is not None and label:
            try:
                grp.Label = _safe_text(label)
            except Exception:
                pass
        return grp

    def _rename_and_group_guides(self, list_widget):
        names = self._selected_guide_names(list_widget)
        if not names:
            sel = [o for o in self._current_selection_objects() if _is_guide_route_candidate(o)]
            names = [_safe_text(getattr(o, "Name", "")) for o in sel]
        objs = [o for o in _objects_by_names(self.doc, names) if _is_guide_route_candidate(o)]
        if not objs:
            _warn("No hay rutas guia validas para renombrar/agrupar.")
            return

        objs = sorted(
            objs,
            key=lambda o: (
                _safe_text(getattr(o, "Label", "")).lower(),
                _safe_text(getattr(o, "Name", "")).lower(),
            ),
        )

        g_electrico = self._ensure_root_group("electrico", label="electrico")
        if g_electrico is None:
            _warn("No se pudo crear/encontrar el grupo raiz 'electrico'.")
            return
        g_guides = _ensure_child_group(self.doc, g_electrico, "Rutas_Guia_2D", prefix="RutasGuia")

        new_names = []
        try:
            self.doc.openTransaction("ElectricCR: renombrar y agrupar rutas guia")
        except Exception:
            pass
        try:
            for idx, obj in enumerate(objs, start=1):
                target_name = f"Ruta_Guia_{idx:03d}"
                target_label = f"Ruta Guia {idx:03d}"
                current_name = _safe_text(getattr(obj, "Name", "")).strip()
                if target_name != current_name:
                    probe = target_name
                    salt = 1
                    while True:
                        existing = _find_object_by_name(self.doc, probe)
                        if existing is None or existing is obj:
                            break
                        probe = f"{target_name}_{salt:02d}"
                        salt += 1
                    target_name = probe
                    try:
                        self.doc.renameObject(current_name, target_name)
                    except Exception:
                        pass
                obj2 = _find_object_by_name(self.doc, target_name) or obj
                try:
                    obj2.Label = target_label
                except Exception:
                    pass
                _ensure_in_group(g_guides, obj2)
                new_names.append(_safe_text(getattr(obj2, "Name", "")).strip())
            try:
                self.doc.recompute()
            except Exception:
                pass
            try:
                self.doc.commitTransaction()
            except Exception:
                pass
        except Exception:
            try:
                self.doc.abortTransaction()
            except Exception:
                pass
            raise

        self._set_selected_guides(list_widget, new_names)

    def _move_dialog_to_side(self, dlg, parent):
        if QtCore is None:
            return
        try:
            dlg.adjustSize()
        except Exception:
            pass
        try:
            base_geo = parent.frameGeometry() if parent is not None else dlg.frameGeometry()
            screen = None
            if parent is not None and parent.windowHandle() is not None:
                screen = parent.windowHandle().screen()
            if screen is not None:
                avail = screen.availableGeometry()
            else:
                avail = QtWidgets.QApplication.desktop().availableGeometry(parent)  # type: ignore[attr-defined]
            right_x = base_geo.x() + base_geo.width() + 12
            x = min(right_x, avail.right() - dlg.width() - 12)
            y = max(avail.top() + 12, base_geo.y() + 40)
            if x < avail.left() + 12:
                x = max(avail.left() + 12, base_geo.x() - dlg.width() - 12)
            if y + dlg.height() > avail.bottom() - 12:
                y = max(avail.top() + 12, avail.bottom() - dlg.height() - 12)
            dlg.move(x, y)
        except Exception:
            pass

    def run(self):
        cfg = _default_config()
        if not GUI_UP or QtWidgets is None:
            return cfg

        parent = None
        try:
            parent = Gui.getMainWindow()
        except Exception:
            parent = None

        dlg = QtWidgets.QDialog(parent)
        dock = None
        root = None
        lay = None
        if QtCore is not None and parent is not None and hasattr(QtWidgets, "QDockWidget"):
            try:
                old = parent.findChild(QtWidgets.QDockWidget, "ElectricCR_ConectarCajasTableroDock")
                if old is not None:
                    old.close()
                    old.deleteLater()
            except Exception:
                pass
            try:
                dock = QtWidgets.QDockWidget(f"Conectar Cajas a Tablero (Auto) v{UI_VERSION}", parent)
                dock.setObjectName("ElectricCR_ConectarCajasTableroDock")
                # Mantener el panel fijo evita caidas al arrastrar/flotar el dock
                # en algunas instalaciones de FreeCAD/PySide.
                dock.setAllowedAreas(QtCore.Qt.RightDockWidgetArea)
                dock.setMinimumWidth(440)
                dock.setMaximumWidth(540)
                dock.setFeatures(QtWidgets.QDockWidget.DockWidgetClosable)
                try:
                    dock.setFloating(False)
                except Exception:
                    pass
                root = QtWidgets.QWidget(dock)
                root.setObjectName("CajaTabAutoRoot")
                root.setStyleSheet(_config_dialog_qss())
                dock.setWidget(root)
                parent.addDockWidget(QtCore.Qt.RightDockWidgetArea, dock)
                lay = QtWidgets.QVBoxLayout(root)
            except Exception:
                dock = None
                root = None
                lay = None

        if root is None or lay is None:
            dlg.setWindowTitle(f"Conectar Cajas a Tablero (Auto) v{UI_VERSION}")
            dlg.setMinimumWidth(500)
            if QtCore is not None:
                dlg.setWindowModality(QtCore.Qt.NonModal)
                dlg.setWindowFlag(QtCore.Qt.Tool, True)
            root = QtWidgets.QWidget(dlg)
            root.setObjectName("CajaTabAutoRoot")
            root.setStyleSheet(_config_dialog_qss())
            outer = QtWidgets.QVBoxLayout(dlg)
            outer.addWidget(root)
