        form.addRow(bi("Nivel ruta:", "Route elevation:"), sp_route)
        form.addRow(bi("Radio curvatura:", "Bend radius:"), sp_bend)
        form.addRow(bi("Separación circuitos:", "Circuit spacing:"), sp_sep)
        form.addRow(bi("Inicio abanico tablero:", "Board fan start:"), sp_board_align)
        form.addRow("", chk_apag)
        form.addRow("", chk_perim)
        form.addRow("", chk_refresh)

        lbl_backend = QtWidgets.QLabel(
            "Motor estable encapsulado / Stable engine wrapper. "
            f"NetworkX disponible / available: {'SI / YES' if backend.networkx_available() else 'NO / NO'}"
        )
        lbl_backend.setWordWrap(True)
        try:
            lbl_backend.setProperty("role", "help")
        except Exception:
            pass
        lbl_manual = QtWidgets.QLabel(
            "ES: la macro reutiliza los datos manuales heredados y aquí se pueden revisar visualmente.<br>"
            "EN: the macro reuses inherited manual data and lets you review it visually here."
        )
        lbl_manual.setWordWrap(True)
        try:
            lbl_manual.setProperty("role", "help")
        except Exception:
            pass
        manual_state = {
            "guide_order": list(manual_guide_order_default),
            "circuit_order": list(manual_circuit_order_default),
            "section_order_map": dict(manual_section_map_default),
            "section_override_map": dict(manual_section_override_default),
            "board_slot_map": dict(manual_board_slot_default),
        }
        preview_state = {"jobs": [], "section_keys": [], "section_map": {}, "job_items": [], "job_section_map": {}}
        active_section_state = {"key": "AUTO"}
        board_state = {"columns": int(board_slot_columns_default), "rows": int(board_slot_rows_default)}
        btn_open_board_table = QtWidgets.QPushButton("Abrir salidas de tuberia del tablero...")
        lbl_board_table_summary = QtWidgets.QLabel("")
        lbl_board_table_summary.setWordWrap(True)
        board_jobs_mime = "application/x-electriccr-board-jobs"

        class _BoardJobListWidget(QtWidgets.QListWidget):
            def mimeData(self, items):
                try:
                    mime = super(_BoardJobListWidget, self).mimeData(items)
                except Exception:
                    mime = QtCore.QMimeData() if QtCore is not None else None
                if mime is None and QtCore is not None:
                    mime = QtCore.QMimeData()
                gids = []
                for item in list(items or []):
                    gid = texto_seguro(item.data(QtCore.Qt.UserRole) if QtCore else item.text()).strip()
                    if gid and gid not in gids:
                        gids.append(gid)
                if mime is not None and QtCore is not None and gids:
                    mime.setData(board_jobs_mime, "\n".join(gids).encode("utf-8"))
                return mime

        class _BoardSlotTableWidget(QtWidgets.QTableWidget):
            def __init__(self, *args, **kwargs):
                super(_BoardSlotTableWidget, self).__init__(*args, **kwargs)
                self._drop_callback = None

            def set_drop_callback(self, callback):
                self._drop_callback = callback

            def mimeData(self, items):
                try:
                    mime = super(_BoardSlotTableWidget, self).mimeData(items)
                except Exception:
                    mime = QtCore.QMimeData() if QtCore is not None else None
                if mime is None and QtCore is not None:
                    mime = QtCore.QMimeData()
                gids = []
                for item in list(items or []):
                    gid = texto_seguro(item.data(QtCore.Qt.UserRole) if QtCore else item.text()).strip()
                    if gid and gid not in gids:
                        gids.append(gid)
                if mime is not None and QtCore is not None and gids:
                    mime.setData(board_jobs_mime, "\n".join(gids).encode("utf-8"))
                return mime

            def _decode_gids(self, mime):
                if mime is None:
                    return []
                raw = b""
                try:
                    if QtCore is not None and mime.hasFormat(board_jobs_mime):
                        raw = bytes(mime.data(board_jobs_mime))
                except Exception:
                    raw = b""
                text = ""
                if raw:
                    try:
                        text = raw.decode("utf-8")
                    except Exception:
                        text = ""
                gids = [texto_seguro(x).strip() for x in texto_seguro(text).splitlines() if texto_seguro(x).strip()]
                return gids

            def dragEnterEvent(self, event):
                gids = self._decode_gids(event.mimeData())
                if gids:
                    event.acceptProposedAction()
                    return
                super(_BoardSlotTableWidget, self).dragEnterEvent(event)

            def dragMoveEvent(self, event):
                gids = self._decode_gids(event.mimeData())
                if gids:
                    event.acceptProposedAction()
                    return
                super(_BoardSlotTableWidget, self).dragMoveEvent(event)

            def dropEvent(self, event):
                gids = self._decode_gids(event.mimeData())
                if not gids or self._drop_callback is None:
                    super(_BoardSlotTableWidget, self).dropEvent(event)
                    return
                try:
                    pos = event.pos()
                except Exception:
                    pos = None
                idx = self.indexAt(pos) if pos is not None else None
                if idx is None or not idx.isValid():
                    row = int(self.currentRow())
                    col = int(self.currentColumn())
                else:
                    row = int(idx.row())
                    col = int(idx.column())
                if row < 0 or col < 0:
                    row, col = 0, 0
                try:
                    self._drop_callback(gids, row, col, bool(event.source() is self))
                    event.acceptProposedAction()
                except Exception:
                    super(_BoardSlotTableWidget, self).dropEvent(event)

        def _route_section_items():
            items = []
            seen = set()
            for obj in list(state["rutas"] or []):
                key = texto_seguro(getattr(obj, "Name", "")).strip() or texto_seguro(getattr(obj, "Label", "")).strip()
                label = texto_seguro(getattr(obj, "Label", "")).strip() or key
                if key and key not in seen:
                    items.append((key, label))
                    seen.add(key)
            if "AUTO" not in seen:
                items.append(("AUTO", "AUTO"))
            return items

        def _route_key_from_any(value):
            raw = texto_seguro(value).strip()
            if not raw or raw == "AUTO":
                return "AUTO" if raw == "AUTO" else raw
            for obj in list(state["rutas"] or []):
                name = texto_seguro(getattr(obj, "Name", "")).strip()
                label = texto_seguro(getattr(obj, "Label", "")).strip()
                if raw == name or raw == label:
                    return name or label
            return raw

        def _section_label(key):
            raw = texto_seguro(key).strip()
            if not raw:
                return ""
            if raw == "AUTO":
                return "AUTO"
            for obj in list(state["rutas"] or []):
                name = texto_seguro(getattr(obj, "Name", "")).strip()
                label = texto_seguro(getattr(obj, "Label", "")).strip()
                if raw == name or raw == label:
                    return label or name
            return raw

        def _job_label_map():
            return {
                texto_seguro(job.get("job_key", "")).strip(): texto_seguro(job.get("circuit_id", "")).strip()
                for job in list(preview_state.get("jobs", []) or [])
                if texto_seguro(job.get("job_key", "")).strip()
            }

        def _board_default_columns():
            jobs_n = max(1, len(list(preview_state.get("jobs", []) or [])))
            cols = max(1, (jobs_n + 1) // 2)
            return int(cols)

        def _normalize_board_slot_map():
            valid_jobs = set(_job_label_map().keys())
            cols = max(1, int(board_state.get("columns", 0) or _board_default_columns()))
            rows_n = max(1, int(board_state.get("rows", 2) or 2))
            out = {}
            for key, val in dict(manual_state.get("board_slot_map", {}) or {}).items():
                gid = texto_seguro(key).strip()
                if not gid or gid not in valid_jobs:
                    continue
                row = None
                col = None
                if isinstance(val, dict):
                    row = val.get("row", None)
                    col = val.get("col", None)
                elif isinstance(val, (list, tuple)) and len(val) >= 2:
                    row = val[0]
                    col = val[1]
                try:
                    row = int(row)
                    col = int(col)
                except Exception:
                    continue
                if row < 0 or row >= rows_n:
                    continue
                if col < 0 or col >= cols:
                    continue
                out[gid] = {"row": int(row), "col": int(col)}
            manual_state["board_slot_map"] = out
            return out

        def _board_fill_sequence(cols, start_row=0, start_col=0):
            out = []
            cols_n = max(0, int(cols))
            rows_n = max(1, int(board_state.get("rows", 2) or 2))
            c0 = max(0, int(start_col))
            r0 = max(0, min(rows_n - 1, int(start_row)))
            base_rows = list(range(rows_n))
            rotated_rows = base_rows[r0:] + base_rows[:r0]
            for col in range(c0, cols_n):
                rows = list(rotated_rows)
                if (col - c0) % 2 == 1:
                    rows = list(reversed(rows))
                for row in rows:
                    out.append((row, col))
            return out

        def _warn(msg):
            log_error(msg)
            try:
                QtWidgets.QMessageBox.warning(parent, DEFAULT_PANEL_TITLE, texto_seguro(msg))
            except Exception:
                pass

        def _list_ids(list_widget):
            out = []
            for idx in range(list_widget.count()):
                item = list_widget.item(idx)
                data = item.data(QtCore.Qt.UserRole) if QtCore is not None else item.text()
                txt = texto_seguro(data).strip()
                if txt:
                    out.append(txt)
            return out

        def _set_list_items(list_widget, items, ordered_ids=None):
            list_widget.clear()
            ordered_ids = [_route_key_from_any(x) for x in list(ordered_ids or []) if texto_seguro(x).strip()]
            item_map = {texto_seguro(k).strip(): texto_seguro(v) for k, v in list(items or []) if texto_seguro(k).strip()}
            keys = []
            for key in ordered_ids:
                if key in item_map and key not in keys:
                    keys.append(key)
            for key in sorted(item_map.keys(), key=natural_key):
                if key not in keys:
                    keys.append(key)
            for key in keys:
                item = QtWidgets.QListWidgetItem(item_map[key])
                if QtCore is not None:
                    item.setData(QtCore.Qt.UserRole, key)
                list_widget.addItem(item)

        def _move_current_item(list_widget, delta):
            row = list_widget.currentRow()
            if row < 0:
                return
            target = row + int(delta)
            if target < 0 or target >= list_widget.count():
                return
            item = list_widget.takeItem(row)
            list_widget.insertItem(target, item)
            list_widget.setCurrentRow(target)

        def _reverse_list_items(list_widget):
            rows = []
            current_key = ""
            if list_widget is None:
                return
            current_item = list_widget.currentItem()
            if current_item is not None:
                try:
                    current_key = texto_seguro(current_item.data(QtCore.Qt.UserRole) if QtCore is not None else current_item.text()).strip()
                except Exception:
                    current_key = ""
            for idx in range(list_widget.count()):
                item = list_widget.item(idx)
                if item is None:
                    continue
                gid = texto_seguro(item.data(QtCore.Qt.UserRole) if QtCore is not None else item.text()).strip()
                label = texto_seguro(item.text()).strip()
                if gid:
                    rows.append((gid, label))
            rows.reverse()
            _set_list_items(list_widget, rows, [gid for gid, _label in rows])
            if current_key:
                for idx in range(list_widget.count()):
                    item = list_widget.item(idx)
                    if item is None:
                        continue
                    gid = texto_seguro(item.data(QtCore.Qt.UserRole) if QtCore is not None else item.text()).strip()
                    if gid == current_key:
                        list_widget.setCurrentRow(idx)
                        break

        def _set_combo_keys(combo, keys):
            current = texto_seguro(combo.currentData()).strip()
            combo.blockSignals(True)
            combo.clear()
            for key in list(keys or []):
                k = _route_key_from_any(key)
                combo.addItem(_section_label(k), k)
            idx = combo.findData(current)
            if idx < 0:
                idx = combo.findData("AUTO")
            if idx >= 0:
                combo.setCurrentIndex(idx)
            combo.blockSignals(False)

        def _build_preview():
            tablero_preview = state["tablero"]
            rutas_preview = list(state["rutas"] or [])
            if tablero_preview is None:
                preview_state["jobs"] = []
                preview_state["section_keys"] = ["AUTO"]
                preview_state["section_map"] = {"AUTO": []}
                preview_state["job_items"] = []
                preview_state["job_section_map"] = {}
                return
            temp_cfg = {
                "include_apagadores": bool(chk_apag.isChecked()),
                "route_by_perimeter": bool(chk_perim.isChecked()),
                "route_z": float(sp_route.value()),
                "bend_radius": float(sp_bend.value()),
                "separation": float(sp_sep.value()),
                "board_align_distance": float(sp_board_align.value()),
                "manual_circuit_order_enabled": bool(chk_manual_circuits.isChecked()),
                "manual_circuit_order": list(_list_ids(list_circuits)),
                "manual_guide_order_enabled": bool(chk_manual_guides.isChecked()),
                "manual_guide_order": list(_list_ids(list_sections)),
                "manual_section_circuit_order_enabled": bool(chk_manual_section_circuits.isChecked()),
                "manual_section_circuit_order_map": dict(manual_state["section_order_map"]),
                "manual_section_override_map": dict(manual_state["section_override_map"]),
            }
            engine_preview = cfg_backend(tablero_preview, list(state["caras"] or []), temp_cfg)
            circuit_groups = backend.candidate_circuit_groups(self.doc, [])
            circuit_groups = backend.sort_circuit_groups_manual(circuit_groups, engine_preview)
            jobs = []
            for cgroup in circuit_groups:
                circuit_id = backend.circuit_id_for_group(cgroup)
                devices, boxes = backend.collect_circuit_objects(cgroup, include_apagadores=temp_cfg["include_apagadores"])
                if not devices and not boxes:
                    continue
                plan, _box_by_source = backend.build_plan_for_circuit(cgroup, devices, boxes, engine_preview, tablero_preview)
                if backend.feeder_source_from_plan(plan) is None:
                    continue
                jobs.append({
                    "job_key": backend.group_id(cgroup) or circuit_id,
                    "circuit_id": circuit_id,
                    "group": cgroup,
                })
            lane_map, lane_count, lane_meta_map = backend.feeder_lane_map(jobs, tablero_preview, rutas_preview, engine_preview)
            job_map = {texto_seguro(job.get("job_key", "")).strip(): job for job in list(jobs or [])}
            section_map = {}
            for job in jobs:
                job_key = texto_seguro(job.get("job_key", "")).strip()
                meta = lane_meta_map.get(job_key, {}) if isinstance(lane_meta_map, dict) else {}
                sec_auto = texto_seguro(meta.get("section_key", "")).strip() or "AUTO"
                sec_manual = _route_key_from_any(manual_state["section_override_map"].get(job_key, ""))
                sec = sec_manual or sec_auto or "AUTO"
                section_map.setdefault(sec, []).append((job_key, job["circuit_id"]))
            section_map = {k: v for k, v in section_map.items() if list(v or [])}
            if bool(chk_manual_section_circuits.isChecked()):
                for sec in list(section_map.keys()):
                    ordered = [texto_seguro(x).strip() for x in list(manual_state["section_order_map"].get(sec, []) or []) if texto_seguro(x).strip()]
                    item_map = {k: v for k, v in section_map.get(sec, [])}
                    keys = []
                    for key in ordered:
                        if key in item_map and key not in keys:
                            keys.append(key)
                    for key in sorted(item_map.keys(), key=natural_key):
                        if key not in keys:
                            keys.append(key)
                    section_map[sec] = [(key, item_map[key]) for key in keys]
            section_keys = list(section_map.keys())
            if "AUTO" not in section_keys:
                section_keys.append("AUTO")
            ordered_sections = []
            for key in _list_ids(list_sections):
                if key in section_keys and key not in ordered_sections:
                    ordered_sections.append(key)
            for key in sorted(section_keys, key=natural_key):
                if key not in ordered_sections:
                    ordered_sections.append(key)
            preview_state["jobs"] = jobs
            preview_state["section_keys"] = ordered_sections
            preview_state["section_map"] = section_map
            preview_state["job_items"] = [(texto_seguro(job.get("job_key", "")).strip(), texto_seguro(job.get("circuit_id", "")).strip()) for job in jobs]
            preview_state["job_section_map"] = {
                texto_seguro(gid).strip(): texto_seguro(sec).strip() or "AUTO"
                for sec, pairs in list(section_map.items())
                for gid, _lbl in list(pairs or [])
                if texto_seguro(gid).strip()
            }

        grp_circuits = QtWidgets.QGroupBox(bi("Orden manual de circuitos", "Manual circuit order"))
        lay_circuits = QtWidgets.QVBoxLayout(grp_circuits)
        chk_manual_circuits = QtWidgets.QCheckBox(bi("Usar orden manual", "Use manual order"))
        chk_manual_circuits.setChecked(bool(manual_circuit_enabled_default))
        list_circuits = QtWidgets.QListWidget()
        list_circuits.setMinimumHeight(110)
        list_circuits.setDragDropMode(QtWidgets.QAbstractItemView.InternalMove)
        list_circuits.setDefaultDropAction(QtCore.Qt.MoveAction if QtCore else list_circuits.defaultDropAction())
        list_circuits.setSelectionMode(QtWidgets.QAbstractItemView.SingleSelection)
        circuit_items = [(gid, cid) for gid, cid in [(backend.group_id(g) or backend.circuit_id_for_group(g), backend.circuit_id_for_group(g)) for g in backend.candidate_circuit_groups(self.doc, [])] if texto_seguro(gid).strip()]
        _set_list_items(list_circuits, circuit_items, manual_state["circuit_order"])
        row_circuits = QtWidgets.QHBoxLayout()
        btn_circuit_up = QtWidgets.QPushButton("Subir")
        btn_circuit_down = QtWidgets.QPushButton("Bajar")
        btn_clear_circuits = QtWidgets.QPushButton(bi("Automático", "Automatic"))
        row_circuits.addWidget(btn_circuit_up)
        row_circuits.addWidget(btn_circuit_down)
        row_circuits.addWidget(btn_clear_circuits)
        lay_circuits.addWidget(chk_manual_circuits)
        lay_circuits.addWidget(list_circuits)
        lay_circuits.addLayout(row_circuits)

        grp_sections = QtWidgets.QGroupBox(bi("Secciones / guías", "Sections / guides"))
        lay_sections = QtWidgets.QVBoxLayout(grp_sections)
        chk_manual_guides = QtWidgets.QCheckBox(bi("Usar orden manual de secciones", "Use manual section order"))
        chk_manual_guides.setChecked(bool(manual_guide_enabled_default))
        list_sections = QtWidgets.QListWidget()
        list_sections.setMinimumHeight(110)
        list_sections.setDragDropMode(QtWidgets.QAbstractItemView.InternalMove)
        list_sections.setDefaultDropAction(QtCore.Qt.MoveAction if QtCore else list_sections.defaultDropAction())
