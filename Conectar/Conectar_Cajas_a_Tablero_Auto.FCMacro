        btn_section_up = QtWidgets.QPushButton("Subir")
        btn_section_down = QtWidgets.QPushButton("Bajar")
        btn_clear_sections = QtWidgets.QPushButton("Automatico")
        section_buttons.addWidget(btn_refresh_sections, 0, 0)
        section_buttons.addWidget(btn_clear_sections, 0, 1)
        section_buttons.addWidget(btn_section_up, 1, 0)
        section_buttons.addWidget(btn_section_down, 1, 1)
        note_sections = QtWidgets.QLabel(
            "Cada guia forma una seccion de salida del tablero. AUTO agrupa los circuitos sin guia."
        )
        note_sections.setWordWrap(True)
        note_sections.setStyleSheet("color:#4b5563;")
        lay_sections.addWidget(chk_manual_guides)
        lay_sections.addWidget(list_sections)
        lay_sections.addLayout(section_buttons)
        lay_sections.addWidget(note_sections)

        grp_section_circuits = QtWidgets.QGroupBox("Circuitos por seccion")
        lay_section_circuits = QtWidgets.QVBoxLayout(grp_section_circuits)
        chk_manual_section_circuits = QtWidgets.QCheckBox("Usar orden manual de circuitos por seccion")
        chk_manual_section_circuits.setChecked(bool(cfg.get("manual_section_circuit_order_enabled", False)))
        cmb_section_filter = QtWidgets.QComboBox()
        cmb_section_target = QtWidgets.QComboBox()
        list_section_circuits = QtWidgets.QListWidget()
        list_section_circuits.setMinimumHeight(130)
        list_section_circuits.setDragDropMode(QtWidgets.QAbstractItemView.InternalMove)
        list_section_circuits.setDefaultDropAction(QtCore.Qt.MoveAction if QtCore else list_section_circuits.defaultDropAction())
        list_section_circuits.setSelectionMode(QtWidgets.QAbstractItemView.SingleSelection)
        section_circuit_buttons = QtWidgets.QGridLayout()
        btn_refresh_section_circuits = QtWidgets.QPushButton("Actualizar circuitos")
        btn_section_circuit_up = QtWidgets.QPushButton("Subir")
        btn_section_circuit_down = QtWidgets.QPushButton("Bajar")
        btn_clear_section_circuits = QtWidgets.QPushButton("Automatico")
        section_circuit_buttons.addWidget(btn_refresh_section_circuits, 0, 0)
        section_circuit_buttons.addWidget(btn_clear_section_circuits, 0, 1)
        section_circuit_buttons.addWidget(btn_section_circuit_up, 1, 0)
        section_circuit_buttons.addWidget(btn_section_circuit_down, 1, 1)
        row_move_section = QtWidgets.QHBoxLayout()
        row_move_section.addWidget(cmb_section_target, 1)
        btn_move_section = QtWidgets.QPushButton("Mover a seccion")
        btn_reset_section = QtWidgets.QPushButton("Volver a auto")
        row_move_section.addWidget(btn_move_section)
        row_move_section.addWidget(btn_reset_section)
        note_section_circuits = QtWidgets.QLabel(
            "Seleccione una seccion para ordenar solo los circuitos que salen por esa guia o por AUTO."
        )
        note_section_circuits.setWordWrap(True)
        note_section_circuits.setStyleSheet("color:#4b5563;")
        lay_section_circuits.addWidget(chk_manual_section_circuits)
        lay_section_circuits.addWidget(cmb_section_filter)
        lay_section_circuits.addWidget(list_section_circuits)
        lay_section_circuits.addLayout(section_circuit_buttons)
        lay_section_circuits.addLayout(row_move_section)
        lay_section_circuits.addWidget(note_section_circuits)

        section_order_state = {
            key: list(vals)
            for key, vals in dict(cfg.get("manual_section_circuit_order_map", {}) or {}).items()
            if _safe_text(key).strip()
        }
        section_override_state = {
            _safe_text(k).strip(): _safe_text(v).strip()
            for k, v in dict(cfg.get("manual_section_override_map", {}) or {}).items()
            if _safe_text(k).strip() and _safe_text(v).strip()
        }
        section_preview = {"map": {}, "keys": []}
        active_section_state = {"key": "AUTO"}

        def _save_active_section_order():
            sec_key = _safe_text(active_section_state.get("key", "")).strip()
            if not sec_key:
                return
            section_order_state[sec_key] = self._selected_section_circuit_ids(list_section_circuits)

        def _load_active_section_order():
            sec_key = _safe_text(cmb_section_filter.currentData()).strip() or "AUTO"
            active_section_state["key"] = sec_key
            items = list(section_preview["map"].get(sec_key, []) or [])
            self._set_section_circuit_order(
                list_section_circuits,
                items,
                section_order_state.get(sec_key, []),
            )

        def _refresh_sections_and_circuits():
            _save_active_section_order()
            section_keys, section_map = self._preview_section_circuit_items(
                anchor_name=_safe_text(cmb_anchor.currentData()).strip(),
                anchor_face=_safe_text(cmb_anchor_face.currentText() or "Auto"),
                anchor_faces=self._selected_anchor_face_names(list_anchor_faces),
                guide_names=self._selected_guide_names(list_guides),
                include_apagadores=bool(cfg.get("include_apagadores", True)),
                section_override_map=section_override_state,
            )
            section_preview["map"] = dict(section_map or {})
            section_preview["keys"] = list(section_keys or [])
            self._set_section_order(
                list_sections,
                section_preview["keys"],
                self._selected_section_keys(list_sections) or cfg.get("manual_guide_order", []),
            )
            self._set_section_keys_in_combo(cmb_section_filter, self._selected_section_keys(list_sections))
            self._set_section_keys_in_combo(cmb_section_target, self._selected_section_keys(list_sections))
            _load_active_section_order()

        def _move_selected_circuit_to_section(target_section=None, reset_to_auto=False):
            item = list_section_circuits.currentItem()
            gid = _safe_text(item.data(QtCore.Qt.UserRole) if (QtCore and item is not None) else (item.text() if item is not None else "")).strip()
            if not gid:
                _warn("Seleccione un circuito en la lista de la seccion actual.")
                return
            _save_active_section_order()
            for sec_key in list(section_order_state.keys()):
                section_order_state[sec_key] = [x for x in (section_order_state.get(sec_key, []) or []) if _safe_text(x).strip() != gid]
            if reset_to_auto:
                section_override_state.pop(gid, None)
                target_key = "AUTO"
            else:
                target_key = _safe_text(target_section or cmb_section_target.currentData()).strip() or "AUTO"
                section_override_state[gid] = target_key
            target_list = list(section_order_state.get(target_key, []) or [])
            if gid not in target_list:
                target_list.append(gid)
            section_order_state[target_key] = target_list
            _refresh_sections_and_circuits()
            idx = cmb_section_filter.findData(target_key)
            if idx >= 0:
                cmb_section_filter.setCurrentIndex(idx)
            _load_active_section_order()

        _refresh_sections_and_circuits()

        info_scope = QtWidgets.QLabel(
            "Alcance: si selecciona tomas, apagadores o grupos de circuito antes de abrir la macro, "
            "se procesaran esos circuitos. Si no hay seleccion util, se procesara todo el arbol."
        )
        info_scope.setWordWrap(True)
        info_scope.setStyleSheet("color:#4b5563;")

        lay_scope.addWidget(grp_scope)
        lay_scope.addWidget(grp_anchor_faces)
        lay_scope.addWidget(sel_box)
        lay_scope.addWidget(grp_guides)
        lay_scope.addWidget(info_scope)
        lay_scope.addStretch(1)

        tab_route = QtWidgets.QWidget()
        lay_route = QtWidgets.QVBoxLayout(tab_route)

        grp_conduit = QtWidgets.QGroupBox("Canalizacion")
        form_conduit = QtWidgets.QFormLayout(grp_conduit)
        cmb_type = QtWidgets.QComboBox()
        cmb_type.addItems(["EMT", "PVC"])
        idx = max(0, cmb_type.findText(_safe_text(cfg.get("conduit_type", DEFAULT_CONDUIT)).upper()))
        cmb_type.setCurrentIndex(idx)

        sp_diam = QtWidgets.QDoubleSpinBox()
        sp_diam.setRange(1.0, 200.0)
        sp_diam.setDecimals(1)
        sp_diam.setSuffix(" mm")
        sp_diam.setValue(float(cfg.get("diameter", DEFAULT_DIAMETER)))

        sp_route_z = QtWidgets.QDoubleSpinBox()
        sp_route_z.setRange(-5000.0, 20000.0)
        sp_route_z.setDecimals(1)
        sp_route_z.setSuffix(" mm")
        sp_route_z.setValue(float(cfg.get("route_z", DEFAULT_ROUTE_Z)))

        sp_bend = QtWidgets.QDoubleSpinBox()
        sp_bend.setRange(10.0, 1000.0)
        sp_bend.setDecimals(1)
        sp_bend.setSuffix(" mm")
        sp_bend.setValue(float(cfg.get("bend_radius", DEFAULT_BEND_RADIUS)))

        cmb_axis = QtWidgets.QComboBox()
        cmb_axis.addItems(["Horizontal", "Vertical"])
        axis_txt = _safe_text(cfg.get("feeder_axis", DEFAULT_FEEDER_AXIS)).strip() or DEFAULT_FEEDER_AXIS
        axis_idx = max(0, cmb_axis.findText(axis_txt))
        cmb_axis.setCurrentIndex(axis_idx)

        sp_margin = QtWidgets.QDoubleSpinBox()
        sp_margin.setRange(0.0, 5000.0)
        sp_margin.setDecimals(1)
        sp_margin.setSuffix(" mm")
        sp_margin.setValue(float(cfg.get("wall_margin", DEFAULT_WALL_OFFSET)))
        sp_margin.setToolTip("0 mantiene la ruta exactamente sobre el perimetro definido por cajas y tablero.")

        sp_sep = QtWidgets.QDoubleSpinBox()
        sp_sep.setRange(0.0, 5000.0)
        sp_sep.setDecimals(1)
        sp_sep.setSuffix(" mm")
        sp_sep.setValue(float(cfg.get("circuit_separation", DEFAULT_CIRCUIT_SEPARATION)))

        form_conduit.addRow("Tipo:", cmb_type)
        form_conduit.addRow("Diametro:", sp_diam)
        form_conduit.addRow("Nivel ruta:", sp_route_z)
        form_conduit.addRow("Radio curvatura:", sp_bend)
        form_conduit.addRow("Organizar alimentadores:", cmb_axis)
        form_conduit.addRow("Offset extra al perimetro:", sp_margin)
        form_conduit.addRow("Separacion circuitos:", sp_sep)

        note_route = QtWidgets.QLabel(
            "Regla de proyecto: el perimetro ya lo definen las octogonales sobre el muro. "
            "Use offset extra solo si quiere despegar intencionalmente la ruta."
        )
        note_route.setWordWrap(True)
        note_route.setStyleSheet("color:#4b5563;")

        lay_route.addWidget(grp_conduit)
        lay_route.addWidget(note_route)
        lay_route.addStretch(1)

        tab_rules = QtWidgets.QWidget()
        lay_rules_tab = QtWidgets.QVBoxLayout(tab_rules)
        grp_rules = QtWidgets.QGroupBox("Reglas")
        lay_rules = QtWidgets.QVBoxLayout(grp_rules)

        tab_circuits = QtWidgets.QWidget()
        lay_circuits_tab = QtWidgets.QVBoxLayout(tab_circuits)
        circuits_toolbox = QtWidgets.QToolBox()
        circuits_toolbox.setSizePolicy(QtWidgets.QSizePolicy.Expanding, QtWidgets.QSizePolicy.Preferred)
        page_sections = QtWidgets.QWidget()
        lay_page_sections = QtWidgets.QVBoxLayout(page_sections)
        lay_page_sections.setContentsMargins(0, 0, 0, 0)
        lay_page_sections.addWidget(grp_sections)
        lay_page_sections.addStretch(1)
        page_section_circuits = QtWidgets.QWidget()
        lay_page_section_circuits = QtWidgets.QVBoxLayout(page_section_circuits)
        lay_page_section_circuits.setContentsMargins(0, 0, 0, 0)
        lay_page_section_circuits.addWidget(grp_section_circuits)
        lay_page_section_circuits.addStretch(1)
        circuits_toolbox.addItem(page_sections, "Secciones / guias")
        circuits_toolbox.addItem(page_section_circuits, "Circuitos por seccion")
        circuits_toolbox.setCurrentIndex(1)
        lay_circuits_tab.addWidget(circuits_toolbox)
        lay_circuits_tab.addStretch(1)

        chk_apa = QtWidgets.QCheckBox("Incluir apagadores")
        chk_apa.setChecked(bool(cfg.get("include_apagadores", True)))
        chk_missing = QtWidgets.QCheckBox("Si falta caja, conectar al dispositivo mas cercano")
        chk_missing.setChecked(bool(cfg.get("fallback_missing_box", True)))
        chk_same_level = QtWidgets.QCheckBox("Conexion directa dispositivo-dispositivo solo si estan a la misma cota")
        chk_same_level.setChecked(bool(cfg.get("direct_same_level_only", True)))
        sp_level_tol = QtWidgets.QDoubleSpinBox()
        sp_level_tol.setRange(0.0, 500.0)
        sp_level_tol.setDecimals(1)
        sp_level_tol.setSuffix(" mm")
        sp_level_tol.setValue(float(cfg.get("device_level_tolerance", DEFAULT_DEVICE_LEVEL_TOLERANCE)))
        row_level_tol = QtWidgets.QWidget()
        row_level_tol_lay = QtWidgets.QHBoxLayout(row_level_tol)
        row_level_tol_lay.setContentsMargins(18, 0, 0, 0)
        row_level_tol_lay.addWidget(QtWidgets.QLabel("Tolerancia de cota:"))
        row_level_tol_lay.addWidget(sp_level_tol)
        row_level_tol_lay.addStretch(1)
        chk_ortho = QtWidgets.QCheckBox("Ruta ortogonal (X-Y-Z)")
