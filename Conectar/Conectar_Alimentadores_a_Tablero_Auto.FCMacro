        def _build_cfg():
            _save_active_section_order()
            cfg = {
                "tablero": state["tablero"],
                "caras": list(state["caras"] or []),
                "rutas": list(state["rutas"] or []),
                "route_z": float(sp_route.value()),
                "bend_radius": float(sp_bend.value()),
                "separation": float(sp_sep.value()),
                "board_align_distance": float(sp_board_align.value()),
                "include_apagadores": bool(chk_apag.isChecked()),
                "route_by_perimeter": bool(chk_perim.isChecked()),
                "refresh_existing_routes": bool(chk_refresh.isChecked()),
                "anchor_face": texto_seguro(engine_defaults.get("anchor_face", "Auto")) or "Auto",
                "anchor_faces": list(engine_defaults.get("anchor_faces", []) or []),
                "manual_circuit_order": list(_list_ids(list_circuits)),
                "manual_circuit_order_enabled": bool(chk_manual_circuits.isChecked()),
                "manual_guide_order": list(_list_ids(list_sections)),
                "manual_guide_order_enabled": bool(chk_manual_guides.isChecked()),
                "manual_section_circuit_order_map": dict(manual_state["section_order_map"]),
                "manual_section_circuit_order_enabled": bool(chk_manual_section_circuits.isChecked()),
                "manual_section_override_map": dict(manual_state["section_override_map"]),
                "manual_board_slot_map": dict(manual_state["board_slot_map"]),
                "board_slot_columns": int(board_state.get("columns", max(1, int(sp_board_cols.value())))),
                "board_slot_rows": int(board_state.get("rows", max(1, int(sp_board_rows.value())))),
            }
            pref_set("board_name", texto_seguro(getattr(cfg["tablero"], "Name", "")))
            pref_set("board_faces", cfg["caras"])
            pref_set("guide_names", [texto_seguro(getattr(o, "Name", "")) for o in cfg["rutas"] if texto_seguro(getattr(o, "Name", ""))])
            pref_set("route_z", cfg["route_z"])
            pref_set("bend_radius", cfg["bend_radius"])
            pref_set("separation", cfg["separation"])
            pref_set("board_align_distance", cfg["board_align_distance"])
            pref_set("include_apagadores", cfg["include_apagadores"])
            pref_set("route_by_perimeter", cfg["route_by_perimeter"])
            pref_set("refresh_existing_routes", cfg["refresh_existing_routes"])
            pref_set("manual_circuit_order_json", cfg["manual_circuit_order"])
            pref_set("manual_circuit_order_enabled", cfg["manual_circuit_order_enabled"])
            pref_set("manual_guide_order_json", cfg["manual_guide_order"])
            pref_set("manual_guide_order_enabled", cfg["manual_guide_order_enabled"])
            pref_set("manual_section_circuit_order_json", cfg["manual_section_circuit_order_map"])
            pref_set("manual_section_circuit_order_enabled", cfg["manual_section_circuit_order_enabled"])
            pref_set("manual_section_override_json", cfg["manual_section_override_map"])
            pref_set("manual_board_slot_map_json", cfg["manual_board_slot_map"])
            pref_set("board_slot_columns", cfg["board_slot_columns"])
            pref_set("board_slot_rows", cfg["board_slot_rows"])
            return cfg

        buttons = QtWidgets.QDialogButtonBox(QtWidgets.QDialogButtonBox.Apply | QtWidgets.QDialogButtonBox.Close)
        try:
            apply_btn = buttons.button(QtWidgets.QDialogButtonBox.Apply)
            if apply_btn is not None:
                apply_btn.setObjectName("primaryAction")
                apply_btn.setText(bi("Actualizar alimentadores", "Update feeders"))
                apply_btn.setToolTip(
                    "ES: borra y redibuja los alimentadores existentes y deja el panel abierto.\n"
                    "EN: deletes and redraws existing feeders while keeping the panel open."
                )
        except Exception:
            apply_btn = None
        try:
            close_btn = buttons.button(QtWidgets.QDialogButtonBox.Close)
            if close_btn is not None:
                close_btn.setText(bi("Cerrar", "Close"))
        except Exception:
            close_btn = None

        lay.addWidget(tabs)
        lay.addWidget(buttons)
        refresh()

        last_cfg = {"value": None}

        def _apply_current():
            cfg = _build_cfg()
            last_cfg["value"] = cfg
            if callable(self.on_apply):
                try:
                    if apply_btn is not None:
                        apply_btn.setEnabled(False)
                    try:
                        QtWidgets.QApplication.processEvents()
                    except Exception:
                        pass
                    self.on_apply(cfg)
                finally:
                    if apply_btn is not None:
                        apply_btn.setEnabled(True)

        def _close_panel():
            if dock is not None:
                dock.close()
            else:
                try:
                    dlg.close()
                except Exception:
                    dlg.reject()

        if apply_btn is not None:
            apply_btn.clicked.connect(_apply_current)
        if close_btn is not None:
            close_btn.clicked.connect(_close_panel)

        if QtCore is None:
            dlg.exec_()
            return last_cfg["value"]
        else:
            loop = QtCore.QEventLoop()

            if dock is not None:
                try:
                    dock.visibilityChanged.connect(lambda visible: loop.quit() if not visible else None)
                except Exception:
                    pass
                dock.show()
                try:
                    parent.resizeDocks([dock], [dock_pref_w], QtCore.Qt.Horizontal)
                except Exception:
                    pass
                try:
                    dock.raise_()
                except Exception:
                    pass
            else:
                dlg.show()
                try:
                    dlg.raise_()
                    dlg.activateWindow()
                except Exception:
                    pass
                dlg.finished.connect(loop.quit)

            loop.exec_()
            return last_cfg["value"]


def cfg_backend(tablero, caras, cfg):
    anchor_faces = list(caras or cfg.get("anchor_faces", []) or [])
    anchor_face = caras[0] if len(caras) == 1 else (texto_seguro(cfg.get("anchor_face", "Auto")) or "Auto")
    return {
        "connect_to_board": True,
        "include_apagadores": bool(cfg.get("include_apagadores", DEFAULT_INCLUDE_APAGADORES)),
        "route_by_perimeter": bool(cfg.get("route_by_perimeter", DEFAULT_ROUTE_BY_PERIMETER)),
        "route_z": float(cfg.get("route_z", DEFAULT_ROUTE_Z)),
        "bend_radius": float(cfg.get("bend_radius", DEFAULT_BEND_RADIUS)),
        "board_align_distance": float(cfg.get("board_align_distance", DEFAULT_BOARD_ALIGN_DISTANCE)),
        "orthogonal_route": True,
        "wall_margin": 0.0,
        "conduit_type": DEFAULT_CONDUIT,
        "diameter": DEFAULT_DIAMETER,
        "circuit_separation": float(cfg.get("separation", DEFAULT_CIRCUIT_SEPARATION)),
        "feeder_axis": "Horizontal",
        "anchor_name": texto_seguro(getattr(tablero, "Name", "")),
        "anchor_face": anchor_face,
        "anchor_faces": anchor_faces,
        "guide_names": [texto_seguro(getattr(o, "Name", "")) for o in list(cfg.get("rutas", []) or []) if texto_seguro(getattr(o, "Name", ""))],
        "skip_existing": True,
        "reserve_ports": True,
        "manual_circuit_order_enabled": bool(cfg.get("manual_circuit_order_enabled", False)),
        "manual_circuit_order": list(cfg.get("manual_circuit_order", []) or []),
        "manual_guide_order_enabled": bool(cfg.get("manual_guide_order_enabled", False)),
        "manual_guide_order": list(cfg.get("manual_guide_order", []) or []),
        "manual_section_circuit_order_enabled": bool(cfg.get("manual_section_circuit_order_enabled", False)),
        "manual_section_circuit_order_map": dict(cfg.get("manual_section_circuit_order_map", {}) or {}),
        "manual_section_override_map": dict(cfg.get("manual_section_override_map", {}) or {}),
        "manual_board_slot_map": dict(cfg.get("manual_board_slot_map", {}) or {}),
        "board_slot_columns": int(cfg.get("board_slot_columns", 0) or 0),
        "board_slot_rows": int(cfg.get("board_slot_rows", 2) or 2),
    }


def ejecutar_alimentadores(doc, cfg):
    if doc is None:
        log_error("No hay documento activo")
        return
    backend = cargar_backend(force_reload=True)
    tablero = cfg.get("tablero")
    caras = list(cfg.get("caras", []) or [])
    rutas = list(cfg.get("rutas", []) or [])
    if tablero is None:
        log_error("No se selecciono un tablero")
        return
    if not rutas:
        log_error("No se seleccionaron rutas guia")
        return

    engine_cfg = cfg_backend(tablero, caras, cfg)
    log_info(f"Panel detectado: {texto_seguro(getattr(tablero, 'Label', '')) or texto_seguro(getattr(tablero, 'Name', ''))}")
    log_info("Caras activas: " + (", ".join(caras) if caras else "automaticas"))
    log_info(f"Rutas guia detectadas: {len(rutas)}")
    log_info(f"NetworkX disponible en backend: {'SI' if backend.networkx_available() else 'NO'}")
    log_info(
        "Orden manual heredado | secciones={} | circuitos={} | por_seccion={}".format(
            "SI" if engine_cfg.get("manual_guide_order_enabled", False) else "NO",
            "SI" if engine_cfg.get("manual_circuit_order_enabled", False) else "NO",
            "SI" if engine_cfg.get("manual_section_circuit_order_enabled", False) else "NO",
        )
    )

    circuit_groups = backend.candidate_circuit_groups(doc, [])
    circuit_groups = backend.sort_circuit_groups_manual(circuit_groups, engine_cfg)
    if not circuit_groups:
        log_error("No se encontraron grupos de circuito")
        return

    jobs = []
    for cgroup in circuit_groups:
        circuit_id = backend.circuit_id_for_group(cgroup)
        devices, boxes = backend.collect_circuit_objects(cgroup, include_apagadores=cfg.get("include_apagadores", DEFAULT_INCLUDE_APAGADORES))
        if not devices and not boxes:
            continue
        plan, _box_by_source = backend.build_plan_for_circuit(cgroup, devices, boxes, engine_cfg, tablero)
        if backend.feeder_source_from_plan(plan) is None:
            continue
        jobs.append({
            "job_key": backend.group_id(cgroup) or circuit_id,
            "group": cgroup,
            "circuit_id": circuit_id,
            "devices": devices,
            "boxes": boxes,
            "plan": plan,
        })
    if not jobs:
        log_error("No se encontraron alimentadores para generar")
        return

    lane_map, feeder_lane_count, lane_meta_map = backend.feeder_lane_map(jobs, tablero, rutas, engine_cfg)
    if feeder_lane_count <= 0:
        feeder_lane_count = 1
    if isinstance(lane_meta_map, dict) and lane_meta_map:
        jobs = sorted(jobs, key=lambda job: (int(lane_meta_map.get(job.get("job_key"), {}).get("plan_order", 10 ** 9)), natural_key(job.get("circuit_id", ""))))

    stats = {"circuits": 0, "created": 0, "existing": 0, "skipped": 0}
    try:
        removed_empty_groups = int(backend.cleanup_empty_generated_groups(doc))
        if removed_empty_groups:
            log_info(f"Grupos generados vacíos eliminados antes de recalcular = {removed_empty_groups}")
        doc.openTransaction("ElectricCR: Conectar Alimentadores a Tablero Auto")
        cleared = set()
        for job in jobs:
            cgroup = job["group"]
            circuit_id = job["circuit_id"]
            devices = list(job["devices"])
            boxes = list(job["boxes"])
            plan = list(job["plan"])
            stats["circuits"] += 1

            conduit_txt = DEFAULT_CONDUIT
            group_dest = backend.ensure_unique_child_group(doc, cgroup, f"Alimentadores_{conduit_txt}", prefix="Alimentadores", create_if_missing=True)
            legacy_group = backend.ensure_unique_child_group(doc, cgroup, f"Tuberias_{conduit_txt}", prefix="Tuberias", create_if_missing=False)
            branch_group = backend.ensure_unique_child_group(doc, cgroup, f"Ramales_{conduit_txt}", prefix="Ramales", create_if_missing=False)

            gname = texto_seguro(getattr(cgroup, "Name", ""))
            if bool(cfg.get("refresh_existing_routes", DEFAULT_REFRESH_EXISTING)) and gname and gname not in cleared:
                removed = int(backend.delete_autoroute_feeders(doc, cgroup, texto_seguro(getattr(tablero, "Name", ""))))
                if removed:
                    log_info(f"Circuito {circuit_id}: alimentadores eliminados antes de recalcular = {removed}")
                cleared.add(gname)

            existing_keys = set(backend.collect_existing_route_keys(group_dest))
            existing_keys.update(backend.collect_existing_route_keys(legacy_group))
            used_ports = defaultdict(set)
            backend.reserve_existing_ports(group_dest, used_ports)
            backend.reserve_existing_ports(legacy_group, used_ports)
            backend.reserve_existing_ports(branch_group, used_ports)
            route_rect = backend.route_rect_for_feeder(devices, boxes, engine_cfg, tablero)

            lane_meta = lane_meta_map.get(job["job_key"], {}) if isinstance(lane_meta_map, dict) else {}
            face_index = int(lane_meta.get("face_index", lane_map.get(job["job_key"], 0)))
            face_count = int(lane_meta.get("face_count", feeder_lane_count))
            route_index = int(lane_meta.get("route_index", face_index))
            route_count = int(lane_meta.get("route_count", face_count))
            section_key = texto_seguro(lane_meta.get("section_key", "")).strip()
            section_index = int(lane_meta.get("section_index", 0))
            section_count = int(lane_meta.get("section_count", 1))
            section_lane_index = int(lane_meta.get("section_lane_index", 0))
            section_lane_count = int(lane_meta.get("section_lane_count", face_count))
            guide_lane_index = int(lane_meta.get("guide_lane_index", section_lane_index))
            guide_lane_count = int(lane_meta.get("guide_lane_count", section_lane_count))
            guide_straight_priority = bool(lane_meta.get("guide_straight_priority", False))
            board_entry_x = lane_meta.get("board_entry_x", None)
            board_entry_y = lane_meta.get("board_entry_y", None)
            feeder_face = texto_seguro(lane_meta.get("face", "")).strip()
            manual_board_slot = bool(lane_meta.get("manual_board_slot", False))
            manual_board_col = int(lane_meta.get("manual_board_col", 0))
            manual_board_cols = max(1, int(lane_meta.get("manual_board_cols", route_count)))
            if section_key and section_key != "AUTO":
                route_lane_index_for_offset = guide_lane_index
                feeder_lane_vec = backend.lane_offset_vector_for_section(
                    route_lane_index_for_offset,
                    max(1, guide_lane_count),
                    cfg.get("separation", DEFAULT_CIRCUIT_SEPARATION),
                    section_key,
                    rutas,
                    board_obj=tablero,
                )
                log_info(
                    "Offset por guia | circuito={} | seccion={} | lane={}/{}".format(
                        circuit_id,
                        section_key,
                        route_lane_index_for_offset,
                        max(1, guide_lane_count),
                    )
                )
            elif feeder_face in ("Top", "Bottom"):
                if manual_board_slot:
                    route_lane_index_for_offset = manual_board_col
                    feeder_lane_vec = backend.lane_offset_vector(
                        route_lane_index_for_offset,
                        manual_board_cols,
                        cfg.get("separation", DEFAULT_CIRCUIT_SEPARATION),
                        "Horizontal",
                    )
                    log_info(
                        "Offset sobre tablero | circuito={} | face={} | eje=Horizontal | col={}/{}".format(
                            circuit_id,
                            feeder_face or "-",
                            route_lane_index_for_offset,
                            manual_board_cols,
                        )
                    )
                else:
                    route_lane_index_for_offset = max(0, route_count - 1 - route_index)
                    feeder_lane_vec = backend.lane_offset_vector(
                        route_lane_index_for_offset,
                        route_count,
                        cfg.get("separation", DEFAULT_CIRCUIT_SEPARATION),
                        "Vertical",
                    )
                    log_info(
                        "Offset sobre tablero | circuito={} | face={} | eje=Vertical | lane={}/{}".format(
                            circuit_id,
                            feeder_face or "-",
                            route_lane_index_for_offset,
                            route_count,
                        )
                    )
            elif feeder_face == "North":
                route_lane_index_for_offset = route_index
                feeder_lane_vec = backend.lane_offset_vector(
                    route_lane_index_for_offset,
                    route_count,
                    cfg.get("separation", DEFAULT_CIRCUIT_SEPARATION),
                    "Horizontal",
                )
                log_info(
                    "Offset sobre tablero | circuito={} | face={} | eje=Horizontal | lane={}/{}".format(
                        circuit_id,
                        feeder_face,
                        route_lane_index_for_offset,
                        route_count,
                    )
                )
            elif feeder_face == "South":
                route_lane_index_for_offset = route_index
                feeder_lane_vec = backend.lane_offset_vector(
                    route_lane_index_for_offset,
                    route_count,
                    cfg.get("separation", DEFAULT_CIRCUIT_SEPARATION),
                    "Horizontal",
                )
                log_info(
                    "Offset sobre tablero | circuito={} | face={} | eje=Horizontal | lane={}/{}".format(
                        circuit_id,
                        feeder_face,
                        route_lane_index_for_offset,
                        route_count,
                    )
                )
            elif feeder_face in ("East", "West"):
                route_lane_index_for_offset = route_index
                feeder_lane_vec = backend.lane_offset_vector(
                    route_lane_index_for_offset,
                    route_count,
                    cfg.get("separation", DEFAULT_CIRCUIT_SEPARATION),
                    "Vertical",
                )
                log_info(
                    "Offset sobre tablero | circuito={} | face={} | eje=Vertical | lane={}/{}".format(
                        circuit_id,
                        feeder_face,
                        route_lane_index_for_offset,
                        route_count,
                    )
                )
            else:
                route_lane_index_for_offset = route_index
                feeder_lane_vec = backend.lane_offset_vector(
                    route_lane_index_for_offset,
                    route_count,
                    cfg.get("separation", DEFAULT_CIRCUIT_SEPARATION),
                    "Horizontal",
                )

            for src_obj, dst_obj, link_kind in plan:
                if texto_seguro(link_kind).strip().lower() != "feeder":
                    continue
                status, route_key = backend.connect_pair(
                    doc=doc,
                    src_obj=src_obj,
                    dst_obj=dst_obj,
                    circuit_id=circuit_id,
                    conduit_type=conduit_txt,
                    diameter=DEFAULT_DIAMETER,
                    bend_radius=cfg.get("bend_radius", DEFAULT_BEND_RADIUS),
                    route_z=cfg.get("route_z", DEFAULT_ROUTE_Z),
                    route_by_perimeter=cfg.get("route_by_perimeter", DEFAULT_ROUTE_BY_PERIMETER),
                    route_rect=route_rect,
                    guide_objs=rutas,
                    guide_section_key=section_key,
                    board_obj=tablero,
                    anchor_face=texto_seguro(engine_cfg.get("anchor_face", "Auto")) or "Auto",
                    anchor_faces=list(engine_cfg.get("anchor_faces", caras) or []),
                    feeder_lane_vec=feeder_lane_vec,
                    feeder_board_lane_index=face_index,
                    feeder_board_lane_count=face_count,
                    feeder_board_lane_separation=cfg.get("separation", DEFAULT_CIRCUIT_SEPARATION),
                    board_align_distance=cfg.get("board_align_distance", DEFAULT_BOARD_ALIGN_DISTANCE),
                    feeder_board_section_index=section_index,
                    feeder_board_section_count=section_count,
                    feeder_board_section_lane_index=section_lane_index,
                    feeder_board_section_lane_count=section_lane_count,
                    feeder_board_face=feeder_face,
                    manual_board_slot=manual_board_slot,
                    board_slot_rows=cfg.get("board_slot_rows", 2),
                    board_entry_x=board_entry_x,
                    board_entry_y=board_entry_y,
                    guide_lane_index=guide_lane_index,
                    guide_lane_count=guide_lane_count,
                    guide_straight_priority=guide_straight_priority,
                    used_ports=used_ports,
                    group_target=group_dest,
                    existing_keys=existing_keys,
                    skip_existing=True,
                )
                if status == "created":
                    stats["created"] += 1
                    route_obj = backend.find_route_object_by_key(group_dest, route_key)
                    backend.mark_generated_by(route_obj, "Conectar_Alimentadores_a_Tablero_Auto")
                elif status == "existing":
                    stats["existing"] += 1
                else:
                    stats["skipped"] += 1

        removed_empty_groups = int(backend.cleanup_empty_generated_groups(doc))
        if removed_empty_groups:
            log_info(f"Grupos generados vacíos eliminados después de recalcular = {removed_empty_groups}")
        doc.recompute()
        doc.commitTransaction()
    except Exception as ex:
        try:
            doc.abortTransaction()
        except Exception:
            pass
        log_error(f"Error general: {ex}")
        return

    log_info(
        "Proceso terminado | circuitos={} | creados={} | existentes={} | omitidos={}".format(
            stats["circuits"], stats["created"], stats["existing"], stats["skipped"]
        )
    )


def main():
    doc = App.ActiveDocument
    if doc is None:
        log_error("No hay documento activo")
        return
    if Gui is None:
        log_error("FreeCADGui no esta activo")
        return

    def _apply_from_form(cfg):
        ejecutar_alimentadores(doc, cfg)

    cfg = FormularioAlimentadores(doc, on_apply=_apply_from_form).run()
    if QtWidgets is None:
        if cfg is None:
            log_info("Operacion cancelada")
            return
        ejecutar_alimentadores(doc, cfg)


main()
