        grp_sections = QtWidgets.QGroupBox("Orden de secciones / guias")
        lay_sections = QtWidgets.QVBoxLayout(grp_sections)
        chk_manual_guides = QtWidgets.QCheckBox("Usar orden manual de secciones")
        chk_manual_guides.setChecked(bool(cfg.get("manual_guide_order_enabled", False)))
        list_sections = QtWidgets.QListWidget()
        list_sections.setMinimumHeight(110)
        list_sections.setDragDropMode(QtWidgets.QAbstractItemView.InternalMove)
        list_sections.setDefaultDropAction(QtCore.Qt.MoveAction if QtCore else list_sections.defaultDropAction())
        list_sections.setSelectionMode(QtWidgets.QAbstractItemView.SingleSelection)
        self._set_section_order(list_sections, list(cfg.get("guide_names", []) or []) + ["AUTO"], cfg.get("manual_guide_order", []))
        section_buttons = QtWidgets.QGridLayout()
