DEFAULT_DIAMETER = 22.2
DEFAULT_ROUTE_Z = 3000.0
DEFAULT_BEND_RADIUS = 100.0
DEFAULT_CIRCUIT_SEPARATION = 50.0
DEFAULT_BOARD_ALIGN_DISTANCE = 700.0
DEFAULT_INCLUDE_APAGADORES = True
DEFAULT_ROUTE_BY_PERIMETER = True
DEFAULT_REFRESH_EXISTING = True
DEFAULT_PANEL_TITLE = "[ACTIVA] Conectar Alimentadores a Tablero"
_BACKEND = None

