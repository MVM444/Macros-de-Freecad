# -*- coding: utf-8 -*-
# MenuText: [ACTIVA] Conectar Alimentadores a Tablero
# Icon: Conectar_Alimentadores_a_Tablero_Auto.svg
"""
Macro: Conectar_Alimentadores_a_Tablero_Auto
Description:
Dedicated feeder routing from circuit octagonal boxes to an electrical panel.

This macro keeps:
- a simpler FreeCAD panel inspired by v2
- the stable feeder engine encapsulated in alimentadores_backend.py

Notes:
- only feeders
- no branch internal routing
"""

import importlib
import json
import re
import sys
from collections import defaultdict
from pathlib import Path

import FreeCAD as App

try:
    import FreeCADGui as Gui
except Exception:
    Gui = None

try:
    from PySide2 import QtWidgets, QtCore, QtGui
except Exception:
    try:
        from PySide import QtGui as QtWidgets  # type: ignore
        from PySide import QtCore  # type: ignore
        from PySide import QtGui  # type: ignore
    except Exception:
        QtWidgets = None
        QtCore = None
        QtGui = None


