        sp_sep.setValue(separation_default)
        sp_board_align = QtWidgets.QDoubleSpinBox()
        sp_board_align.setRange(0.0, 5000.0)
        sp_board_align.setSuffix(" mm")
        sp_board_align.setDecimals(1)
        sp_board_align.setValue(board_align_distance_default)
        chk_apag = QtWidgets.QCheckBox(bi("Incluir apagadores", "Include switches"))
        chk_apag.setChecked(include_apag_default)
        chk_perim = QtWidgets.QCheckBox(bi("Usar perímetro donde aplique", "Use perimeter where applicable"))
        chk_perim.setChecked(route_perimeter_default)
        chk_refresh = QtWidgets.QCheckBox(bi("Borrar y redibujar alimentadores existentes", "Delete and redraw existing feeders"))
        chk_refresh.setChecked(refresh_existing_default)
        try:
            chk_refresh.setToolTip(
                "ES: elimina los alimentadores automáticos previos del circuito y dibuja los nuevos en la misma ejecución.\n"
                "EN: removes previous automatic feeders for the circuit and redraws them in the same run."
            )
        except Exception:
