# Icon: Conectar_Alimentadores_a_Tablero_Auto_v2.svg
"""
Macro: Conectar_Alimentadores_a_Tablero_Auto_v2
Description:
Automatic feeder routing from octagonal boxes to electrical panels using guide routes.

This version reorganizes the original macro with a cleaner architecture.

Date:
2026

Author:
Codex

Notes:
Uses channel routing concept and guide routes.
Does not attempt full building autorouting.
Uses optional NetworkX only for logical path computation.
Keeps geometry creation inside FreeCAD.
"""

import math
import re
from collections import defaultdict

import FreeCAD as App
import Draft

