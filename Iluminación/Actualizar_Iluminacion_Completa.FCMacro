    ("Plataforma", ("plataforma",)),
    ("Archivo", ("archivo", "boveda")),
    ("Bodega", ("bodega", "almacen", "cuartoaseo", "aseo", "suministro", "suministros")),
    ("Cocina", ("cocina", "comedor")),
    ("Caja", ("caja",)),
    ("Cochera", ("cochera",)),
    ("Parqueo", ("parqueo", "estacionamiento")),
    ("Exteriores", ("exterior", "exteriores")),
    ("Taller", ("taller",)),
    ("Dormitorio", ("dormitorio",)),
