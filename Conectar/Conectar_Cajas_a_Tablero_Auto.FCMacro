DEFAULT_DIAMETER = 22.2
DEFAULT_ROUTE_Z = 3000.0
DEFAULT_BEND_RADIUS = 100.0
DEFAULT_FEEDER_AXIS = "Horizontal"
DEFAULT_CIRCUIT_SEPARATION = 50.0
DEFAULT_WALL_OFFSET = 0.0
DEFAULT_FALLBACK_NEAR_MM = 700.0
DEFAULT_DEVICE_LEVEL_TOLERANCE = 10.0
DEFAULT_PORT_STUB = 80.0
EPS = 1e-6
CARDINAL_PORTS = ("North", "South", "East", "West")
BOARD_FACES = ("North", "South", "East", "West", "Top", "Bottom")
OCTAGON_SIDE_PORTS = ("North", "South", "East", "West", "NorthEast", "NorthWest", "SouthEast", "SouthWest")
ANCHOR_FACE_OPTIONS = ("Auto", "North", "South", "East", "West", "Top", "Bottom")
OCTAGON_PORT_TARGETS = (
    ("East", 0.0),
    ("NorthEast", 45.0),
    ("North", 90.0),
    ("NorthWest", 135.0),
    ("West", 180.0),
    ("SouthWest", -135.0),
    ("South", -90.0),
    ("SouthEast", -45.0),
)
STRICT_BACKBONE_CARDINAL = True
MAX_FEEDER_SPREAD_MM = 600.0
try:
    DEBUG_LOG_PATH = Path(__file__).resolve().with_name("Conectar_Cajas_a_Tablero_Auto.debug.log")
except Exception:
    DEBUG_LOG_PATH = Path.cwd() / "Conectar_Cajas_a_Tablero_Auto.debug.log"
DEBUG_STATE = {
    "enabled": False,
    "path": DEBUG_LOG_PATH,
}


def _log(msg):
    App.Console.PrintMessage(f"{TAG}[INFO] {msg}\n")
    _write_log_line("INFO", msg)


def _warn(msg):
    App.Console.PrintWarning(f"{TAG}[WARN] {msg}\n")
    _write_log_line("WARN", msg)


def _err(msg):
    App.Console.PrintError(f"{TAG}[ERROR] {msg}\n")
    _write_log_line("ERROR", msg)


def _write_log_line(level, msg):
    path = DEBUG_STATE.get("path") or DEBUG_LOG_PATH
    try:
        path = Path(path)
    except Exception:
        path = DEBUG_LOG_PATH
    try:
        path.parent.mkdir(parents=True, exist_ok=True)
        stamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        with path.open("a", encoding="utf-8") as fh:
            fh.write(f"[{stamp}]{TAG}[{_safe_text(level).upper()}] {_safe_text(msg)}\n")
    except Exception:
        pass


def _debug(msg):
    if not bool(DEBUG_STATE.get("enabled", False)):
        return
    _write_log_line("DEBUG", msg)


def _set_debug_enabled(enabled):
    DEBUG_STATE["enabled"] = bool(enabled)


def _debug_log_path():
    try:
        return str(Path(DEBUG_STATE.get("path") or DEBUG_LOG_PATH))
    except Exception:
        return str(DEBUG_LOG_PATH)


def _open_debug_log():
    path = Path(_debug_log_path())
    try:
        path.parent.mkdir(parents=True, exist_ok=True)
        if not path.exists():
            path.touch()
        os.startfile(str(path))  # type: ignore[attr-defined]
    except Exception as ex:
        _warn(f"No se pudo abrir el log: {ex}")


def _start_debug_session(cfg, selection_ctx=None):
    _write_log_line("INFO", "-" * 72)
    _write_log_line("INFO", f"Nueva ejecucion de Conectar Cajas a Tablero (Auto) v{UI_VERSION}.")
    _write_log_line(
        "INFO",
        (
            f"DebugDetallado={'SI' if DEBUG_STATE.get('enabled', False) else 'NO'} "
            f"Conduit={_safe_text(cfg.get('conduit_type', DEFAULT_CONDUIT)).upper()} "
            f"Diametro={float(cfg.get('diameter', DEFAULT_DIAMETER)):.1f} "
            f"RutaZ={float(cfg.get('route_z', DEFAULT_ROUTE_Z)):.1f} "
            f"Radio={float(cfg.get('bend_radius', DEFAULT_BEND_RADIUS)):.1f} "
            f"Perimetro={'SI' if cfg.get('route_by_perimeter', True) else 'NO'} "
            f"Tablero={_safe_text(cfg.get('anchor_name', '')) or '(sin tablero)'} "
            f"CaraTablero={_safe_text(cfg.get('anchor_face', 'Auto')) or 'Auto'} "
            f"CarasPermitidas={','.join(_anchor_allowed_faces(cfg))} "
            f"OrdenManualCircuitos={'SI' if cfg.get('manual_circuit_order_enabled', False) else 'NO'} "
            f"OrdenManualSecciones={'SI' if cfg.get('manual_guide_order_enabled', False) else 'NO'} "
            f"OrdenManualPorSeccion={'SI' if cfg.get('manual_section_circuit_order_enabled', False) else 'NO'} "
            f"OverridesSeccion={len(cfg.get('manual_section_override_map', {}) or {})} "
            f"DirectaMismaCota={'SI' if cfg.get('direct_same_level_only', True) else 'NO'} "
            f"TolCota={float(cfg.get('device_level_tolerance', DEFAULT_DEVICE_LEVEL_TOLERANCE)):.1f} "
            f"RutasGuia={len(cfg.get('guide_names', []) or [])} "
            f"ActualizarRutas={'SI' if cfg.get('refresh_existing_routes', False) else 'NO'}"
        ),
    )
    if selection_ctx:
        groups = selection_ctx.get("groups") or []
        _write_log_line(
            "INFO",
            f"Seleccion inicial: grupos={len(groups)} ancla={'SI' if selection_ctx.get('anchor') is not None else 'NO'}",
        )


def _safe_text(value):
    try:
        return str(value or "")
    except Exception:
        return ""


def _to_float(value, default=0.0):
    try:
        if hasattr(value, "Value"):
            return float(value.Value)
        return float(value)
    except Exception:
        return float(default)


def _safe_name_token(value, fallback="X"):
    txt = _safe_text(value).strip()
    if not txt:
        return fallback
    txt = re.sub(r"[^0-9A-Za-z_]+", "_", txt)
    txt = re.sub(r"_+", "_", txt).strip("_")
    return txt or fallback


def _vec(x=0.0, y=0.0, z=0.0):
    try:
        return App.Vector(float(x), float(y), float(z))
    except Exception:
        return App.Vector(0.0, 0.0, 0.0)


def _fmt_vec(v):
    if v is None:
        return "(None)"
    try:
        return f"({float(v.x):.1f}, {float(v.y):.1f}, {float(v.z):.1f})"
    except Exception:
        return "(?)"


def _fmt_points(points):
    return "[" + ", ".join(_fmt_vec(p) for p in (points or [])) + "]"


def _vlen(v):
    try:
        return float(v.Length)
    except Exception:
        return 0.0


def _normalize(v):
    n = _vlen(v)
    if n <= EPS:
        return _vec(0.0, 0.0, 0.0)
    return _vec(v.x / n, v.y / n, v.z / n)


def _dot(a, b):
    return (float(a.x) * float(b.x)) + (float(a.y) * float(b.y)) + (float(a.z) * float(b.z))


def _effective_fillet_radius(points, requested_radius):
    req = max(0.0, float(requested_radius))
    if req <= EPS:
        return 0.0
    seg_lens = []
    pts = _dedup_points(points)
    for a, b in zip(pts[:-1], pts[1:]):
        d = a.distanceToPoint(b)
        if d > 0.1:
            seg_lens.append(float(d))
    if not seg_lens:
        return 0.0
    limit = max(0.0, min(seg_lens) * 0.45)
    if limit <= EPS:
        return 0.0
    return min(req, limit)


def _angle_deg_xy(vec):
    return math.degrees(math.atan2(float(vec.y), float(vec.x)))


def _circular_distance_deg(a, b):
    d = abs(float(a) - float(b)) % 360.0
    return 360.0 - d if d > 180.0 else d


def _prefs():
    try:
        return App.ParamGet(PARAM_PATH)
    except Exception:
        return None


def _pref_get_bool(key, default):
    p = _prefs()
    if p is None:
        return bool(default)
    try:
        return bool(p.GetBool(str(key), bool(default)))
    except Exception:
        return bool(default)


def _pref_get_float(key, default):
    p = _prefs()
    if p is None:
        return float(default)
    try:
        return float(p.GetFloat(str(key), float(default)))
    except Exception:
        return float(default)


def _pref_get_str(key, default):
    p = _prefs()
    if p is None:
        return str(default)
    try:
        return str(p.GetString(str(key), str(default)))
    except Exception:
        return str(default)


def _json_list(raw):
    try:
        data = json.loads(_safe_text(raw))
        if isinstance(data, list):
            return [_safe_text(x).strip() for x in data if _safe_text(x).strip()]
    except Exception:
        pass
    return []


def _json_dict_of_lists(raw):
    try:
        data = json.loads(_safe_text(raw))
        if isinstance(data, dict):
            out = {}
            for k, vals in data.items():
                key = _safe_text(k).strip()
                if not key:
                    continue
                if isinstance(vals, list):
                    out[key] = [_safe_text(x).strip() for x in vals if _safe_text(x).strip()]
            return out
    except Exception:
        pass
    return {}


def _json_dict_of_str(raw):
    try:
        data = json.loads(_safe_text(raw))
        if isinstance(data, dict):
            out = {}
            for k, v in data.items():
                key = _safe_text(k).strip()
                val = _safe_text(v).strip()
                if key and val:
                    out[key] = val
            return out
    except Exception:
        pass
    return {}


def _save_config(cfg):
    p = _prefs()
    if p is None:
        return
    try:
        p.SetString("anchor_name", _safe_text(cfg.get("anchor_name", "")))
        p.SetString("anchor_face", _safe_text(cfg.get("anchor_face", "Auto")))
        p.SetString("anchor_faces_json", json.dumps(list(cfg.get("anchor_faces", list(BOARD_FACES))) or list(BOARD_FACES), ensure_ascii=True))
        p.SetString("guide_names_json", json.dumps(list(cfg.get("guide_names", []) or []), ensure_ascii=True))
        p.SetString("manual_circuit_order_json", json.dumps(list(cfg.get("manual_circuit_order", []) or []), ensure_ascii=True))
        p.SetBool("manual_circuit_order_enabled", bool(cfg.get("manual_circuit_order_enabled", False)))
        p.SetString("manual_guide_order_json", json.dumps(list(cfg.get("manual_guide_order", []) or []), ensure_ascii=True))
        p.SetBool("manual_guide_order_enabled", bool(cfg.get("manual_guide_order_enabled", False)))
        p.SetString("manual_section_circuit_order_json", json.dumps(dict(cfg.get("manual_section_circuit_order_map", {}) or {}), ensure_ascii=True))
        p.SetBool("manual_section_circuit_order_enabled", bool(cfg.get("manual_section_circuit_order_enabled", False)))
        p.SetString("manual_section_override_json", json.dumps(dict(cfg.get("manual_section_override_map", {}) or {}), ensure_ascii=True))
        p.SetString("conduit_type", _safe_text(cfg.get("conduit_type", DEFAULT_CONDUIT)))
        p.SetFloat("diameter", float(cfg.get("diameter", DEFAULT_DIAMETER)))
        p.SetFloat("route_z", float(cfg.get("route_z", DEFAULT_ROUTE_Z)))
        p.SetFloat("bend_radius", float(cfg.get("bend_radius", DEFAULT_BEND_RADIUS)))
        p.SetString("feeder_axis", _safe_text(cfg.get("feeder_axis", DEFAULT_FEEDER_AXIS)))
        p.SetBool("include_apagadores", bool(cfg.get("include_apagadores", True)))
        p.SetBool("fallback_missing_box", bool(cfg.get("fallback_missing_box", True)))
        p.SetBool("direct_same_level_only", bool(cfg.get("direct_same_level_only", True)))
        p.SetFloat("device_level_tolerance", float(cfg.get("device_level_tolerance", DEFAULT_DEVICE_LEVEL_TOLERANCE)))
        p.SetBool("connect_to_board", bool(cfg.get("connect_to_board", True)))
        p.SetBool("orthogonal_route", bool(cfg.get("orthogonal_route", True)))
        p.SetBool("route_by_perimeter", bool(cfg.get("route_by_perimeter", True)))
        p.SetFloat("wall_margin", float(cfg.get("wall_margin", DEFAULT_WALL_OFFSET)))
        p.SetFloat("circuit_separation", float(cfg.get("circuit_separation", DEFAULT_CIRCUIT_SEPARATION)))
        p.SetBool("reserve_ports", bool(cfg.get("reserve_ports", True)))
        p.SetBool("skip_existing", bool(cfg.get("skip_existing", True)))
        p.SetBool("debug_enabled", bool(cfg.get("debug_enabled", True)))
    except Exception:
        pass


def _default_config():
    sep = _pref_get_float("circuit_separation", DEFAULT_CIRCUIT_SEPARATION)
    if abs(float(sep) - 120.0) <= 1e-9:
        sep = float(DEFAULT_CIRCUIT_SEPARATION)
    return {
        "anchor_name": _pref_get_str("anchor_name", ""),
        "anchor_face": _pref_get_str("anchor_face", "Auto") or "Auto",
        "anchor_faces": _json_list(_pref_get_str("anchor_faces_json", json.dumps(list(BOARD_FACES), ensure_ascii=True))) or list(BOARD_FACES),
        "guide_names": _json_list(_pref_get_str("guide_names_json", "[]")),
        "manual_circuit_order": _json_list(_pref_get_str("manual_circuit_order_json", "[]")),
        "manual_circuit_order_enabled": _pref_get_bool("manual_circuit_order_enabled", False),
        "manual_guide_order": _json_list(_pref_get_str("manual_guide_order_json", "[]")),
        "manual_guide_order_enabled": _pref_get_bool("manual_guide_order_enabled", False),
        "manual_section_circuit_order_map": _json_dict_of_lists(_pref_get_str("manual_section_circuit_order_json", "{}")),
        "manual_section_circuit_order_enabled": _pref_get_bool("manual_section_circuit_order_enabled", False),
        "manual_section_override_map": _json_dict_of_str(_pref_get_str("manual_section_override_json", "{}")),
        "conduit_type": _pref_get_str("conduit_type", DEFAULT_CONDUIT) or DEFAULT_CONDUIT,
        "diameter": _pref_get_float("diameter", DEFAULT_DIAMETER),
        "route_z": _pref_get_float("route_z", DEFAULT_ROUTE_Z),
        "bend_radius": _pref_get_float("bend_radius", DEFAULT_BEND_RADIUS),
        "feeder_axis": _pref_get_str("feeder_axis", DEFAULT_FEEDER_AXIS) or DEFAULT_FEEDER_AXIS,
        "include_apagadores": _pref_get_bool("include_apagadores", True),
        "fallback_missing_box": _pref_get_bool("fallback_missing_box", True),
        "direct_same_level_only": _pref_get_bool("direct_same_level_only", True),
        "device_level_tolerance": _pref_get_float("device_level_tolerance", DEFAULT_DEVICE_LEVEL_TOLERANCE),
        "connect_to_board": _pref_get_bool("connect_to_board", True),
        "orthogonal_route": _pref_get_bool("orthogonal_route", True),
        "route_by_perimeter": _pref_get_bool("route_by_perimeter", True),
        "wall_margin": _pref_get_float("wall_margin", DEFAULT_WALL_OFFSET),
        "circuit_separation": float(sep),
        "reserve_ports": _pref_get_bool("reserve_ports", True),
        "skip_existing": _pref_get_bool("skip_existing", True),
        "debug_enabled": _pref_get_bool("debug_enabled", True),
    }


