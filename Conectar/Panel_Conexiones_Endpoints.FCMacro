def _safe_text(value):
    try:
        return str(value or "")
    except Exception:
        return ""


def _log(msg):
    App.Console.PrintMessage(f"[CONEX_PANEL][INFO] {msg}\n")


def _warn(msg):
    App.Console.PrintWarning(f"[CONEX_PANEL][WARN] {msg}\n")


def _err(msg):
    App.Console.PrintError(f"[CONEX_PANEL][ERROR] {msg}\n")


def _dbg(msg):
    if not DEBUG_ENABLED:
        return
    App.Console.PrintMessage(f"[CONEX_PANEL][DEBUG] {msg}\n")


def _is_group(obj):
    if obj is None:
        return False
    try:
        if obj.isDerivedFrom("App::DocumentObjectGroup"):
            return True
    except Exception:
        pass
    try:
        if obj.isDerivedFrom("App::Part"):
            return True
    except Exception:
        pass
    return hasattr(obj, "Group")


def _selection_objects():
    out = []
    seen = set()
    try:
        sel_ex = Gui.Selection.getSelectionEx() or []
    except Exception:
        sel_ex = []
    for sx in sel_ex:
        obj = getattr(sx, "Object", None)
        if obj is None or _is_group(obj):
            continue
        key = _safe_text(getattr(obj, "Name", "")).strip() or str(id(obj))
        if key in seen:
            continue
        seen.add(key)
        out.append(obj)
    if out:
        return out
    try:
        sel = Gui.Selection.getSelection() or []
    except Exception:
        sel = []
    for obj in sel:
        if obj is None or _is_group(obj):
            continue
        key = _safe_text(getattr(obj, "Name", "")).strip() or str(id(obj))
        if key in seen:
            continue
        seen.add(key)
        out.append(obj)
    return out


